            "dataType": "double",
            "sourceColumn": "Price"
          },
          {
            "name": "Quantity",
            "dataType": "int64",
            "sourceColumn": "Quantity"
          },
          {
            "name": "TotalCommission",
            "dataType": "double",
            "sourceColumn": "TotalCommission"
          },
          {
            "name": "TotalPrice",
            "dataType": "double",
            "sourceColumn": "TotalPrice"
          },
          {
            "name": "TradeId",
            "dataType": "int64",
            "sourceColumn": "TradeId"
          },
          {
            "name": "TradingStationId",
            "dataType": "int64",
            "sourceColumn": "TradingStationId"
          }
        ],
        "partitions": [
          {
            "name": "Partition",
            "dataView": "full",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Value.NativeQuery(#\"SQL/192 168 65 11;automationdw\", \"SELECT ",
                "\tft.TradeId",
                "\t  ,ft.Date",
                "\t  ,ft.CustomerId",
                "\t  ,ft.OrderSideId",
                "\t  ,ft.InstrumentId",
                "\t  ,ft.Quantity",
                "\t  ,ft.Price",
                "\t  ,ft.TotalPrice",
                "\t  ,ft.TradingStationId",
                "\t  ,ft.BrokerCommission",
                "\t  ,ft.TotalCommission",
                "\t  ,ft.bcom",
                "\t  FROM FactTrade ft",
                "\t  WHERE ft.IsCanceled=0 AND date>='2022-03-21'\")",
                "in",
                "    Source"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "Bcom1",
            "expression": "sum(FactTrade[bcom])"
          },
          {
            "name": "BPAVG",
            "expression": "[BTP]/[BQTY]"
          },
          {
            "name": "BQTY",
            "expression": "SUMX(FILTER(FactTrade,FactTrade[OrderSideId]=1),FactTrade[Quantity])"
          },
          {
            "name": "BTP",
            "expression": "SUMX(FILTER(FactTrade,FactTrade[OrderSideId]=1),FactTrade[TotalPrice])"
          },
          {
            "name": "PSellProfit",
            "expression": [
              "",
              "SWITCH(TRUE()",
              ",[BQTY]=[SQTY]&& not ISBLANK([BQTY]) &&  not ISBLANK([SQTY])\t ,([STP]/[BTP])-1",
              ",[BQTY]=[SQTY]&& not ISBLANK([BQTY]) &&  ISBLANK([SQTY])\t ,0",
              ",[BQTY]>[SQTY] &&  not ISBLANK([SQTY])  , ( [STP] / ([SQTY] * [BPAVG] ) ) - 1",
              ",BLANK()",
              "",
              ")",
              "",
              ""
            ],
            "formatString": "0.00%;-0.00%;0.00%"
          },
          {
            "name": "SellProfit",
            "expression": "if([BQTY]=[SQTY],[STP]-[BTP],IF([BQTY]>[SQTY],[STP]-([SQTY]*[BPAVG]),0))"
          },
          {
            "name": "SPAVG",
            "expression": "[STP]/[SQTY]"
          },
          {
            "name": "SQTY",
            "expression": "SUMX(FILTER(FactTrade,FactTrade[OrderSideId]=2),FactTrade[Quantity])"
          },
          {
            "name": "STP",
            "expression": "SUMX(FILTER(FactTrade,FactTrade[OrderSideId]=2),FactTrade[TotalPrice])"
          }
        ]
      },
      {
        "name": "HistoricalPortfolio",
        "columns": [
          {
            "name": "Asset",
            "dataType": "int64",
            "sourceColumn": "Asset"
          },
          {
            "name": "CustomerId",
            "dataType": "int64",
            "sourceColumn": "CustomerId"
          },
          {
            "name": "Date",
            "dataType": "dateTime",
            "sourceColumn": "Date"
          },
          {
            "name": "InstrumentId",
            "dataType": "int64",
            "sourceColumn": "InstrumentId"
          },
          {
            "name": "IsFreez",
            "dataType": "boolean",
            "sourceColumn": "IsFreez"
          },
          {
            "name": "Price",
            "dataType": "double",
            "sourceColumn": "Price"
          },
          {
            "name": "TotalPrice",
            "dataType": "double",
            "sourceColumn": "TotalPrice"
          }
        ],
        "partitions": [
          {
            "name": "Partition",
            "dataView": "full",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Value.NativeQuery(#\"SQL/192 168 65 11;TempHistorical\", \"SELECT [Date]",
                "\t  ,di.InstrumentId",
                "      ,[CustomerId]",
                "      ,[Asset]",
                "\t  ,[Price]",
                "      ,[Asset]*[Price] AS TotalPrice",
                "      ,[IsFreez]",
                "  FROM [TempHistorical].[dbo].[HistoricalPortfolio]",
                "  JOIN automationdw.dbo.DimInstrument di ON di.Isin = [InstrumentIsin]",
                "  WHERE Date = (SELECT MAX(date) FROM [TempHistorical].[dbo].[HistoricalPortfolio])\")",
                "in",
                "    Source"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "CBStats",
            "expression": [
              " SWITCH(",
              "TRUE(),",
              "[BQTY]=[SQTY] && [SQTY]>0 ,4,",
              "[BQTY]=[SellAndHpQty] ,1,",
              "[BQTY]>[SellAndHpQty] ,3,",
              "[BQTY]<[SellAndHpQty] ,2,5)"
            ]
          },
          {
            "name": "FilterCBstats",
            "expression": [
              " ",
              "var currentSelection = SELECTEDVALUE(CBStats[id])",
              "var currentClass = HistoricalPortfolio[CBStats]",
              "return",
              "SWITCH(TRUE(),",
              "currentSelection = 1 && currentClass = 1,1",
              ",currentSelection = 3 && currentClass = 3,1",
              ",currentSelection = 2 && currentClass = 2,1",
              ",currentSelection = 4 && currentClass = 4,1,",
              "currentSelection = 5 ,1,",
              "0)"
            ]
          },
          {
            "name": "HPQty",
            "expression": " sum(HistoricalPortfolio[Asset])"
          },
          {
            "name": "HPV",
            "expression": "SUM(HistoricalPortfolio[TotalPrice])"
          },
          {
            "name": "PTotalProfit",
            "expression": "if([BQTY]=[SQTY]+sum(HistoricalPortfolio[Asset]), (([STP]+[HPV]-[BTP])/[BTP]),0)",
            "formatString": "0.00%;-0.00%;0.00%"
          },
          {
            "name": "SellAndHpQty",
            "expression": " [SQTY]+[HPQty]"
          },
          {
            "name": "TotalProfit",
            "expression": " if([BQTY]=[SQTY]+sum(HistoricalPortfolio[Asset]),[STP]-[BTP]+[HPV],0)"
          }
        ]
      },
      {
        "name": "LastUpdate",
        "columns": [
          {
            "type": "calculatedTableColumn",
            "name": "ID",
            "dataType": "int64",
