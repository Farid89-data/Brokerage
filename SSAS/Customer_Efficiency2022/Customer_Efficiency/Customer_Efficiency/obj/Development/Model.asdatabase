        "partitions": [
          {
            "name": "CalculatedTable 1",
            "source": {
              "type": "calculated",
              "expression": [
                "SELECTCOLUMNS({(1,CALCULATE(max(DimDate[PersianStr]),filter(DimDate,DimDate[GregorianDate]=max(FactTrade[Date]))),\"FT\"),(2,CALCULATE(max(DimDate[PersianStr]),FILTER(DimDate,DimDate[GregorianDate]=max(HistoricalPortfolio[Date]))),\"HP\")",
                "},\"ID\",[Value1],\"Name\",[Value2],\"Type\",[Value3])"
              ]
            }
          }
        ]
      }
    ],
