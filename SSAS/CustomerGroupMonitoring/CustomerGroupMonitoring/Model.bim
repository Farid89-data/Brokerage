            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #\"SQL/192 168 65 11;AutomationDW\",",
                "",
                "    // Build a date with (current year - 1), fixed month/day",
                "    CurrentYear = Date.Year(Date.From(DateTime.LocalNow())),",
                "    DynamicDate = #date(CurrentYear - 1, 3, 21),",
                "    DynamicDateText = Date.ToText(DynamicDate, \"yyyy-MM-dd\"),",
                "",
                "    dbo_FactTrade =",
                "        Value.NativeQuery(",
                "            Source,",
                "            \"",
                "   SELECT ft.TradeId, ft.Date, ft.CustomerId, ft.OrderSideId, ft.InstrumentId,",
                "                   ft.Quantity, ft.Price, ft.TotalPrice, ft.TradingStationId, ft.bcom",
                "            FROM AutomationDW.dbo.FactTrade ft",
                "\t\t\tJOIN [RawDB].[bi].[GetCustomerGroups] ON ft.CustomerId=GetCustomerGroups.CustomerId",
                "            WHERE ft.IsCanceled = 0 AND CustomerGroupsId IN (202,208,240,285)",
                "              AND ft.Date >= @StartDate;",
                "            \",",
                "            [StartDate = DynamicDateText]",
                "        )",
                "in",
                "    dbo_FactTrade"
              ]
            },
