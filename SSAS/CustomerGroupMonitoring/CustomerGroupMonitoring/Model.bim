                "                , [BranchCityID]",
                "                , [BranchCityName]",
                "                , [BranchStateName]",
                "                , [BranchStatusID]",
                "                , [BranchStatusName]",
                "                , [BranchStatusID2]",
                "                , [StartDate]",
                "                , [MembershipAge]",
                "                , [MembershipAgeYear]",
                "                , [MembershipAgeMonth]",
                "                , [MarketerId]",
                "                , [MarketerName]",
                "                , [MarketerGenderName]",
                "                , [MarketerIsActiveName]",
                "                , [MarketerPersonTypeName]",
                "                , [InsertUserId]",
                "                , [InsertUserPersonName]",
                "                , [InsertUserGenderID]",
                "                , [InsertUserGenderName]",
                "                , [BourseCode]",
                "                , [ClientAccountNumber]",
                "                , [StationCredit]",
                "                , [IntroducerPersonId]",
                "                , [IntroducerPersonName]",
                "                , [ClubMemberShipDate]",
                "                , [CodeAccount]",
                "                , [IsForeigner]",
                "                , [CustomerFrom]",
                "\t\t\t\t,gg.*",
                "\t\t\t\t,CASE WHEN GroupId = 202 THEN N'کارا'",
                "\t\t\t\t   WHEN GroupId = 208 THEN N'آ.آتی'",
                "\t\t\t\t   WHEN GroupId = 240 THEN N'دماوند'",
                "\t\t\t\t   WHEN GroupId = 285 THEN N'نوین'",
                "\t\t\t\t  END AS ShortGroupName",
                "",
                "FROM [AutomationDW].[dbo].[DimCustomer] dc",
                "JOIN rawdb.bi.GetCustomerGroups gcg ON dc.CustomerId=gcg.CustomerId",
                "JOIN RawDB.bi.GetGroups gg ON gg.GroupId=gcg.CustomerGroupsId",
                "\tWHERE GroupId IN (202,208,240,285);",
                "",
                "            \"",
                "        )",
                "in",
                "    dbo_DimCustomer"
              ]
            },
