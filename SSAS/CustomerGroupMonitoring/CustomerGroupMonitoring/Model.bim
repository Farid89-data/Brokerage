          {
            "name": "Partition",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #\"SQL/192 168 65 11;AutomationDW\",",
                "",
                "    dbo_DimCustomer =",
                "        Value.NativeQuery(",
                "            Source,",
                "            \"",
                "  ",
                " SELECT ",
                "                  dc.[CustomerId]",
                "                , [PersonId]",
                "                , [IsFromSejam]",
                "                , [IsFromSejamName]",
                "                , [PersonTypeId]",
                "                , [PersonTypeName]",
