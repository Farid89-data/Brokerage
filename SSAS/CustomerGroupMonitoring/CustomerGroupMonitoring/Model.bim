      {
        "name": "FactFixedIncomeTrade",
        "columns": [
          {
            "name": "Date",
            "dataType": "dateTime",
            "sourceColumn": "date"
          },
          {
            "name": "OrderSideId",
            "dataType": "int64",
            "sourceColumn": "OrderSideId"
          },
          {
            "name": "OrderSideName",
            "dataType": "string",
            "sourceColumn": "OrderSideName"
          },
          {
            "name": "ShortName",
            "dataType": "string",
            "sourceColumn": "ShortName"
          },
          {
            "name": "TotalPrice",
            "dataType": "double",
            "sourceColumn": "TotalPrice"
          }
        ],
        "partitions": [
          {
            "name": "Partition",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #\"SQL/192 168 65 11;AutomationDW\",",
                "",
                "    // تاریخ امروز",
                "    Today = Date.From(DateTimeZone.SwitchZone(DateTimeZone.LocalNow(), 0)),",
                "",
                "    // فقط سال را یک سال کم می‌کنیم",
                "    YearAgo = Date.Year(Today) - 1,",
                "",
                "    // ماه و روز ثابت",
                "    FixedMonth = \"03\",",
                "    FixedDay   = \"21\",",
                "",
                "    // ساخت تاریخ نهایی",
                "    FixedDate = Text.From(YearAgo) & \"-\" & FixedMonth & \"-\" & FixedDay,",
                "",
                "    // اجرای SQL به صورت پارامتری",
                "    Result =",
                "        Value.NativeQuery(",
                "            Source,",
                "\"",
                "SELECT ",
                "    ft.date,",
                "    di.ShortName,ft.OrderSideId,CASE WHEN ft.OrderSideId=1 THEN N'خرید' WHEN ft.OrderSideId=2 THEN N'فروش' END AS OrderSideName ,",
                "    SUM(ft.TotalPrice) AS TotalPrice",
                "FROM [AutomationDW].[dbo].[FactTrade] ft",
                "JOIN [AutomationDW].[dbo].[DimInstrument] di ",
                "    ON di.InstrumentId = ft.InstrumentId",
                "WHERE ft.IsCanceled = 0",
                "  AND (di.ShortName LIKE N'%آکورد%' ",
                "       OR di.ShortName LIKE N'%صنهال%' )",
                "  AND ft.Date >= @FixDate",
                "GROUP BY ft.date, di.ShortName,ft.OrderSideId",
                "\",",
                "            [FixDate = FixedDate]",
                "        )",
                "in",
                "    Result"
              ]
            },
            "annotations": [
              {
                "name": "QueryEditorSerialization",
                "value": [
                  "<?xml version=\"1.0\" encoding=\"UTF-16\"?><Gemini xmlns=\"QueryEditorSerialization\"><AnnotationContent><![CDATA[<RSQueryCommandText>let",
                  "    Source = #\"SQL/192 168 65 11;AutomationDW\",",
                  "",
                  "    // تاریخ امروز",
                  "    Today = Date.From(DateTimeZone.SwitchZone(DateTimeZone.LocalNow(), 0)),",
                  "",
                  "    // فقط سال را یک سال کم می‌کنیم",
                  "    YearAgo = Date.Year(Today) - 1,",
                  "",
                  "    // ماه و روز ثابت",
                  "    FixedMonth = \"03\",",
                  "    FixedDay   = \"21\",",
                  "",
                  "    // ساخت تاریخ نهایی",
                  "    FixedDate = Text.From(YearAgo) & \"-\" & FixedMonth & \"-\" & FixedDay,",
                  "",
                  "    // اجرای SQL به صورت پارامتری",
                  "    Result =",
                  "        Value.NativeQuery(",
                  "            Source,",
                  "\"",
                  "SELECT ",
                  "    ft.date,",
                  "    di.ShortName,ft.OrderSideId,CASE WHEN ft.OrderSideId=1 THEN N'خرید' WHEN ft.OrderSideId=2 THEN N'فروش' END AS OrderSideName ,",
                  "    SUM(ft.TotalPrice) AS TotalPrice",
                  "FROM [AutomationDW].[dbo].[FactTrade] ft",
                  "JOIN [AutomationDW].[dbo].[DimInstrument] di ",
                  "    ON di.InstrumentId = ft.InstrumentId",
                  "WHERE ft.IsCanceled = 0",
                  "  AND (di.ShortName LIKE N'%آکورد%' ",
                  "       OR di.ShortName LIKE N'%صنهال%' )",
                  "  AND ft.Date >= @FixDate",
                  "GROUP BY ft.date, di.ShortName,ft.OrderSideId",
                  "\",",
                  "            [FixDate = FixedDate]",
                  "        )",
                  "in",
                  "    Result</RSQueryCommandText><RSQueryCommandType>Text</RSQueryCommandType><RSQueryDesignState></RSQueryDesignState>]]></AnnotationContent></Gemini>"
                ]
              }
            ]
          }
        ]
      },
