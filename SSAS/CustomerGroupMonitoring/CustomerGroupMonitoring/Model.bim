    "tables": [
      {
        "name": "BcomRollUp",
        "columns": [
          {
            "name": "Bazar",
            "dataType": "string",
            "sourceColumn": "Bazar"
          },
          {
            "name": "bcom",
            "dataType": "double",
            "sourceColumn": "bcom"
          },
          {
            "name": "CustomerId",
            "dataType": "int64",
            "sourceColumn": "CustomerId"
          },
          {
            "name": "Date",
            "dataType": "dateTime",
            "sourceColumn": "Date"
          }
        ],
        "partitions": [
          {
            "name": "Partition",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = #\"SQL/192 168 65 11;AutomationDW\",",
                "",
                "    // تاریخ امروز",
                "    Today = Date.From(DateTimeZone.SwitchZone(DateTimeZone.LocalNow(), 0)),",
                "",
                "    // سال یک سال قبل",
                "    YearAgo = Date.Year(Today) - 1,",
                "",
                "    // ماه و روز ثابت (۳/۲۱)",
                "    FixedMonth = \"03\",",
                "    FixedDay   = \"21\",",
                "",
                "    // ساخت تاریخ نهایی",
                "    FixedDate = Text.From(YearAgo) & \"-\" & FixedMonth & \"-\" & FixedDay,",
                "",
                "    Result =",
                "        Value.NativeQuery(",
                "            Source,",
                "\"",
                "SELECT ",
                "    ft.Date,",
                "    ft.CustomerId,",
                "    SUM(ft.bcom) AS bcom,N'اوراق' AS Bazar",
                "FROM AutomationDW.dbo.FactTrade ft",
                "JOIN RawDB.bi.GetCustomerGroups gcg ",
                "    ON ft.CustomerId = gcg.CustomerId",
                "WHERE ft.IsCanceled = 0",
                "  AND ft.Date >= @CutDate",
                "  AND gcg.CustomerGroupsId IN (202,208,240,285)",
                "GROUP BY ft.Date, ft.CustomerId",
                "",
                "UNION",
                "",
                "SELECT ",
                "    fft.Date,",
                "    fft.CustomerId,",
                "    SUM(fft.BrokerCommission) AS bcom,N'آتی' AS Bazar",
                "FROM AutomationDW.dbo.FactFeutureTrade fft",
                "JOIN RawDB.bi.GetCustomerGroups gcg ",
                "    ON fft.CustomerId = gcg.CustomerId",
                "WHERE fft.Date >= @CutDate",
                "  AND gcg.CustomerGroupsId IN (202,208,240,285)",
                "GROUP BY fft.Date, fft.CustomerId",
                "\",",
                "            [CutDate = FixedDate]",
                "        )",
                "in",
                "    Result"
              ]
            },
            "annotations": [
              {
                "name": "QueryEditorSerialization",
                "value": [
                  "<?xml version=\"1.0\" encoding=\"UTF-16\"?><Gemini xmlns=\"QueryEditorSerialization\"><AnnotationContent><![CDATA[<RSQueryCommandText>let",
                  "    Source = #\"SQL/192 168 65 11;AutomationDW\",",
                  "",
                  "    // تاریخ امروز",
                  "    Today = Date.From(DateTimeZone.SwitchZone(DateTimeZone.LocalNow(), 0)),",
                  "",
                  "    // سال یک سال قبل",
                  "    YearAgo = Date.Year(Today) - 1,",
                  "",
                  "    // ماه و روز ثابت (۳/۲۱)",
                  "    FixedMonth = \"03\",",
                  "    FixedDay   = \"21\",",
                  "",
                  "    // ساخت تاریخ نهایی",
                  "    FixedDate = Text.From(YearAgo) & \"-\" & FixedMonth & \"-\" & FixedDay,",
                  "",
                  "    Result =",
                  "        Value.NativeQuery(",
                  "            Source,",
                  "\"",
                  "SELECT ",
                  "    ft.Date,",
                  "    ft.CustomerId,",
                  "    SUM(ft.bcom) AS bcom",
                  "FROM AutomationDW.dbo.FactTrade ft",
                  "JOIN RawDB.bi.GetCustomerGroups gcg ",
                  "    ON ft.CustomerId = gcg.CustomerId",
                  "WHERE ft.IsCanceled = 0",
                  "  AND ft.Date >= @CutDate",
                  "  AND gcg.CustomerGroupsId IN (202,208,240,285)",
                  "GROUP BY ft.Date, ft.CustomerId",
                  "",
                  "UNION",
                  "",
                  "SELECT ",
                  "    fft.Date,",
                  "    fft.CustomerId,",
                  "    SUM(fft.BrokerCommission) AS bcom",
                  "FROM AutomationDW.dbo.FactFeutureTrade fft",
                  "JOIN RawDB.bi.GetCustomerGroups gcg ",
                  "    ON fft.CustomerId = gcg.CustomerId",
                  "WHERE fft.Date >= @CutDate",
                  "  AND gcg.CustomerGroupsId IN (202,208,240,285)",
                  "GROUP BY fft.Date, fft.CustomerId",
                  "\",",
                  "            [CutDate = FixedDate]",
                  "        )",
                  "in",
                  "    Result</RSQueryCommandText><RSQueryCommandType>Text</RSQueryCommandType><RSQueryDesignState></RSQueryDesignState>]]></AnnotationContent></Gemini>"
                ]
              }
            ]
          }
        ]
      },
