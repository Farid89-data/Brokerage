    "expressions": [
      {
        "name": "BcomMarketer",
        "kind": "m",
        "expression": [
          "let",
          "    Source = Value.NativeQuery(#\"SQL/192 168 65 11;automationdw\", \"SELECT dd.PersianYearMonthInt,dm.MarketerTypeId,dc.MarketerId,SUM(ft.bcom) AS Bcom",
          ", PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) AS PercentileBcom",
          ",CASE  WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) <= 1 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) > 0.75 THEN 1",
          "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) <= 0.75 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) > 0.5 THEN 2",
          "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) <= 0.5 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) > 0.25 THEN 3",
          "ELSE 4 END AS PercentileRankBcom ",
          "FROM FactTrade ft",
          "JOIN DimDate dd ON ft.Date = dd.GregorianDate",
          "JOIN DimCustomer dc ON dc.CustomerId=ft.CustomerId",
          "JOIN DimMarketer dm ON dc.MarketerId=dm.MarketerId",
          "WHERE dd.PersianYearMonthInt>=140201 AND ft.IsCanceled = 0 AND dc.MarketerId <> -1",
          "GROUP BY dd.PersianYearMonthInt,dm.MarketerTypeId,dc.MarketerId\")",
          "in",
