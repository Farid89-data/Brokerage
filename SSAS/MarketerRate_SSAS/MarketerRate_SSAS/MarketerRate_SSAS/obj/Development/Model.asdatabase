          "WHERE dd.PersianYearMonthInt>=140201 AND  fcb.ChangeBrokerStateId = 4 AND dc.MarketerId <>-1",
          "GROUP BY dd.PersianYearMonthInt,dm.MarketerTypeId,dc.MarketerId\")",
          "in",
          "    Source"
        ]
      },
      {
        "name": "RegCountMarketer",
        "kind": "m",
        "expression": [
          "let",
          "    Source = Value.NativeQuery(#\"SQL/192 168 65 11;automationdw\", \"SELECT  dd.PersianYearMonthInt,dm.MarketerTypeId,dc.MarketerId,SUM(dc.IsStockMarketCustomer) AS RegCount ",
          ",PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) AS PercentileRegCount",
          ",CASE  WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) <= 1 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) > 0.75 THEN 1",
          "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) <= 0.75 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) > 0.5 THEN 2",
          "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) <= 0.5 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) > 0.25 THEN 3",
          "ELSE 4 END AS PercentileRankRegCount ",
          "",
          "FROM DimCustomer dc",
          "JOIN DimDate dd ON dd.GregorianDate=dc.StartDate",
