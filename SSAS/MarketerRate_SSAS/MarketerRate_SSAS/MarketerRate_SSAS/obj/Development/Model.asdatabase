          "SELECT dd.PersianYearMonthInt,dm.MarketerTypeId,dc.MarketerId, COUNT(*) AS CBCount ,",
          "PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) AS PercentileCBCount",
          ",CASE  WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) <= 1 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) > 0.75 THEN 1",
          "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) <= 0.75 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) > 0.5 THEN 2",
          "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) <= 0.5 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) > 0.25 THEN 3",
          "ELSE 4 END AS PercentileRankCBCount ",
