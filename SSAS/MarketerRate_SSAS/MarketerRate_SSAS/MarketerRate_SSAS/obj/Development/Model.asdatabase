      {
        "name": "BcomMarketer",
        "columns": [
          {
            "name": "PersianYearMonthInt",
            "dataType": "int64",
            "sourceColumn": "PersianYearMonthInt"
          },
          {
            "name": "MarketerTypeId",
            "dataType": "int64",
            "sourceColumn": "MarketerTypeId"
          },
          {
            "name": "MarketerId",
            "dataType": "int64",
            "sourceColumn": "MarketerId"
          },
          {
            "name": "Bcom",
            "dataType": "double",
            "sourceColumn": "Bcom"
          },
          {
            "name": "PercentileBcom",
            "dataType": "double",
            "sourceColumn": "PercentileBcom"
          },
          {
            "name": "PercentileRankBcom",
            "dataType": "int64",
            "sourceColumn": "PercentileRankBcom"
          },
          {
            "type": "calculated",
            "name": "OverallBcom",
            "dataType": "double",
            "isDataTypeInferred": true,
            "expression": "CALCULATE(sum(BcomMarketer[Bcom]),ALLEXCEPT(BcomMarketer,BcomMarketer[PersianYearMonthInt],BcomMarketer[MarketerTypeId]))"
          },
          {
            "type": "calculated",
            "name": "RatioBcom",
            "dataType": "double",
            "isDataTypeInferred": true,
            "expression": " ROUNDUP( BcomMarketer[Bcom]/BcomMarketer[OverallBcom],4)"
          }
        ],
        "partitions": [
          {
            "name": "Partition",
            "dataView": "full",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Value.NativeQuery(#\"SQL/192 168 65 11;automationdw\", \"SELECT dd.PersianYearMonthInt,dm.MarketerTypeId,dc.MarketerId,SUM(ft.bcom) AS Bcom",
                ", PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) AS PercentileBcom",
                ",CASE  WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) <= 1 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) > 0.75 THEN 1",
                "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) <= 0.75 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) > 0.5 THEN 2",
                "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) <= 0.5 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(ft.bcom)) > 0.25 THEN 3",
                "ELSE 4 END AS PercentileRankBcom ",
                "FROM FactTrade ft",
                "JOIN DimDate dd ON ft.Date = dd.GregorianDate",
                "JOIN DimCustomer dc ON dc.CustomerId=ft.CustomerId",
                "JOIN DimMarketer dm ON dc.MarketerId=dm.MarketerId",
                "WHERE dd.PersianYearMonthInt>=140201 AND ft.IsCanceled = 0 AND dc.MarketerId <> -1",
                "GROUP BY dd.PersianYearMonthInt,dm.MarketerTypeId,dc.MarketerId\")",
                "in",
                "    Source"
              ]
            }
          }
        ],
        "measures": [
          {
            "name": "TotalRatio",
            "expression": " (0.75 *sum( BcomMarketer[RatioBcom]))+(0.15 *sum(CBMarketer[RatioCBCount]))+(0.1*sum(RegCountMarketer[RatioRegCount]))"
          }
        ]
      },
      {
        "name": "CBMarketer",
        "columns": [
          {
            "name": "PersianYearMonthInt",
            "dataType": "int64",
            "sourceColumn": "PersianYearMonthInt"
          },
          {
            "name": "MarketerTypeId",
            "dataType": "int64",
            "sourceColumn": "MarketerTypeId"
          },
          {
            "name": "MarketerId",
            "dataType": "int64",
            "sourceColumn": "MarketerId"
          },
          {
            "name": "CBCount",
            "dataType": "int64",
            "sourceColumn": "CBCount"
          },
          {
            "name": "PercentileCBCount",
            "dataType": "double",
            "sourceColumn": "PercentileCBCount"
          },
          {
            "name": "PercentileRankCBCount",
            "dataType": "int64",
            "sourceColumn": "PercentileRankCBCount"
          },
          {
            "type": "calculated",
            "name": "OverallCBCount",
            "dataType": "int64",
            "isDataTypeInferred": true,
            "expression": "CALCULATE(sum(CBMarketer[CBCount]),ALLEXCEPT(CBMarketer,CBMarketer[PersianYearMonthInt],CBMarketer[MarketerTypeId]))"
          },
          {
            "type": "calculated",
            "name": "RatioCBCount",
            "dataType": "double",
            "isDataTypeInferred": true,
            "expression": "if(ISBLANK(ROUNDUP(CBMarketer[CBCount]/CBMarketer[OverallCBCount],4)),0,ROUNDUP(CBMarketer[CBCount]/CBMarketer[OverallCBCount],4))"
          }
        ],
        "partitions": [
          {
            "name": "Partition",
            "dataView": "full",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Value.NativeQuery(#\"SQL/192 168 65 11;automationdw\", \"",
                "SELECT dd.PersianYearMonthInt,dm.MarketerTypeId,dc.MarketerId, COUNT(*) AS CBCount ,",
                "PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) AS PercentileCBCount",
                ",CASE  WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) <= 1 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) > 0.75 THEN 1",
                "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) <= 0.75 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) > 0.5 THEN 2",
                "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) <= 0.5 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by COUNT(*)) > 0.25 THEN 3",
                "ELSE 4 END AS PercentileRankCBCount ",
                "",
                "FROM FactChangeBroker fcb",
                "JOIN DimDate dd ON dd.GregorianDate=fcb.Date",
                "JOIN DimCustomer dc ON dc.CustomerId=fcb.CustomerId",
                "JOIN DimMarketer dm ON dc.MarketerId=dm.MarketerId",
                "WHERE dd.PersianYearMonthInt>=140201 AND  fcb.ChangeBrokerStateId = 4 AND dc.MarketerId <>-1",
                "GROUP BY dd.PersianYearMonthInt,dm.MarketerTypeId,dc.MarketerId\")",
                "in",
                "    Source"
              ]
            }
          }
        ]
      },
      {
        "name": "RegCountMarketer",
        "columns": [
          {
            "name": "PersianYearMonthInt",
            "dataType": "int64",
            "sourceColumn": "PersianYearMonthInt"
          },
          {
            "name": "MarketerTypeId",
            "dataType": "int64",
            "sourceColumn": "MarketerTypeId"
          },
          {
            "name": "MarketerId",
            "dataType": "int64",
            "sourceColumn": "MarketerId"
          },
          {
            "name": "RegCount",
            "dataType": "int64",
            "sourceColumn": "RegCount"
          },
          {
            "name": "PercentileRegCount",
            "dataType": "double",
            "sourceColumn": "PercentileRegCount"
          },
          {
            "name": "PercentileRankRegCount",
            "dataType": "int64",
            "sourceColumn": "PercentileRankRegCount"
          },
          {
            "type": "calculated",
            "name": "OverallRegCount",
            "dataType": "int64",
            "isDataTypeInferred": true,
            "expression": " CALCULATE(sum(RegCountMarketer[RegCount]),ALLEXCEPT(RegCountMarketer,RegCountMarketer[PersianYearMonthInt],RegCountMarketer[MarketerTypeId]))"
          },
          {
            "type": "calculated",
            "name": "RatioRegCount",
            "dataType": "double",
            "isDataTypeInferred": true,
            "expression": "ROUNDUP( RegCountMarketer[RegCount]/RegCountMarketer[OverallRegCount],4)"
          }
        ],
        "partitions": [
          {
            "name": "Partition",
            "dataView": "full",
            "source": {
              "type": "m",
              "expression": [
                "let",
                "    Source = Value.NativeQuery(#\"SQL/192 168 65 11;automationdw\", \"SELECT  dd.PersianYearMonthInt,dm.MarketerTypeId,dc.MarketerId,SUM(dc.IsStockMarketCustomer) AS RegCount ",
                ",PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) AS PercentileRegCount",
                ",CASE  WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) <= 1 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) > 0.75 THEN 1",
                "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) <= 0.75 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) > 0.5 THEN 2",
                "WHEN PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) <= 0.5 AND PERCENT_RANK() OVER (PARTITION BY dm.MarketerTypeId ORDER by SUM(dc.IsStockMarketCustomer)) > 0.25 THEN 3",
                "ELSE 4 END AS PercentileRankRegCount ",
                "",
                "FROM DimCustomer dc",
                "JOIN DimDate dd ON dd.GregorianDate=dc.StartDate",
                "JOIN DimMarketer dm ON dc.MarketerId=dm.MarketerId",
                "",
                "WHERE dd.PersianYearMonthInt>=140201 AND dc.MarketerId <>-1",
                "GROUP BY dd.PersianYearMonthInt,dm.MarketerTypeId,dc.MarketerId\")",
                "in",
                "    Source"
              ]
            }
          }
        ]
      }
    ],
