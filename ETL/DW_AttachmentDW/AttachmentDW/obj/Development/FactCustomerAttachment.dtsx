          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{A999BB46-705E-448D-8965-C0CC005655BB}"
              SQLTask:SqlStatementSource="INSERT INTO [AttachmentDW].[dbo].FactCustomerAttachment ([CustomerAttachmenCustomerId],[AttachmentTypeId],&#xA;[CustomerAttachmenInsertDate],[AttachmentCategoryID],[DimAttachmentTypeID])&#xA;&#x9;SELECT Distinct [CustomerAttachment].[CustomerId],[CustomerAttachment].[AttachmentTypeId],CONVERT(DATE,[InsertDateTime]),[AttachmentCategoryID] AS DATE ,[DimAttachmentTypeID]&#xA;       FROM [AttachmentStage].[dbo].[CustomerAttachment]&#xA;       INNER JOIN [AttachmentDW].[dbo].[DimAttachmentType]&#xA;           ON [AttachmentStage].[dbo].[CustomerAttachment].[AttachmentTypeId]=[AttachmentDW].[dbo].[DimAttachmentType].[AttachmentTypeId]" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
