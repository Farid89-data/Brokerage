        <DTS:Executable
          DTS:refId="Package\Sequence Container\Update date Controller"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{88edd062-81a1-4115-8c35-4b47b269ef8c}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Update date Controller"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{A9BF166E-7F74-4D19-9FEE-E7BA384E0954}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="DECLARE @StartDateTime date&#xA;DECLARE @EndDateTime date&#xA;&#xA;SET @StartDateTime = (SELECT MAX(OriginalDate) FROM DbController)&#xA;SET @EndDateTime = Convert(DATE,GETDATE());&#xA;&#xA;WITH DateRange(DateData) AS &#xA;(&#xA;   SELECT DATEADD(d,1,@StartDateTime) AS date&#xA;    UNION ALL&#xA;    SELECT DATEADD(d,1,DateData)&#xA;    FROM DateRange &#xA;    WHERE DateData &lt; @EndDateTime &#xA;&#xA;)&#xA;&#xA;INSERT [dbo].[DbController] (OriginalDate,DEVEN)&#xA;SELECT DateData,CAST(CONVERT(char(8),DateData,112) as int)&#xA;FROM DateRange &#xA;WHERE DateData &lt; @EndDateTime&#xA;OPTION (MAXRECURSION 0)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
