            <SQLTask:SqlTaskData
              SQLTask:Connection="{A9BF166E-7F74-4D19-9FEE-E7BA384E0954}"
              SQLTask:SqlStatementSource="Drop table if exists Instrument&#xA;CREATE TABLE Instrument (&#xA;  ID INT IDENTITY&#xA; ,InsertDate SMALLDATETIME NULL&#xA; ,deven INT NULL&#xA; ,inscode BIGINT NULL&#xA; ,instrumentid NCHAR(100) NULL&#xA; ,cvalmne NCHAR(60) NULL&#xA; ,lval18 NCHAR(60) NULL&#xA; ,csoccsac NCHAR(60) NULL&#xA; ,lsoc30 NCHAR(60) NULL&#xA; ,lval18afc NCHAR(60) NULL&#xA; ,lval30 NCHAR(60) NULL&#xA; ,cisin NCHAR(60) NULL&#xA; ,qnmvlo DECIMAL(18, 2) NULL&#xA; ,ztitad NCHAR(60) NULL&#xA; ,desop INT NULL&#xA; ,yopsj SMALLINT NULL&#xA; ,cgdsval NCHAR(60) NULL&#xA; ,cgrvalcot NCHAR(60) NULL&#xA; ,dinmar INT NULL&#xA; ,yuniexpp INT NULL&#xA; ,ymarnsc NCHAR(60) NULL&#xA; ,ccomval INT NULL&#xA; ,csecval NCHAR(60) NULL&#xA; ,csosecval NCHAR(60) NULL&#xA; ,ydecomp SMALLINT NULL&#xA; ,psaismaxokvalmdv INT NULL&#xA; ,psaisminokvalmdv INT NULL&#xA; ,basevol INT NULL&#xA; ,yval INT NULL&#xA; ,qpascotfxeval DECIMAL NULL&#xA; ,qqttranmarval INT NULL&#xA; ,Flow INT NULL&#xA; ,qtitminsaiomprod INT NULL&#xA; ,qtitmaxsaiomprod INT NULL&#xA; ,valid INT NULL&#xA; ,Hashvalue AS (HASHBYTES('MD5', CONCAT_WS('|', [inscode], [instrumentid], [cvalmne], [lval18], [csoccsac], [lsoc30], [lval18afc], [lval30], [cisin], [qnmvlo], [ztitad], [desop], [yopsj], [cgdsval], [cgrvalcot], [dinmar], [yuniexpp], [ymarnsc], [ccomval], [csecval], [csosecval], [ydecomp], [psaismaxokvalmdv], [psaisminokvalmdv], [basevol], [yval], [qpascotfxeval], [qqttranmarval], [Flow], [qtitminsaiomprod], [qtitmaxsaiomprod], [valid])))&#xA;) ON [PRIMARY]&#xA;WITH (DATA_COMPRESSION = PAGE)&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
