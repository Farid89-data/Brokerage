        <DTS:Executable
          DTS:refId="Package\TradeOneDay\Update date Controller"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{A5946974-2829-4601-8397-85FAE841B594}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Update date Controller"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{A9BF166E-7F74-4D19-9FEE-E7BA384E0954}"
              SQLTask:SqlStatementSource="DECLARE @StartDateTime date&#xA;DECLARE @EndDateTime date&#xA;&#xA;SET @StartDateTime =DATEADD(d,1,CONVERT (datetime,convert(char(8),(SELECT MAX([DEVEN]) FROM [DBControllerWithFlow])))) ;&#xA;SET @EndDateTime = CONVERT(char(8),GETDATE(),112);&#xA;&#xA;WITH DateRange(DateData) AS &#xA;(&#xA;    SELECT @StartDateTime AS date&#xA;    UNION ALL&#xA;    SELECT DATEADD(d,1,DateData)&#xA;    FROM DateRange &#xA;    WHERE DateData &lt; @EndDateTime AND @StartDateTime&lt;@EndDateTime&#xA;&#xA;)&#xA;&#xA;INSERT [DBControllerWithFlow] (DEVEN,Flow)&#xA;SELECT CAST(CONVERT(char(8),DateData,112) as int),ID&#xA;FROM DateRange,FlowTable &#xA;WHERE DateData &lt; @EndDateTime&#xA;OPTION (MAXRECURSION 0)&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
