          DTS:From="Package\TradeOneDay\Update date Controller"
          DTS:LogicalAnd="True"
          DTS:ObjectName="Constraint"
          DTS:To="Package\TradeOneDay\For Loop Container" />
      </DTS:PrecedenceConstraints>
