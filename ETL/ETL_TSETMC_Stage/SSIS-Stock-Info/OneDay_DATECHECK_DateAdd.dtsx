      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{6CD5F404-BB43-444C-B9D3-56419DE16AF8}"
          SQLTask:SqlStatementSource="DECLARE @dd INT = CAST(CONVERT(char(8),GETDATE(),112) as int)&#xA;BEGIN&#xA;   IF NOT EXISTS (SELECT deven FROM  OneDay_DATECHECK WHERE deven=@dd )&#xA;   BEGIN&#xA;       INSERT INTO OneDay_DATECHECK &#xA;       VALUES (GETDATE(),FORMAT(GETDATE(),'yyyy'),FORMAT(GETDATE(),'MM'),FORMAT(GETDATE(),'dd'),@dd,0,0,0,0)&#xA;   END&#xA;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
