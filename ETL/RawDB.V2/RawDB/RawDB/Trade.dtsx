            <SQLTask:SqlTaskData
              SQLTask:Connection="{2C29B200-2F22-487B-A7EB-B2FCA432F505}"
              SQLTask:SqlStatementSource="&#xA;  DECLARE @MaxDate DATE&#xA;SET @MaxDate=(SELECT MAX(date) FROM RawDB.bi.Trade t) &#xA;DECLARE @StartDate DATE&#xA;SET @StartDate=(SELECT DATEADD(DAY,-30, MAX(date)) FROM RawDB.bi.Trade t) &#xA;DELETE FROM rawdb.bi.Trade &#xA;WHERE Date BETWEEN DATEADD(day,-30,  @MaxDate) AND @MaxDate&#xA;&#xA;  INSERT into bi.Trade ([Id]&#xA;      ,[DateTime]&#xA;      ,[CustomerId]&#xA;      ,[UnixDateTime]&#xA;      ,[OrderSideId]&#xA;      ,[InstrumentId]&#xA;      ,[Quantity]&#xA;      ,[Price]&#xA;      ,[TradingStationId]&#xA;      ,[OrderEntrydate]&#xA;      ,[OrderSequence]&#xA;      ,[BrokerCommission]&#xA;      ,[TotalCommission]&#xA;      ,[OriginalOrderPrice]&#xA;      ,[is_canceled]&#xA;      ,[MarketId]&#xA;      ,[Is_Online_Station]&#xA;      ,[Isin]&#xA;      ,[OriginOfTransaction]&#xA;      ,[Account]&#xA;      ,[HasRemaining]&#xA;      ,[ClubBrokerCommission]&#xA;      ,[TotalPrice]&#xA;      ,[Date]&#xA;      ,[Time])&#x9;&#xA;&#xA;SELECT [Id]&#xA;      ,[DateTime]&#xA;      ,[CustomerId]&#xA;      ,[UnixDateTime]&#xA;      ,[OrderSideId]&#xA;      ,[InstrumentId]&#xA;      ,[Quantity]&#xA;      ,[Price]&#xA;      ,[TradingStationId]&#xA;      ,[OrderEntrydate]&#xA;      ,[OrderSequence]&#xA;      ,[BrokerCommission]&#xA;      ,[TotalCommission]&#xA;      ,[OriginalOrderPrice]&#xA;      ,[is_canceled]&#xA;      ,[MarketId]&#xA;      ,[Is_Online_Station]&#xA;      ,[Isin]&#xA;      ,[OriginOfTransaction]&#xA;      ,[Account]&#xA;      ,[HasRemaining]&#xA;      ,[ClubBrokerCommission] , t.Price* t.Quantity AS [TotalPrice] , CONVERT (DATE , t.DateTime) AS Date , CONVERT(TIME(0),t.DateTime) AS Time&#xA;FROM [192.168.60.11].Automation.[bi].[Trade]  t &#xA;&#x9;WHERE t.date BETWEEN  CONVERT( int, CONVERT( nchar(8), @StartDate, 112 ) ) AND  CONVERT( int, CONVERT( nchar(8), CONVERT(DATE, GETDATE()), 112 ) )&#xA;&#xA;&#x9;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
