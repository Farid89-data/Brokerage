          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{1B307589-DB4F-4749-B725-D1F9947C665E}"
              SQLTask:SqlStatementSource="IF NOT EXISTS(SELECT * FROM sys.schemas WHERE name = N'bi')&#xA;BEGIN&#xA;EXEC(N'CREATE SCHEMA [bi]')&#xA;END&#xA;CREATE TABLE [bi].[SubSector] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(250),&#xA;[SecorId] int&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[Trade] (&#xA;[Id] bigint NOT NULL,&#xA;[DateTime] datetime NOT NULL,&#xA;[CustomerId] int,&#xA;[UnixDateTime] int,&#xA;[OrderSideId] int NOT NULL,&#xA;[InstrumentId] int,&#xA;[Quantity] bigint NOT NULL,&#xA;[Price] money NOT NULL,&#xA;[TradingStationId] int,&#xA;[OrderEntrydate] int,&#xA;[OrderSequence] int,&#xA;[BrokerCommission] decimal(38,5),&#xA;[TotalCommission] decimal(38,5),&#xA;[OriginalOrderPrice] money&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[TradingStation] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(50) NOT NULL,&#xA;[StockTypeId] int NOT NULL,&#xA;[IsOnlineStation] int&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[User] (&#xA;[Id] int NOT NULL,&#xA;[IsActive] int,&#xA;[PersonName] nvarchar(100) NOT NULL,&#xA;[PersonId] int,&#xA;[GenderId] int NOT NULL,&#xA;[BirthDate] date,&#xA;[HomeLocationId] int,&#xA;[BranchId] int,&#xA;[ContractStartDate] date,&#xA;[ContractEndDate] date&#xA;)&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
