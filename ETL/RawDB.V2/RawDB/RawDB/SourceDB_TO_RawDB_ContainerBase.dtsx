              SQLTask:SqlStatementSource="IF NOT EXISTS(SELECT * FROM sys.schemas WHERE name = N'bi')&#xA;BEGIN&#xA;EXEC(N'CREATE SCHEMA [bi]')&#xA;END&#xA;CREATE TABLE [bi].[HistoricalRemain] (&#xA;[Date] date NOT NULL,&#xA;[StockTypeId] int NOT NULL,&#xA;[CustomerId] int NOT NULL,&#xA;[Remain] decimal(22,9) NOT NULL,&#xA;[DampingRemain] decimal(22,9) NOT NULL,&#xA;[Cost] decimal(38,15)&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[Instrument] (&#xA;[Id] int NOT NULL,&#xA;[Isin] nvarchar(12) NOT NULL,&#xA;[Name] nvarchar(30) NOT NULL,&#xA;[ShortName] nvarchar(18) NOT NULL,&#xA;[SectorId] int,&#xA;[SubSectorId] int&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[Job] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(100) NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[Marketer] (&#xA;[Id] int NOT NULL,&#xA;[StartDate] date NOT NULL,&#xA;[EndDate] date,&#xA;[IsActive] int NOT NULL,&#xA;[PersonId] int NOT NULL,&#xA;[MarketerName] nvarchar(100) NOT NULL,&#xA;[PersonTypeId] int NOT NULL,&#xA;[GenderId] int NOT NULL,&#xA;[HomeLocationId] int,&#xA;[BranchId] int&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[MarriedState] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(50) NOT NULL&#xA;)&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
