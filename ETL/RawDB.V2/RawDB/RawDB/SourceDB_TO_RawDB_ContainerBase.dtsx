              SQLTask:SqlStatementSource="IF NOT EXISTS(SELECT * FROM sys.schemas WHERE name = N'bi')&#xA;BEGIN&#xA;EXEC(N'CREATE SCHEMA [bi]')&#xA;END&#xA;CREATE TABLE [bi].[Customer] (&#xA;[Id] int NOT NULL,&#xA;[PersonId] int NOT NULL,&#xA;[ClubMemberId] int,&#xA;[IsClubMember] int NOT NULL,&#xA;[IsFromSejam] int,&#xA;[PersonTypeId] int NOT NULL,&#xA;[PersonName] nvarchar(100) NOT NULL,&#xA;[GenderId] int,&#xA;[MarriedStateId] int,&#xA;[MilitaryStateId] int,&#xA;[FatherName] nvarchar(100),&#xA;[NationalCode] varchar(20),&#xA;[BirthDate] date,&#xA;[RegistrationDate] date,&#xA;[BirthCityId] int,&#xA;[RegistrationCityId] int,&#xA;[EconomicCode] nvarchar(30),&#xA;[StockIntroductionId] int,&#xA;[IntroducerGenderId] int,&#xA;[IntroducerHomeLocationId] int,&#xA;[JobId] int,&#xA;[Credit] money,&#xA;[StationCredit] money&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[CustomerAttachment] (&#xA;[CustomerId] int,&#xA;[AttachmentTypeId] int,&#xA;[InsertDateTime] datetime2(7) NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[CustomerStockType] (&#xA;[Id] int NOT NULL,&#xA;[CustomerId] int NOT NULL,&#xA;[StockTypeId] int NOT NULL,&#xA;[BranchId] int,&#xA;[StartDate] date,&#xA;[MarketerId] int,&#xA;[InsertUserId] int,&#xA;[BourseCode] nvarchar(50),&#xA;[ClientAccountNumber] nvarchar(50)&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[Gender] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(50) NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[HistoricalCredit] (&#xA;[Id] int NOT NULL,&#xA;[CustomerId] int NOT NULL,&#xA;[FromDate] date NOT NULL,&#xA;[Credit] money NOT NULL,&#xA;[StationCredit] money&#xA;)&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
