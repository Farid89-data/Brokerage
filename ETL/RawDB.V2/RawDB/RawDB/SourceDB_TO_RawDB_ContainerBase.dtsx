              SQLTask:SqlStatementSource="IF NOT EXISTS(SELECT * FROM sys.schemas WHERE name = N'bi')&#xA;BEGIN&#xA;EXEC(N'CREATE SCHEMA [bi]')&#xA;END&#xA;CREATE TABLE [bi].[MilitaryState] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(50) NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[OrderSide] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(50) NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[PaymentRequest] (&#xA;[Id] int NOT NULL,&#xA;[PersonId] int NOT NULL,&#xA;[RequestedPrice] decimal(25,5) NOT NULL,&#xA;[ConfirmPrice] decimal(25,5),&#xA;[RequestDateTime] datetime NOT NULL,&#xA;[ConfirmDateTime] datetime,&#xA;[BankId] int NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[PersonType] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(5) NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[Sector] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(250)&#xA;)&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
