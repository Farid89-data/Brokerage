            <SQLTask:SqlTaskData
              SQLTask:Connection="{1B307589-DB4F-4749-B725-D1F9947C665E}"
              SQLTask:SqlStatementSource="IF NOT EXISTS(SELECT * FROM sys.schemas WHERE name = N'bi')&#xA;BEGIN&#xA;EXEC(N'CREATE SCHEMA [bi]')&#xA;END&#xA;CREATE TABLE [bi].[AttachmentType] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(200)&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[Bank] (&#xA;[Id] int NOT NULL,&#xA;[BankName] nvarchar(100) NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[Branch] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(50) NOT NULL,&#xA;[CityId] int,&#xA;[IsActive] int,&#xA;[IsBranch] int,&#xA;[GoogleMapUrl] nvarchar(150),&#xA;[IsMainBranch] bit NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[City] (&#xA;[Id] int NOT NULL,&#xA;[CityName] nvarchar(50) NOT NULL,&#xA;[StateId] int,&#xA;[StateName] nvarchar(50) NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[CompanyType] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(50) NOT NULL&#xA;)&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
