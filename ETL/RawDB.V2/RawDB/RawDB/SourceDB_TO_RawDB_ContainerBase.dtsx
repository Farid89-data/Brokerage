              SQLTask:SqlStatementSource="IF NOT EXISTS(SELECT * FROM sys.schemas WHERE name = N'bi')&#xA;BEGIN&#xA;EXEC(N'CREATE SCHEMA [bi]')&#xA;END&#xA;CREATE TABLE [bi].[Settlement] (&#xA;[Id] int NOT NULL,&#xA;[PersonId] int NOT NULL,&#xA;[CustomerId] int NOT NULL,&#xA;[Date] datetime NOT NULL,&#xA;[Price] money NOT NULL,&#xA;[BranchId] int,&#xA;[StockTypeId] int NOT NULL,&#xA;[BankId] int,&#xA;[SettlementNatureTypeId] int&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[SettlementNatureType] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(50) NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[State] (&#xA;[Id] int NOT NULL,&#xA;[CityName] nvarchar(50) NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[StockIntroduction] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(50) NOT NULL&#xA;)&#xA;GO&#xA;CREATE TABLE [bi].[StockType] (&#xA;[Id] int NOT NULL,&#xA;[Name] nvarchar(50) NOT NULL&#xA;)&#xA;GO&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
