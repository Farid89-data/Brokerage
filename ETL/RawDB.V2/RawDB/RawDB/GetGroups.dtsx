        <DTS:Executable
          DTS:refId="Package\For Loop Container\Merge With Db"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{64BDB00A-BF4A-4AB8-9BEA-709F934BA6CC}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Merge With Db"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2C29B200-2F22-487B-A7EB-B2FCA432F505}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="&#xA;  Declare @JSON nvarchar(max)&#xA;SELECT @JSON=BulkColumn&#xA;FROM OPENROWSET (BULK 'C:\WebApiRequests\GetGroups\jsondata.txt', SINGLE_NCLOB) import&#xA;&#xA;MERGE [RawDB].[bi].[GetGroups] AS TARGET&#xA;USING (&#xA;&#x9;&#x9;SELECT &#xA;&#x9;&#x9;&#x9;  *&#x9;   &#xA;&#x9;&#x9;FROM OPENJSON (@JSON,'$.Items' )&#xA;&#x9;&#x9;WITH (&#xA;&#x9;&#x9;GroupId INT '$.Id',&#xA;&#x9;&#x9;GroupName NVARCHAR(150) '$.Name'&#xA;&#x9;&#x9;)&#xA;) Source &#xA;ON (&#xA;Target.GroupId = SOURCE.GroupId )&#xA;WHEN NOT MATCHED BY TARGET THEN &#xA;INSERT([GroupId]&#xA;      ,[GroupName]   &#xA;)&#x9;   &#xA;VALUES(&#xA;&#x9;   source.[GroupId]&#xA;      ,source.[GroupName]&#xA;)&#xA;WHEN MATCHED AND TARGET.GroupName &lt;&gt; SOURCE.GroupName&#xA;THEN UPDATE SET &#xA;TARGET.GroupName = SOURCE.GroupName&#xA;WHEN NOT MATCHED BY SOURCE THEN&#xA;    DELETE;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
