              WorkingDirectory="C:\WebApiRequests\GetSettlement" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\For Loop Container\Merge With Db"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{E2A00686-A6F6-4247-9345-31F450F43AB1}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Merge With Db"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2C29B200-2F22-487B-A7EB-B2FCA432F505}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="Declare @JSON nvarchar(max)&#xA;SELECT @JSON=BulkColumn&#xA;FROM OPENROWSET (BULK 'C:\WebApiRequests\GetSettlement\jsondata.txt', SINGLE_NCLOB) import&#xA;&#xA;MERGE Rawdb.[bi].[GetSettlement] AS TARGET&#xA;USING (SELECT &#xA;      *&#x9;   &#xA;FROM OPENJSON (@JSON,'$.Items' )&#xA;WITH &#xA;(&#xA;  Id INT&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;'$.Id'&#xA; ,CustomerId INT&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;'$.CustomerId'&#xA; ,price FLOAT&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;'$.price'&#xA; ,SettlementDate DATE&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;'$.SettlementDate'&#xA; ,PersianSettlementDate NVARCHAR(10)&#x9;&#x9;'$.PersianSettlementDate'&#xA; ,UserInputId INT&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;'$.UserInputId'&#xA; ,UserInputPersonName NVARCHAR(40)&#x9;&#x9;&#x9;'$.UserInputPersonName'&#xA; ,CompanyBranchId INT&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;'$.CompanyBranchId'&#xA; ,GnrCompanyBranchName NVARCHAR(50)&#x9;&#x9;&#x9;'$.GnrCompanyBranchName' &#xA; ,SettlementNatureTypeId INT&#x9;&#x9;&#x9;&#x9;'$.SettlementNatureTypeId'&#xA; ,SettlementNatureTypeName NVARCHAR(20)&#x9;&#x9;'$.SettlementNatureTypeName'&#xA; ,SettlementNumber NVARCHAR(20)&#x9;&#x9;&#x9;&#x9;'$.SettlementNumber'&#xA; ,TrackingNumber NVARCHAR(20)&#x9;&#x9;&#x9;&#x9;'$.TrackingNumber' &#xA; ,State NVARCHAR(10)&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;'$.State'&#xA; ,IsConfirm BIT&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;'$.IsConfirm'&#xA; ,UserConfirmId INT&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;'$.UserConfirmId'&#xA; ,UserConfirmPersonName NVARCHAR(50)&#x9;&#x9;'$.UserConfirmPersonName' &#xA; ,HasAttachment BIT&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;'$.HasAttachment'&#xA;)) Source &#xA;ON (&#xA;Target.Id = SOURCE.Id )&#xA;WHEN NOT MATCHED BY TARGET THEN &#xA;INSERT(&#xA;[Id]&#xA;      ,[CustomerId]&#xA;      ,[price]&#xA;      ,[SettlementDate]&#xA;      ,[PersianSettlementDate]&#xA;      ,[UserInputId]&#xA;      ,[UserInputPersonName]&#xA;      ,[CompanyBranchId]&#xA;      ,[GnrCompanyBranchName]&#xA;      ,[SettlementNatureTypeId]&#xA;      ,[SettlementNatureTypeName]&#xA;      ,[SettlementNumber]&#xA;      ,[TrackingNumber]&#xA;      ,[State]&#xA;      ,[IsConfirm]&#xA;      ,[UserConfirmId]&#xA;      ,[UserConfirmPersonName]&#xA;      ,[HasAttachment]&#xA;)&#xA;VALUES(&#xA;&#x9;&#x9;Source.[Id]&#xA;      ,Source.[CustomerId]&#xA;      ,Source.[price]&#xA;      ,Source.[SettlementDate]&#xA;      ,Source.[PersianSettlementDate]&#xA;      ,Source.[UserInputId]&#xA;      ,Source.[UserInputPersonName]&#xA;      ,Source.[CompanyBranchId]&#xA;      ,Source.[GnrCompanyBranchName]&#xA;      ,Source.[SettlementNatureTypeId]&#xA;      ,Source.[SettlementNatureTypeName]&#xA;      ,Source.[SettlementNumber]&#xA;      ,Source.[TrackingNumber]&#xA;      ,Source.[State]&#xA;      ,Source.[IsConfirm]&#xA;      ,Source.[UserConfirmId]&#xA;      ,Source.[UserConfirmPersonName]&#xA;      ,Source.[HasAttachment]&#xA;)&#xA;WHEN MATCHED AND TARGET.HashValue &lt;&gt; HASHBYTES('MD5', CONCAT_WS('|',Source.[Id]&#xA;      ,Source.[CustomerId]&#xA;      ,Source.[price]&#xA;      ,Source.[SettlementDate]&#xA;      ,Source.[PersianSettlementDate]&#xA;      ,Source.[UserInputId]&#xA;      ,Source.[UserInputPersonName]&#xA;      ,Source.[CompanyBranchId]&#xA;      ,Source.[GnrCompanyBranchName]&#xA;      ,Source.[SettlementNatureTypeId]&#xA;      ,Source.[SettlementNatureTypeName]&#xA;      ,Source.[SettlementNumber]&#xA;      ,Source.[TrackingNumber]&#xA;      ,Source.[State]&#xA;      ,Source.[IsConfirm]&#xA;      ,Source.[UserConfirmId]&#xA;      ,Source.[UserConfirmPersonName]&#xA;      ,Source.[HasAttachment]))&#xA;THEN UPDATE SET &#xA;TARGET.[Id] = SOURCE.[Id],&#xA;TARGET.[CustomerId] = SOURCE. [CustomerId],&#xA;TARGET.[price] = SOURCE. [price],&#xA;TARGET.[SettlementDate] = SOURCE. [SettlementDate],&#xA;TARGET.[PersianSettlementDate] = SOURCE. [PersianSettlementDate],&#xA;TARGET.[UserInputId] = SOURCE. [UserInputId],&#xA;TARGET.[UserInputPersonName] = SOURCE. [UserInputPersonName],&#xA;TARGET.[CompanyBranchId] = SOURCE. [CompanyBranchId],&#xA;TARGET.[GnrCompanyBranchName] = SOURCE. [GnrCompanyBranchName],&#xA;TARGET.[SettlementNatureTypeId] = SOURCE. [SettlementNatureTypeId],&#xA;TARGET.[SettlementNatureTypeName] = SOURCE. [SettlementNatureTypeName],&#xA;TARGET.[SettlementNumber] = SOURCE. [SettlementNumber],&#xA;TARGET.[TrackingNumber] = SOURCE. [TrackingNumber],&#xA;TARGET.[State] = SOURCE. [State],&#xA;TARGET.[IsConfirm] = SOURCE. [IsConfirm],&#xA;TARGET.[UserConfirmId] = SOURCE. [UserConfirmId],&#xA;TARGET.[UserConfirmPersonName] = SOURCE. [UserConfirmPersonName],&#xA;TARGET.[HasAttachment] = SOURCE. [HasAttachment]&#xA;;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
