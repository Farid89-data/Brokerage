        <DTS:Executable
          DTS:refId="Package\For Loop Container\Merge With Db"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{E15E86F9-F0CA-42ED-B211-02A366DDF690}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Merge With Db"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2C29B200-2F22-487B-A7EB-B2FCA432F505}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="Declare @JSON nvarchar(max)&#xA;SELECT @JSON=BulkColumn&#xA;FROM OPENROWSET (BULK 'C:\WebApiRequests\ReportCallInfo\jsondata.txt', SINGLE_NCLOB) import&#xA;&#xA;MERGE Rawdb.[bi].[CallCenterVIP] AS TARGET&#xA;USING (SELECT &#xA;      *&#x9;   &#xA;FROM OPENJSON (@JSON,'$.Items' )&#xA;WITH &#xA;(&#xA;   &#xA; [id] INT  '$.id'  &#xA;,[personName] NVARCHAR(100)  '$.personName'  &#xA;,[customerId] INT  '$.customerId'  &#xA;,[persianDate] NVARCHAR(50)  '$.persianDate'  &#xA;,[creatorName] NVARCHAR(100)  '$.creatorName'  &#xA;,[creatorId] INT  '$.creatorId'  &#xA;,[dateClose] NVARCHAR(50)  '$.dateClose'  &#xA;,[hour] INT  '$.hour'  &#xA;,[hourClose] INT  '$.hourClose'  &#xA;,[callType] NVARCHAR(50)  '$.callType'  &#xA;,[callPriority] NVARCHAR(10)  '$.callPriority'  &#xA;,[description] NVARCHAR(150)  '$.description'  &#xA;,[nationalCode] NVARCHAR(10)  '$.nationalCode'  &#xA;,[mobileNumber] NVARCHAR(20)  '$.mobileNumber'  &#xA;,[unknownPerson] BIT  '$.unknownPerson'  &#xA;,[callStateName] NVARCHAR(50)  '$.callStateName'  &#xA;,[callStateId] INT  '$.callStateId'  &#xA;,[companyChartId] INT  '$.companyChartId'  &#xA;,[priorityId] INT  '$.priorityId'  &#xA;,[callTypeId] INT  '$.callTypeId'  &#xA;,[callPriorityId] INT  '$.callPriorityId'  &#xA;,[jobTitle] NVARCHAR(50)  '$.jobTitle'  &#xA;,[companyChartDescription] NVARCHAR(50)  '$.companyChartDescription'  &#xA;,[companyChartDate] NVARCHAR(50)  '$.companyChartDate'  &#xA;,[companyChartTime] INT  '$.companyChartTime'  &#xA;,[companyChartDateResolve] NVARCHAR(50)  '$.companyChartDateResolve'  &#xA;,[companyChartTimeResolve] INT  '$.companyChartTimeResolve'  &#xA;,[callAgainDate] NVARCHAR(50)  '$.callAgainDate' &#xA;,[crmAttitudeDeterminationId] INT  '$.crmAttitudeDeterminationId'  &#xA;,[crmAttitudeDeterminationName] NVARCHAR(50)  '$.crmAttitudeDeterminationName'  &#xA;,[customerSatisfactionId] INT  '$.customerSatisfactionId'  &#xA;,[rate] FLOAT  '$.rate'  &#xA;,[totalRowNumber] INT  '$.totalRowNumber'  &#xA;,[pageSize] INT  '$.pageSize'  &#xA;,[pageNumber] INT  '$.pageNumber'  &#xA;,[activeCapitalMarket] BIT  '$.activeCapitalMarket'  &#xA;,[traderTypeId] INT  '$.traderTypeId' &#xA;,[traderTypeName] NVARCHAR(50)  '$.traderTypeName'  &#xA;,[yourActivity] NVARCHAR(50)  '$.yourActivity'  &#xA;,[portfolioManagerActivity] NVARCHAR(50)  '$.portfolioManagerActivity'  &#xA;,[changePortfolioManager] NVARCHAR(50)  '$.changePortfolioManager'  &#xA;,[havePortfolioManager] NVARCHAR(50)  '$.havePortfolioManager'  &#xA;,[portfolioManagerLicense] NVARCHAR(50)  '$.portfolioManagerLicense'  &#xA;,[backToBroker] NVARCHAR(50)  '$.backToBroker'  &#xA;,[backToCapitalMarket] BIT  '$.backToCapitalMarket'  &#xA;,[crmCompanyChartIds] INT  '$.crmCompanyChartIds'  &#xA;,[crmCompanyChartNames] NVARCHAR(50)  '$.crmCompanyChartNames' &#xA;,[companyChartProblemIds] INT  '$.companyChartProblemIds'  &#xA;,[companyChartProblemNames] NVARCHAR(50)  '$.companyChartProblemNames'  &#xA;,[crmMarketIds] INT  '$.crmMarketIds'  &#xA;,[crmMarketNames] NVARCHAR(50)  '$.crmMarketNames'  &#xA;,[crmReasonInactivityIds] INT  '$.crmReasonInactivityIds'  &#xA;,[crmReasonInactivityNames] NVARCHAR(100)  '$.crmReasonInactivityNames'  &#xA;,[crmReasonNotInvestingOtherMarketsIds] INT  '$.crmReasonNotInvestingOtherMarketsIds'  &#xA;,[crmReasonNotInvestingOtherMarketsNames] NVARCHAR(150)  '$.crmReasonNotInvestingOtherMarketsNames'  &#xA;,[crmMessageIds] INT  '$.crmMessageIds'  &#xA;,[crmMessageNames] NVARCHAR(50)  '$.crmMessageNames'  &#xA;,[crmDissociateReasonIds] INT  '$.crmDissociateReasonIds'  &#xA;,[crmDissociateReasonNames] NVARCHAR(50)  '$.crmDissociateReasonNames'  &#xA;,[crmCustomerActivityTypeOtherBrokerIds] INT  '$.crmCustomerActivityTypeOtherBrokerIds'  &#xA;,[crmCustomerActivityTypeOtherBrokerNames] NVARCHAR(50)  '$.crmCustomerActivityTypeOtherBrokerNames'  &#xA;,[crmBrokerIds] INT  '$.crmBrokerIds'  &#xA;,[crmBrokerNames] NVARCHAR(50)  '$.crmBrokerNames'  &#xA;,[companyBranchNames] NVARCHAR(50)  '$.companyBranchNames'  &#xA;,[companyBranchIds] INT  '$.companyBranchIds'  &#xA;&#xA;&#xA;&#xA;&#xA;&#xA;)) Source &#xA;ON (&#xA;Target.id   = SOURCE.id   )&#xA;WHEN NOT MATCHED BY TARGET THEN &#xA;INSERT(&#xA;&#xA; [id]  &#xA;,[personName]  &#xA;,[customerId]  &#xA;,[persianDate]  &#xA;,[creatorName]  &#xA;,[creatorId]  &#xA;,[dateClose]  &#xA;,[hour]  &#xA;,[hourClose]  &#xA;,[callType]  &#xA;,[callPriority]  &#xA;,[description]  &#xA;,[nationalCode]  &#xA;,[mobileNumber]  &#xA;,[unknownPerson]  &#xA;,[callStateName]  &#xA;,[callStateId]  &#xA;,[companyChartId]  &#xA;,[priorityId]  &#xA;,[callTypeId]  &#xA;,[callPriorityId]  &#xA;,[jobTitle]  &#xA;,[companyChartDescription]  &#xA;,[companyChartDate]  &#xA;,[companyChartTime]  &#xA;,[companyChartDateResolve]  &#xA;,[companyChartTimeResolve]  &#xA;,[callAgainDate]  &#xA;,[crmAttitudeDeterminationId]  &#xA;,[crmAttitudeDeterminationName]  &#xA;,[customerSatisfactionId]  &#xA;,[rate]  &#xA;,[totalRowNumber]  &#xA;,[pageSize]  &#xA;,[pageNumber]  &#xA;,[activeCapitalMarket]  &#xA;,[traderTypeId]  &#xA;,[traderTypeName]  &#xA;,[yourActivity]  &#xA;,[portfolioManagerActivity]  &#xA;,[changePortfolioManager]  &#xA;,[havePortfolioManager]  &#xA;,[portfolioManagerLicense]  &#xA;,[backToBroker]  &#xA;,[backToCapitalMarket]  &#xA;,[crmCompanyChartIds]  &#xA;,[crmCompanyChartNames]  &#xA;,[companyChartProblemIds]  &#xA;,[companyChartProblemNames]  &#xA;,[crmMarketIds]  &#xA;,[crmMarketNames]  &#xA;,[crmReasonInactivityIds]  &#xA;,[crmReasonInactivityNames]  &#xA;,[crmReasonNotInvestingOtherMarketsIds]  &#xA;,[crmReasonNotInvestingOtherMarketsNames]  &#xA;,[crmMessageIds]  &#xA;,[crmMessageNames]  &#xA;,[crmDissociateReasonIds]  &#xA;,[crmDissociateReasonNames]  &#xA;,[crmCustomerActivityTypeOtherBrokerIds]  &#xA;,[crmCustomerActivityTypeOtherBrokerNames]  &#xA;,[crmBrokerIds]  &#xA;,[crmBrokerNames]  &#xA;,[companyBranchNames]  &#xA;,[companyBranchIds]  &#xA;&#xA;&#xA;&#xA;)&#xA;VALUES(&#xA;&#xA;Source.[id]  &#xA;,Source.[personName]  &#xA;,Source.[customerId]  &#xA;,Source.[persianDate]  &#xA;,Source.[creatorName]  &#xA;,Source.[creatorId]  &#xA;,Source.[dateClose]  &#xA;,Source.[hour]  &#xA;,Source.[hourClose]  &#xA;,Source.[callType]  &#xA;,Source.[callPriority]  &#xA;,Source.[description]  &#xA;,Source.[nationalCode]  &#xA;,Source.[mobileNumber]  &#xA;,Source.[unknownPerson]  &#xA;,Source.[callStateName]  &#xA;,Source.[callStateId]  &#xA;,Source.[companyChartId]  &#xA;,Source.[priorityId]  &#xA;,Source.[callTypeId]  &#xA;,Source.[callPriorityId]  &#xA;,Source.[jobTitle]  &#xA;,Source.[companyChartDescription]  &#xA;,Source.[companyChartDate]  &#xA;,Source.[companyChartTime]  &#xA;,Source.[companyChartDateResolve]  &#xA;,Source.[companyChartTimeResolve]  &#xA;,Source.[callAgainDate]  &#xA;,Source.[crmAttitudeDeterminationId]  &#xA;,Source.[crmAttitudeDeterminationName]  &#xA;,Source.[customerSatisfactionId]  &#xA;,Source.[rate]  &#xA;,Source.[totalRowNumber]  &#xA;,Source.[pageSize]  &#xA;,Source.[pageNumber]  &#xA;,Source.[activeCapitalMarket]  &#xA;,Source.[traderTypeId]  &#xA;,Source.[traderTypeName]  &#xA;,Source.[yourActivity]  &#xA;,Source.[portfolioManagerActivity]  &#xA;,Source.[changePortfolioManager]  &#xA;,Source.[havePortfolioManager]  &#xA;,Source.[portfolioManagerLicense]  &#xA;,Source.[backToBroker]  &#xA;,Source.[backToCapitalMarket]  &#xA;,Source.[crmCompanyChartIds]  &#xA;,Source.[crmCompanyChartNames]  &#xA;,Source.[companyChartProblemIds]  &#xA;,Source.[companyChartProblemNames]  &#xA;,Source.[crmMarketIds]  &#xA;,Source.[crmMarketNames]  &#xA;,Source.[crmReasonInactivityIds]  &#xA;,Source.[crmReasonInactivityNames]  &#xA;,Source.[crmReasonNotInvestingOtherMarketsIds]  &#xA;,Source.[crmReasonNotInvestingOtherMarketsNames]  &#xA;,Source.[crmMessageIds]  &#xA;,Source.[crmMessageNames]  &#xA;,Source.[crmDissociateReasonIds]  &#xA;,Source.[crmDissociateReasonNames]  &#xA;,Source.[crmCustomerActivityTypeOtherBrokerIds]  &#xA;,Source.[crmCustomerActivityTypeOtherBrokerNames]  &#xA;,Source.[crmBrokerIds]  &#xA;,Source.[crmBrokerNames]  &#xA;,Source.[companyBranchNames]  &#xA;,Source.[companyBranchIds]  &#xA;&#xA;&#xA;&#xA;)&#xA;WHEN MATCHED AND TARGET.HashValue &lt;&gt; HASHBYTES('MD5', CONCAT_WS('|'&#xA;,Source.[id]  &#xA;,Source.[personName]  &#xA;,Source.[customerId]  &#xA;,Source.[persianDate]  &#xA;,Source.[creatorName]  &#xA;,Source.[creatorId]  &#xA;,Source.[dateClose]  &#xA;,Source.[hour]  &#xA;,Source.[hourClose]  &#xA;,Source.[callType]  &#xA;,Source.[callPriority]  &#xA;,Source.[description]  &#xA;,Source.[nationalCode]  &#xA;,Source.[mobileNumber]  &#xA;,Source.[unknownPerson]  &#xA;,Source.[callStateName]  &#xA;,Source.[callStateId]  &#xA;,Source.[companyChartId]  &#xA;,Source.[priorityId]  &#xA;,Source.[callTypeId]  &#xA;,Source.[callPriorityId]  &#xA;,Source.[jobTitle]  &#xA;,Source.[companyChartDescription]  &#xA;,Source.[companyChartDate]  &#xA;,Source.[companyChartTime]  &#xA;,Source.[companyChartDateResolve]  &#xA;,Source.[companyChartTimeResolve]  &#xA;,Source.[callAgainDate]  &#xA;,Source.[crmAttitudeDeterminationId]  &#xA;,Source.[crmAttitudeDeterminationName]  &#xA;,Source.[customerSatisfactionId]  &#xA;,Source.[rate]  &#xA;,Source.[totalRowNumber]  &#xA;,Source.[pageSize]  &#xA;,Source.[pageNumber]  &#xA;,Source.[activeCapitalMarket]  &#xA;,Source.[traderTypeId]  &#xA;,Source.[traderTypeName]  &#xA;,Source.[yourActivity]  &#xA;,Source.[portfolioManagerActivity]  &#xA;,Source.[changePortfolioManager]  &#xA;,Source.[havePortfolioManager]  &#xA;,Source.[portfolioManagerLicense]  &#xA;,Source.[backToBroker]  &#xA;,Source.[backToCapitalMarket]  &#xA;,Source.[crmCompanyChartIds]  &#xA;,Source.[crmCompanyChartNames]  &#xA;,Source.[companyChartProblemIds]  &#xA;,Source.[companyChartProblemNames]  &#xA;,Source.[crmMarketIds]  &#xA;,Source.[crmMarketNames]  &#xA;,Source.[crmReasonInactivityIds]  &#xA;,Source.[crmReasonInactivityNames]  &#xA;,Source.[crmReasonNotInvestingOtherMarketsIds]  &#xA;,Source.[crmReasonNotIn