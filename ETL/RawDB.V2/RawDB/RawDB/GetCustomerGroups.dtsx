              SQLTask:Connection="{2C29B200-2F22-487B-A7EB-B2FCA432F505}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="  Declare @JSON nvarchar(max)&#xA;SELECT @JSON=BulkColumn&#xA;FROM OPENROWSET (BULK 'C:\WebApiRequests\GetCustomerGroups\jsondata.txt', SINGLE_NCLOB) import&#xA;&#xA;MERGE [RawDB].[bi].[GetCustomerGroups] AS TARGET&#xA;USING (&#xA;&#x9;&#x9;SELECT &#xA;&#x9;&#x9;&#x9;  *&#x9;   &#xA;&#x9;&#x9;FROM OPENJSON (@JSON,'$.Items' )&#xA;&#x9;&#x9;WITH (&#xA;&#x9;&#x9;CustomerId INT '$.CustomerId',&#xA;&#x9;&#x9;CustomerGroupsId INT '$.GroupsId'&#xA;--&#x9;&#x9;,CustomerGroupName NVARCHAR(150) '$.GroupName'&#xA;&#x9;&#x9;)&#xA;) Source &#xA;ON (&#xA;Target.CustomerId = SOURCE.CustomerId AND Target.CustomerGroupsId = SOURCE.CustomerGroupsId)&#xA;WHEN NOT MATCHED BY TARGET THEN &#xA;INSERT([CustomerId]&#xA;      ,[CustomerGroupsId]&#xA;      --,[CustomerGroupName]&#xA;)&#x9;   &#xA;VALUES(&#xA;&#x9;   Source.[CustomerId]&#xA;      ,Source.[CustomerGroupsId]&#xA;      --,Source.[CustomerGroupName]&#xA;)&#xA;;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
