            <SQLTask:SqlTaskData
              SQLTask:Connection="{2C29B200-2F22-487B-A7EB-B2FCA432F505}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="   Declare @JSON nvarchar(max)&#xA;SELECT @JSON=BulkColumn&#xA;FROM OPENROWSET (BULK 'C:\WebApiRequests\LeftCustomerByChangeBrokerDetail\jsondata.txt', SINGLE_NCLOB) import&#xA;&#xA;MERGE Rawdb.bi.LeftCustomerByChangeBrokerDetail AS TARGET&#xA;USING (SELECT &#xA;[id]&#xA;      ,[assetValue]&#xA;      ,[customerId]&#xA;      ,[personName]&#xA;      ,[nationalCode]&#xA;      ,[date]&#xA;      ,[instrumentName]&#xA;      ,[instrumentCode]&#xA;      ,[instrumentShortName]&#xA;      ,[instrumentId]&#xA;&#xA;FROM OPENJSON (@JSON)&#xA;WITH &#xA;(&#xA;  id INT &#xA; ,assetValue FLOAT &#xA; ,customerId INT &#xA; ,personName NVARCHAR(100) &#xA; ,nationalCode VARCHAR(10) &#xA; ,date DATE &#xA; ,instrumentName NVARCHAR(100) &#xA; ,instrumentCode VARCHAR(12) &#xA; ,instrumentShortName NVARCHAR(15) &#xA; ,instrumentId INT &#xA;&#xA;)) Source &#xA;ON (Target.id = Source.id )&#xA;WHEN NOT MATCHED BY TARGET THEN &#xA;INSERT([id]&#xA;      ,[assetValue]&#xA;      ,[customerId]&#xA;      ,[personName]&#xA;      ,[nationalCode]&#xA;      ,[date]&#xA;      ,[instrumentName]&#xA;      ,[instrumentCode]&#xA;      ,[instrumentShortName]&#xA;      ,[instrumentId])&#xA;VALUES(&#xA;&#x9;   Source.[id]&#xA;      ,Source.[assetValue]&#xA;      ,Source.[customerId]&#xA;      ,Source.[personName]&#xA;      ,Source.[nationalCode]&#xA;      ,Source.[date]&#xA;      ,Source.[instrumentName]&#xA;      ,Source.[instrumentCode]&#xA;      ,Source.[instrumentShortName]&#xA;      ,Source.[instrumentId])&#xA;&#xA;WHEN MATCHED AND TARGET.HashValue &lt;&gt; HASHBYTES('MD5', CONCAT_WS('|',Source.[assetValue]&#xA;      ,Source.[customerId]&#xA;      ,Source.[personName]&#xA;      ,Source.[nationalCode]&#xA;      ,Source.[date]&#xA;      ,Source.[instrumentName]&#xA;      ,Source.[instrumentCode]&#xA;      ,Source.[instrumentShortName]&#xA;      ,Source.[instrumentId] ))&#xA;&#xA;THEN UPDATE SET &#xA; Target.[assetValue]=      Source.[assetValue]&#xA; ,Target.[customerId]=      Source.[customerId]&#xA; ,Target.[personName]=      Source.[personName]&#xA; ,Target.[nationalCode]=      Source.[nationalCode]&#xA; ,Target.[date]=      Source.[date]&#xA; ,Target.[instrumentName]=      Source.[instrumentName]&#xA; ,Target.[instrumentCode]=      Source.[instrumentCode]&#xA; ,Target.[instrumentShortName]=      Source.[instrumentShortName]&#xA; ,Target.[instrumentId]=      Source.[instrumentId]&#xA;&#x9;&#x9;&#x9;&#x9;&#xA;;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
