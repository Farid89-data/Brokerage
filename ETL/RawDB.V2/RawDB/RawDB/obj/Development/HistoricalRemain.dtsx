        <DTS:Executable
          DTS:refId="Package\HistoricalRemain\Delete 20 Day Data and Get Again - HistoricalRemain"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{078e3604-2df0-4f64-b1e6-27f6947058cd}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Delete 20 Day Data and Get Again - HistoricalRemain"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="1">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2C29B200-2F22-487B-A7EB-B2FCA432F505}"
              SQLTask:SqlStatementSource="DECLARE @StartDate DATE&#xA;SET @StartDate=(SELECT DATEADD(DAY,-5, MAX(date)) FROM RawDB.[bi].[HistoricalRemain] t) &#xA;&#xA;MERGE Rawdb.[bi].HistoricalRemain AS TARGET&#xA;USING ( SELECT [Date]&#xA;      ,[StockTypeId]&#xA;      ,[CustomerId]&#xA;      ,[Remain]&#xA;      ,[DampingRemain]&#xA;      ,[Cost]&#xA;FROM  [192.168.60.11].Automation.[bi].[HistoricalRemain] &#xA;&#x9;WHERE [Date] &gt;= @StartDate&#xA;) Source &#xA;ON (&#xA;Target.[Date]   = SOURCE.[Date]  AND  Target.[StockTypeId]=SOURCE.[StockTypeId] AND Target.[CustomerId]=SOURCE.[CustomerId])&#xA;WHEN NOT MATCHED BY TARGET THEN &#xA;INSERT(&#xA;[Date]&#xA;      ,[StockTypeId]&#xA;      ,[CustomerId]&#xA;      ,[Remain]&#xA;      ,[DampingRemain]&#xA;      ,[Cost]&#xA;)&#xA;VALUES(&#xA;&#x9;   Source.[Date]&#xA;      ,Source.[StockTypeId]&#xA;      ,Source.[CustomerId]&#xA;      ,Source.[Remain]&#xA;      ,Source.[DampingRemain]&#xA;      ,Source.[Cost]&#xA;)&#xA;WHEN MATCHED AND HASHBYTES('MD5', CONCAT_WS('|'&#xA;      ,Target.[Remain]&#xA;      ,Target.[DampingRemain]&#xA;      ,Target.[Cost] ))&#xA;&#x9;  &lt;&gt;&#xA;&#x9;  HASHBYTES('MD5', CONCAT_WS('|'&#xA;      ,Source.[Remain]&#xA;      ,Source.[DampingRemain]&#xA;      ,Source.[Cost] )&#xA;&#x9;  )&#xA;THEN UPDATE SET &#xA;      Target.[Remain]=Source.[Remain]&#xA;      ,Target.[DampingRemain]=Source.[DampingRemain]&#xA;      ,Target.[Cost]=Source.[Cost]&#xA;;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\HistoricalRemain\Drop and Create New Table - HistoricalRemain"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:Disabled="True"
          DTS:DTSID="{27d1fbcf-2219-4457-bfc4-6de74ded72a1}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop and Create New Table - HistoricalRemain"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2C29B200-2F22-487B-A7EB-B2FCA432F505}"
              SQLTask:SqlStatementSource="&#xA;DROP TABLE if exists &#xA;&#xA;&#xA; [dbo].[HistoricalRemain]&#xA;&#xA;&#xA;,[bi].[HistoricalRemain]&#xA;&#xA;&#xA;&#xA;IF NOT EXISTS(SELECT * FROM sys.schemas WHERE name = N'bi')&#xA;BEGIN&#xA;EXEC(N'CREATE SCHEMA [bi]')&#xA;END&#xA;&#xA;CREATE TABLE [bi].[HistoricalRemain] (&#xA;[Date] date NOT NULL,&#xA;[StockTypeId] int NOT NULL,&#xA;[CustomerId] int NOT NULL,&#xA;[Remain] decimal(22,9) NOT NULL,&#xA;[DampingRemain] decimal(22,9) NOT NULL,&#xA;[Cost] decimal(38,15)&#xA;)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
