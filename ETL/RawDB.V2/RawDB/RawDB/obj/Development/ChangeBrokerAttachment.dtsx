        <DTS:Executable
          DTS:refId="Package\For Loop Container\Merge With Db"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{0137819E-8544-49AD-AE1C-290AFCECA6D0}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Merge With Db"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2C29B200-2F22-487B-A7EB-B2FCA432F505}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="Declare @JSON nvarchar(max)&#xA;SELECT @JSON=BulkColumn&#xA;FROM OPENROWSET (BULK 'C:\WebApiRequests\ChangeBrokerAttachment\jsondata.txt', SINGLE_NCLOB) import&#xA;&#xA;MERGE Rawdb.[bi].[ChangeBrokerAttachment] AS TARGET&#xA;USING (SELECT &#xA;      *&#x9;   &#xA;FROM OPENJSON (@JSON,'$.Items' )&#xA;WITH &#xA;(&#xA;&#xA;     &#xA;      CustomerId INT       '$.CustomerId'&#xA;      ,Id INT       '$.Id'&#xA;     ,CustomerName NVARCHAR(50)       '$.CustomerName'&#xA;     ,NationalCode NVARCHAR(50)       '$.NationalCode'&#xA;     ,AccDetailCode NVARCHAR(50)       '$.AccDetailCode'&#xA;     ,UserId INT       '$.UserId'&#xA;     ,UserInputPersonName NVARCHAR(50)       '$.UserInputPersonName'&#xA;     ,DateTime DATE       '$.DateTime'&#xA;     ,PersianDateTime NVARCHAR(50)       '$.PersianDateTime'&#xA;     ,InstrumentId INT       '$.InstrumentId'&#xA;     ,CsdInstrumentName NVARCHAR(50)       '$.CsdInstrumentName'&#xA;     ,StateId INT       '$.StateId'&#xA;     ,StateName NVARCHAR(50)       '$.StateName'&#xA;     ,RequestSourceId INT       '$.RequestSourceId'&#xA;     ,RequestSourceName NVARCHAR(50)       '$.RequestSourceName'&#xA;     ,CompanyBranchId INT       '$.CompanyBranchId'&#xA;     ,CustomerCompanyBranchName NVARCHAR(50)       '$.CustomerCompanyBranchName'&#xA;     ,HasStockcertificate BIT       '$.HasStockcertificate'&#xA;     ,StockcertificateInsertDateTime DATE       '$.StockcertificateInsertDateTime'&#xA;     ,PersianStockcertificateInsertDateTime NVARCHAR(50)       '$.PersianStockcertificateInsertDateTime'&#xA;     ,HasChangeBrokerForm BIT       '$.HasChangeBrokerForm'&#xA;     ,ChangeBrokerFormInsertDateTime DATE       '$.ChangeBrokerFormInsertDateTime'&#xA;     ,PersianChangeBrokerFormInsertDateTime NVARCHAR(50)       '$.PersianChangeBrokerFormInsertDateTime'&#xA;&#xA;&#xA;&#xA;)) Source &#xA;ON (&#xA;Target.Id = SOURCE.Id )&#xA;WHEN NOT MATCHED BY TARGET THEN &#xA;INSERT(&#xA;&#xA;       [Id]&#xA;      ,[Customerid]&#xA;      ,[Customername]&#xA;      ,[Nationalcode]&#xA;      ,[Accdetailcode]&#xA;      ,[Userid]&#xA;      ,[Userinputpersonname]&#xA;      ,[Datetime]&#xA;      ,[Persiandatetime]&#xA;      ,[Instrumentid]&#xA;      ,[Csdinstrumentname]&#xA;      ,[Stateid]&#xA;      ,[Statename]&#xA;      ,[Requestsourceid]&#xA;      ,[Requestsourcename]&#xA;      ,[Companybranchid]&#xA;      ,[Customercompanybranchname]&#xA;      ,[Hasstockcertificate]&#xA;      ,[Stockcertificateinsertdatetime]&#xA;      ,[Persianstockcertificateinsertdatetime]&#xA;      ,[Haschangebrokerform]&#xA;      ,[Changebrokerforminsertdatetime]&#xA;      ,[Persianchangebrokerforminsertdatetime]&#xA;&#xA;&#xA;)&#xA;VALUES(&#xA;&#xA;       Source.[Id]&#xA;      ,Source.[Customerid]&#xA;      ,Source.[Customername]&#xA;      ,Source.[Nationalcode]&#xA;      ,Source.[Accdetailcode]&#xA;      ,Source.[Userid]&#xA;      ,Source.[Userinputpersonname]&#xA;      ,Source.[Datetime]&#xA;      ,Source.[Persiandatetime]&#xA;      ,Source.[Instrumentid]&#xA;      ,Source.[Csdinstrumentname]&#xA;      ,Source.[Stateid]&#xA;      ,Source.[Statename]&#xA;      ,Source.[Requestsourceid]&#xA;      ,Source.[Requestsourcename]&#xA;      ,Source.[Companybranchid]&#xA;      ,Source.[Customercompanybranchname]&#xA;      ,Source.[Hasstockcertificate]&#xA;      ,Source.[Stockcertificateinsertdatetime]&#xA;      ,Source.[Persianstockcertificateinsertdatetime]&#xA;      ,Source.[Haschangebrokerform]&#xA;      ,Source.[Changebrokerforminsertdatetime]&#xA;      ,Source.[Persianchangebrokerforminsertdatetime]&#xA;&#xA;&#xA;)&#xA;WHEN MATCHED AND TARGET.HashValue &lt;&gt; HASHBYTES('MD5', CONCAT_WS('|'&#xA;      ,Source.[Id]&#xA;      ,Source.[Customerid]&#xA;      ,Source.[Customername]&#xA;      ,Source.[Nationalcode]&#xA;      ,Source.[Accdetailcode]&#xA;      ,Source.[Userid]&#xA;      ,Source.[Userinputpersonname]&#xA;      ,Source.[Datetime]&#xA;      ,Source.[Persiandatetime]&#xA;      ,Source.[Instrumentid]&#xA;      ,Source.[Csdinstrumentname]&#xA;      ,Source.[Stateid]&#xA;      ,Source.[Statename]&#xA;      ,Source.[Requestsourceid]&#xA;      ,Source.[Requestsourcename]&#xA;      ,Source.[Companybranchid]&#xA;      ,Source.[Customercompanybranchname]&#xA;      ,Source.[Hasstockcertificate]&#xA;      ,Source.[Stockcertificateinsertdatetime]&#xA;      ,Source.[Persianstockcertificateinsertdatetime]&#xA;      ,Source.[Haschangebrokerform]&#xA;      ,Source.[Changebrokerforminsertdatetime]&#xA;      ,Source.[Persianchangebrokerforminsertdatetime]&#xA;&#xA;&#x9;  &#xA;&#x9;  ))&#xA;THEN UPDATE SET &#xA;&#xA;       Target.[Id] =Source.[Id]&#xA;      ,Target.[Customerid] =Source.[Customerid]&#xA;      ,Target.[Customername] =Source.[Customername]&#xA;      ,Target.[Nationalcode] =Source.[Nationalcode]&#xA;      ,Target.[Accdetailcode] =Source.[Accdetailcode]&#xA;      ,Target.[Userid] =Source.[Userid]&#xA;      ,Target.[Userinputpersonname] =Source.[Userinputpersonname]&#xA;      ,Target.[Datetime] =Source.[Datetime]&#xA;      ,Target.[Persiandatetime] =Source.[Persiandatetime]&#xA;      ,Target.[Instrumentid] =Source.[Instrumentid]&#xA;      ,Target.[Csdinstrumentname] =Source.[Csdinstrumentname]&#xA;      ,Target.[Stateid] =Source.[Stateid]&#xA;      ,Target.[Statename] =Source.[Statename]&#xA;      ,Target.[Requestsourceid] =Source.[Requestsourceid]&#xA;      ,Target.[Requestsourcename] =Source.[Requestsourcename]&#xA;      ,Target.[Companybranchid] =Source.[Companybranchid]&#xA;      ,Target.[Customercompanybranchname] =Source.[Customercompanybranchname]&#xA;      ,Target.[Hasstockcertificate] =Source.[Hasstockcertificate]&#xA;      ,Target.[Stockcertificateinsertdatetime] =Source.[Stockcertificateinsertdatetime]&#xA;      ,Target.[Persianstockcertificateinsertdatetime] =Source.[Persianstockcertificateinsertdatetime]&#xA;      ,Target.[Haschangebrokerform] =Source.[Haschangebrokerform]&#xA;      ,Target.[Changebrokerforminsertdatetime] =Source.[Changebrokerforminsertdatetime]&#xA;      ,Target.[Persianchangebrokerforminsertdatetime] =Source.[Persianchangebrokerforminsertdatetime]&#xA;&#xA;;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
