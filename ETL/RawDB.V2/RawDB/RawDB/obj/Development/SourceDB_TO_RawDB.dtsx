              SQLTask:SqlStatementSource="&#xA;DROP TABLE if exists &#xA;&#xA;&#xA; [dbo].[Trade] &#xA;&#xA;&#xA;,[bi].[Trade] &#xA;&#xA;SELECT * , t.Price* t.Quantity AS [TotalPrice] , CONVERT (DATE , t.DateTime) AS Date , CONVERT(TIME(0),t.DateTime) AS Time &#xA;  INTO bi.Trade&#xA;FROM [192.168.60.11].Automation.[bi].[Trade]  t " xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
