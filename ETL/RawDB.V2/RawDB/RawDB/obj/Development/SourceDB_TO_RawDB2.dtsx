          SQLTask:SqlStatementSource="&#xA;DROP TABLE if exists &#xA;&#xA;&#xA; [dbo].HistoricalPortfolio&#xA;&#xA;,[bi].HistoricalPortfolio&#xA;&#xA;&#xA;SELECT * INTO [bi].HistoricalPortfolio FROM [192.168.60.11].Automation.bi.HistoricalPortfolio hp&#xA;  WHERE hp.Date &lt;= GETDATE() AND Date &gt; DATEADD(Day,-5,GETDATE())" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
