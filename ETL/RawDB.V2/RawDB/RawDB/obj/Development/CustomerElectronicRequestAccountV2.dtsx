          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2C29B200-2F22-487B-A7EB-B2FCA432F505}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="Declare @JSON nvarchar(max)&#xA;SELECT @JSON=BulkColumn&#xA;FROM OPENROWSET (BULK 'C:\WebApiRequests\CustomerElectronicRequestAccountV2\jsondata.txt', SINGLE_NCLOB) import&#xA;&#xA;MERGE [RawDB].[bi].[CustomerElectronicRequestAccountV2] AS TARGET&#xA;USING (&#xA;&#x9;&#x9;SELECT &#xA;&#x9;&#x9;&#x9;  *&#x9;   &#xA;&#x9;&#x9;FROM OPENJSON (@JSON,'$.Items' )&#xA;&#x9;&#x9;WITH (&#xA;&#x9;&#x9;Id INT '$.Id',&#xA;&#x9;&#x9;CustomerId INT '$.CustomerId',&#xA;&#x9;&#x9;CustomerPersonName NVARCHAR(50) '$.CustomerPersonName' ,&#xA;&#x9;&#x9;ConfirmedTitle NVARCHAR(30) '$.ConfirmedTitle',&#xA;&#x9;&#x9;Confirmed BIT '$.Confirmed',&#xA;&#x9;&#x9;RequestUserId INT '$.RequestUserId',&#xA;&#x9;&#x9;RequestPersonName NVARCHAR(50) '$.RequestPersonName',&#xA;&#x9;&#x9;ConfirmUserId INT '$.ConfirmUserId',&#xA;&#x9;&#x9;ConfirmPersonName NVARCHAR(50) '$.ConfirmPersonName',&#xA;&#x9;&#x9;ConfirmDateTime DATETIME '$.ConfirmDateTime',&#xA;&#x9;&#x9;ConfirmDate DATE '$.ConfirmDateTime',&#xA;&#x9;&#x9;Description NVARCHAR(100) '$.Description' ,&#xA;&#x9;&#x9;IsOfflineAccount BIT '$.IsOfflineAccount',&#xA;&#x9;&#x9;IsOnlineAccount BIT '$.IsOnlineAccount',&#xA;&#x9;&#x9;RequestedOnlinePanelName nvarchar(20) '$.RequestedOnlinePanelName',&#xA;&#x9;&#x9;RequestedOnlinePanelId INT '$.RequestedOnlinePanelId',&#xA;&#x9;&#x9;CurrentOnlinePanelName NVARCHAR(20) '$.CurrentOnlinePanelName',&#xA;&#x9;&#x9;CurrentOnlinePanelId INT '$.CurrentOnlinePanelId',&#xA;&#x9;&#x9;OfflineUserName varchar(50) '$.OfflineUserName',&#xA;&#x9;&#x9;OnlineUserName varchar(50) '$.OnlineUserName'&#xA;&#xA;&#x9;&#x9;)&#xA;) Source &#xA;ON (&#xA;Target.Id = SOURCE.Id )&#xA;WHEN NOT MATCHED BY TARGET THEN &#xA;INSERT(&#xA;&#x9;   [Id]&#xA;      ,[CustomerId]&#xA;      ,[CustomerPersonName]&#xA;      ,[ConfirmedTitle]&#xA;      ,[Confirmed]&#xA;      ,[RequestUserId]&#xA;      ,[RequestPersonName]&#xA;      ,[ConfirmUserId]&#xA;      ,[ConfirmPersonName]&#xA;      ,[ConfirmDateTime]&#xA;&#x9;  ,[ConfirmDate]&#xA;      ,[Description]&#xA;      ,[IsOfflineAccount]&#xA;      ,[IsOnlineAccount]&#xA;      ,[RequestedOnlinePanelName]&#xA;      ,[RequestedOnlinePanelId]&#xA;      ,[CurrentOnlinePanelName]&#xA;      ,[CurrentOnlinePanelId]&#xA;      ,[OfflineUserName]&#xA;      ,[OnlineUserName]&#xA;&#x9;   &#xA;)&#x9;   &#xA;VALUES(&#xA;&#x9;   &#xA;  source.[Id] &#xA;      ,source.[CustomerId]&#xA;      ,source.[CustomerPersonName]&#xA;      ,source.[ConfirmedTitle]&#xA;      ,source.[Confirmed]&#xA;      ,source.[RequestUserId]&#xA;      ,source.[RequestPersonName]&#xA;      ,source.[ConfirmUserId]&#xA;      ,source.[ConfirmPersonName]&#xA;      ,source.[ConfirmDateTime]&#xA;&#x9;  ,SOURCE.[ConfirmDate]&#xA;      ,source.[Description]&#xA;      ,source.[IsOfflineAccount]&#xA;      ,source.[IsOnlineAccount]&#xA;      ,source.[RequestedOnlinePanelName]&#xA;      ,source.[RequestedOnlinePanelId]&#xA;      ,source.[CurrentOnlinePanelName]&#xA;      ,source.[CurrentOnlinePanelId]&#xA;      ,source.[OfflineUserName]&#xA;      ,source.[OnlineUserName]&#xA;&#xA;)&#xA;WHEN MATCHED AND TARGET.HashValue &lt;&gt; HASHBYTES('MD5', CONCAT_WS('|'&#xA;      ,source.[CustomerId]&#xA;      ,source.[CustomerPersonName]&#xA;      ,source.[ConfirmedTitle]&#xA;      ,source.[Confirmed]&#xA;      ,source.[RequestUserId]&#xA;      ,source.[RequestPersonName]&#xA;      ,source.[ConfirmUserId]&#xA;      ,source.[ConfirmPersonName]&#xA;      ,source.[ConfirmDateTime]&#xA;&#x9;  ,SOURCE.[ConfirmDate]&#xA;      ,source.[Description]&#xA;      ,source.[IsOfflineAccount]&#xA;      ,source.[IsOnlineAccount]&#xA;      ,source.[RequestedOnlinePanelName]&#xA;      ,source.[RequestedOnlinePanelId]&#xA;      ,source.[CurrentOnlinePanelName]&#xA;      ,source.[CurrentOnlinePanelId]&#xA;      ,source.[OfflineUserName]&#xA;      ,source.[OnlineUserName]&#xA;&#xA;&#x9;  &#xA;&#x9;  ))&#xA;THEN UPDATE SET &#xA;&#xA; TARGET.[CustomerId]=source.[CustomerId]&#xA;,TARGET.[CustomerPersonName]=source.[CustomerPersonName]&#xA;,TARGET.[ConfirmedTitle]=source.[ConfirmedTitle]&#xA;,TARGET.[Confirmed]=source.[Confirmed]&#xA;,TARGET.[RequestUserId]=source.[RequestUserId]&#xA;,TARGET.[RequestPersonName]=source.[RequestPersonName]&#xA;,TARGET.[ConfirmUserId]=source.[ConfirmUserId]&#xA;,TARGET.[ConfirmPersonName]=source.[ConfirmPersonName]&#xA;,TARGET.[ConfirmDateTime]=source.[ConfirmDateTime]&#xA;,TARGET.[ConfirmDate]=source.[ConfirmDate]&#xA;,TARGET.[Description]=source.[Description]&#xA;,TARGET.[IsOfflineAccount]=source.[IsOfflineAccount]&#xA;,TARGET.[IsOnlineAccount]=source.[IsOnlineAccount]&#xA;,TARGET.[RequestedOnlinePanelName]=source.[RequestedOnlinePanelName]&#xA;,TARGET.[RequestedOnlinePanelId]=source.[RequestedOnlinePanelId]&#xA;,TARGET.[CurrentOnlinePanelName]=source.[CurrentOnlinePanelName]&#xA;,TARGET.[CurrentOnlinePanelId]=source.[CurrentOnlinePanelId]&#xA;,TARGET.[OfflineUserName]=source.[OfflineUserName]&#xA;,TARGET.[OnlineUserName]=source.[OnlineUserName]&#xA;;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
