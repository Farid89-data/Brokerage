          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{2C29B200-2F22-487B-A7EB-B2FCA432F505}"
              SQLTask:BypassPrepare="False"
              SQLTask:SqlStatementSource="Declare @JSON nvarchar(max)&#xA;SELECT @JSON=BulkColumn&#xA;FROM OPENROWSET (BULK 'C:\WebApiRequests\GetRequestMasterStockMarket\jsondata.txt', SINGLE_NCLOB) import&#xA;&#xA;MERGE Rawdb.[bi].[GetRequestMasterStockMarket] AS TARGET&#xA;USING (SELECT &#xA;      RequestId&#x9;&#x9;&#x9;&#x9;&#x9; &#xA;      ,CustomerId&#x9;&#x9;&#x9;&#x9;&#xA;      ,CustomerPersonName&#x9;&#x9;&#xA;      ,AccDetailCode &#x9;&#x9;   &#xA;      ,NationalCode &#x9;&#x9;&#x9;   &#xA;      ,CustomerBourseCode &#x9;   &#xA;      ,RequestDateTime &#x9;&#x9;&#x9;&#xA;      ,PersianRequestDate &#x9;&#x9; &#xA;      ,RequestSourceId &#x9;&#x9;&#x9; &#xA;      ,RequestSourceName &#x9;&#x9; &#xA;      ,CompanyBranchId &#x9;&#x9;&#x9;&#xA;      ,CompanyBranchName &#x9;&#x9; &#xA;      ,SerialNumber &#x9;&#x9;&#x9;&#x9;&#xA;      ,InstrumentName &#x9;&#x9;&#x9; &#xA;      ,InstrumentId &#x9;&#x9;&#x9;&#x9;&#xA;      ,Quantity &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,StockTypeId &#x9;&#x9;&#x9;&#x9;&#xA;      ,StockName &#x9;&#x9;&#x9;&#x9; &#xA;      ,TradeTypeId &#x9;&#x9;&#x9;&#x9;&#xA;      ,TradeTypeName &#x9;&#x9;&#x9; &#xA;      ,MarketId &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,MarketName &#x9;&#x9;&#x9;&#x9; &#xA;      ,InputUserId &#x9;&#x9;&#x9;&#x9;&#xA;      ,UserCreateRequestPersonName&#xA;      ,RequestStateName &#x9;&#x9;&#x9; &#xA;      ,SettlementState &#x9;&#x9;&#x9;&#xA;      ,IsPrinted &#x9;&#x9;&#x9;&#x9;&#xA;      ,IsFinal &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,IsSigned &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,AttachmentfileUpload &#x9;&#x9; &#xA;      ,Description &#x9;&#x9;&#x9;   &#xA;FROM OPENJSON (@JSON,'$.Items' )&#xA;WITH &#xA;(&#xA;      RequestId int&#x9;&#x9;&#x9;&#x9;&#x9;&#x9; &#x9;   '$.RequestId',&#xA;      CustomerId int&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   '$.CustomerId',&#xA;      CustomerPersonName NVARCHAR(20)&#x9;&#x9;   '$.CustomerPersonName',&#xA;      AccDetailCode NVARCHAR(20)&#x9;&#x9;&#x9;   '$.AccDetailCode',&#xA;      NationalCode NVARCHAR(12)&#x9;&#x9;&#x9;&#x9;   '$.NationalCode',&#xA;      CustomerBourseCode NVARCHAR(20)&#x9;&#x9;   '$.CustomerBourseCodeCode',&#xA;      RequestDateTime DATETIME&#x9;&#x9;&#x9;&#x9;   '$.RequestDateTime',&#xA;      PersianRequestDate NVARCHAR(20)&#x9;&#x9;   '$.PersianRequestDate',&#xA;      RequestSourceId int&#x9;&#x9;&#x9;&#x9;&#x9;   '$.RequestSourceId',&#xA;      RequestSourceName NVARCHAR(20)&#x9;&#x9;   '$.RequestSourceName',&#xA;      CompanyBranchId int&#x9;&#x9;&#x9;&#x9;&#x9;   '$.CompanyBranchId',&#xA;      CompanyBranchName NVARCHAR(30)&#x9;&#x9;   '$.CompanyBranchName',&#xA;      SerialNumber int&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   '$.SerialNumber',&#xA;      InstrumentName NVARCHAR(40)&#x9;&#x9;&#x9;   '$.InstrumentName',&#xA;      InstrumentId int&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   '$.InstrumentId',&#xA;      Quantity bigint&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   '$.Quantity',&#xA;      StockTypeId int&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   '$.StockTypeId',&#xA;      StockName NVARCHAR(20)&#x9;&#x9;&#x9;&#x9;   '$.StockName',&#xA;      TradeTypeId int&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   '$.TradeTypeId',&#xA;      TradeTypeName NVARCHAR(20)&#x9;&#x9;&#x9;   '$.TradeTypeName',&#xA;      MarketId int&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   '$.MarketId',&#xA;      MarketName NVARCHAR(20)&#x9;&#x9;&#x9;&#x9;   '$.MarketName',&#xA;      InputUserId int&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   '$.InputUserId',&#xA;      UserCreateRequestPersonName NVARCHAR(20) '$.UserCreateRequestPersonName',&#xA;      RequestStateName NVARCHAR(20)&#x9;&#x9;&#x9;   '$.RequestStateName',&#xA;      SettlementState bit&#x9;&#x9;&#x9;&#x9;&#x9;   '$.SettlementState',&#xA;      IsPrinted bit&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   '$.IsPrinted',&#xA;      IsFinal bit&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   '$.IsFinal',&#xA;      IsSigned bit&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;   '$.IsSigned',&#xA;      AttachmentfileUpload bit&#x9;&#x9;&#x9;&#x9;   '$.AttachmentfileUpload',&#xA;      Description NVARCHAR(20)&#x9;&#x9;&#x9;&#x9;   '$.Description'&#xA;)) Source &#xA;ON (&#xA;Target.RequestId = SOURCE.RequestId )&#xA;WHEN NOT MATCHED BY TARGET THEN &#xA;INSERT(&#xA;RequestId&#x9;&#x9;&#x9;&#x9;&#x9; &#xA;      ,CustomerId&#x9;&#x9;&#x9;&#x9;&#xA;      ,CustomerPersonName&#x9;&#x9;&#xA;      ,AccDetailCode &#x9;&#x9;   &#xA;      ,NationalCode &#x9;&#x9;&#x9;   &#xA;      ,CustomerBourseCode &#x9;   &#xA;      ,RequestDateTime &#x9;&#x9;&#x9;&#xA;      ,PersianRequestDate &#x9;&#x9; &#xA;      ,RequestSourceId &#x9;&#x9;&#x9; &#xA;      ,RequestSourceName &#x9;&#x9; &#xA;      ,CompanyBranchId &#x9;&#x9;&#x9;&#xA;      ,CompanyBranchName &#x9;&#x9; &#xA;      ,SerialNumber &#x9;&#x9;&#x9;&#x9;&#xA;      ,InstrumentName &#x9;&#x9;&#x9; &#xA;      ,InstrumentId &#x9;&#x9;&#x9;&#x9;&#xA;      ,Quantity &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,StockTypeId &#x9;&#x9;&#x9;&#x9;&#xA;      ,StockName &#x9;&#x9;&#x9;&#x9; &#xA;      ,TradeTypeId &#x9;&#x9;&#x9;&#x9;&#xA;      ,TradeTypeName &#x9;&#x9;&#x9; &#xA;      ,MarketId &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,MarketName &#x9;&#x9;&#x9;&#x9; &#xA;      ,InputUserId &#x9;&#x9;&#x9;&#x9;&#xA;      ,UserCreateRequestPersonName&#xA;      ,RequestStateName &#x9;&#x9;&#x9; &#xA;      ,SettlementState &#x9;&#x9;&#x9;&#xA;      ,IsPrinted &#x9;&#x9;&#x9;&#x9;&#xA;      ,IsFinal &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,IsSigned &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,AttachmentfileUpload &#x9;&#x9; &#xA;      ,Description&#xA;)&#xA;VALUES(&#xA;&#x9;  Source.RequestId&#x9;&#x9;&#x9;&#x9;&#x9; &#xA;      ,Source.CustomerId&#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.CustomerPersonName&#x9;&#x9;&#xA;      ,Source.AccDetailCode &#x9;&#x9;   &#xA;      ,Source.NationalCode &#x9;&#x9;&#x9;   &#xA;      ,Source.CustomerBourseCode &#x9;   &#xA;      ,Source.RequestDateTime &#x9;&#x9;&#x9;&#xA;      ,Source.PersianRequestDate &#x9;&#x9; &#xA;      ,Source.RequestSourceId &#x9;&#x9;&#x9; &#xA;      ,Source.RequestSourceName &#x9;&#x9; &#xA;      ,Source.CompanyBranchId &#x9;&#x9;&#x9;&#xA;      ,Source.CompanyBranchName &#x9;&#x9; &#xA;      ,Source.SerialNumber &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.InstrumentName &#x9;&#x9;&#x9; &#xA;      ,Source.InstrumentId &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.Quantity &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.StockTypeId &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.StockName &#x9;&#x9;&#x9;&#x9; &#xA;      ,Source.TradeTypeId &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.TradeTypeName &#x9;&#x9;&#x9; &#xA;      ,Source.MarketId &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.MarketName &#x9;&#x9;&#x9;&#x9; &#xA;      ,Source.InputUserId &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.UserCreateRequestPersonName&#xA;      ,Source.RequestStateName &#x9;&#x9;&#x9; &#xA;      ,Source.SettlementState &#x9;&#x9;&#x9;&#xA;      ,Source.IsPrinted &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.IsFinal &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.IsSigned &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.AttachmentfileUpload &#x9;&#x9; &#xA;      ,Source.Description&#xA;)&#xA;WHEN MATCHED AND TARGET.HashValue &lt;&gt; HASHBYTES('MD5', CONCAT_WS('|',Source.CustomerId&#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.CustomerPersonName&#x9;&#x9;&#xA;      ,Source.AccDetailCode &#x9;&#x9;   &#xA;      ,Source.NationalCode &#x9;&#x9;&#x9;   &#xA;      ,Source.CustomerBourseCode &#x9;   &#xA;      ,Source.RequestDateTime &#x9;&#x9;&#x9;&#xA;      ,Source.PersianRequestDate &#x9;&#x9; &#xA;      ,Source.RequestSourceId &#x9;&#x9;&#x9; &#xA;      ,Source.RequestSourceName &#x9;&#x9; &#xA;      ,Source.CompanyBranchId &#x9;&#x9;&#x9;&#xA;      ,Source.CompanyBranchName &#x9;&#x9; &#xA;      ,Source.SerialNumber &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.InstrumentName &#x9;&#x9;&#x9; &#xA;      ,Source.InstrumentId &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.Quantity &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.StockTypeId &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.StockName &#x9;&#x9;&#x9;&#x9; &#xA;      ,Source.TradeTypeId &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.TradeTypeName &#x9;&#x9;&#x9; &#xA;      ,Source.MarketId &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.MarketName &#x9;&#x9;&#x9;&#x9; &#xA;      ,Source.InputUserId &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.UserCreateRequestPersonName&#xA;      ,Source.RequestStateName &#x9;&#x9;&#x9; &#xA;      ,Source.SettlementState &#x9;&#x9;&#x9;&#xA;      ,Source.IsPrinted &#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.IsFinal &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.IsSigned &#x9;&#x9;&#x9;&#x9;&#x9;&#xA;      ,Source.AttachmentfileUpload &#x9;&#x9; &#xA;      ,Source.Description))&#xA;THEN UPDATE SET &#xA;      target.CustomerId=      Source.CustomerId&#xA;      ,target.CustomerPersonName=      Source.CustomerPersonName&#xA;      ,target.AccDetailCode =      Source.AccDetailCode &#xA;      ,target.NationalCode =      Source.NationalCode &#xA;      ,target.CustomerBourseCode =      Source.CustomerBourseCode &#xA;      ,target.RequestDateTime =      Source.RequestDateTime &#xA;      ,target.PersianRequestDate =      Source.PersianRequestDate &#xA;      ,target.RequestSourceId  =      Source.RequestSourceId &#xA;      ,target.RequestSourceName  =      Source.RequestSourceName &#xA;      ,target.CompanyBranchId =      Source.CompanyBranchId &#xA;      ,target.CompanyBranchName =      Source.CompanyBranchName &#xA;      ,target.SerialNumber =      Source.SerialNumber &#xA;      ,target.InstrumentName =      Source.InstrumentName &#xA;      ,target.InstrumentId =      Source.InstrumentId &#xA;      ,target.Quantity =      Source.Quantity &#xA;      ,target.StockTypeId =      Source.StockTypeId &#xA;      ,target.StockName =      Source.StockName &#xA;      ,target.TradeTypeId =      Source.TradeTypeId &#xA;      ,target.TradeTypeName =      Source.TradeTypeName &#xA;      ,target.MarketId =      Source.MarketId &#xA;      ,target.MarketName =      Source.MarketName &#xA;      ,target.InputUserId =      Source.InputUserId &#xA;      ,target.UserCreateRequestPersonName=      Source.UserCreateRequestPersonName&#xA;      ,target.RequestStateName =      Source.RequestStateName &#xA;      ,target.SettlementState =      Source.SettlementState &#xA;      ,target.IsPrinted =      Source.IsPrinted &#xA;      ,target.IsFinal =      Source.IsFinal &#xA;      ,target.IsSigned =      Source.IsSigned &#xA;      ,target.AttachmentfileUpload =      Source.AttachmentfileUpload &#xA;      ,target.Description=      Source.Description&#xA;&#xA;;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
