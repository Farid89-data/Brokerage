              SQLTask:SqlStatementSource="&#xA;DROP TABLE if exists &#xA;&#xA;&#xA; [dbo].[Customer]&#xA;&#xA;&#xA;,[bi].[Customer]&#xA;&#xA;&#xA;&#xA;IF NOT EXISTS(SELECT * FROM sys.schemas WHERE name = N'bi')&#xA;BEGIN&#xA;EXEC(N'CREATE SCHEMA [bi]')&#xA;END&#xA;&#xA;&#xA;CREATE TABLE [bi].[Customer] (&#xA;[Id] int NOT NULL,&#xA;[PersonId] int NOT NULL,&#xA;[ClubMemberId] int,&#xA;[IsClubMember] int NOT NULL,&#xA;[IsFromSejam] int,&#xA;[PersonTypeId] int NOT NULL,&#xA;[PersonName] nvarchar(100) NOT NULL,&#xA;[GenderId] int,&#xA;[MarriedStateId] int,&#xA;[MilitaryStateId] int,&#xA;[FatherName] nvarchar(100),&#xA;NationalCode VARCHAR(20) ,&#xA;[BirthDate] date,&#xA;[RegistrationDate] date,&#xA;[BirthCityId] int,&#xA;[RegistrationCityId] int,&#xA;[EconomicCode] nvarchar(30),&#xA;[StockIntroductionId] int,&#xA;[IntroducerGenderId] int,&#xA;[IntroducerHomeLocationId] int,&#xA;[JobId] int,&#xA;[Credit] money,&#xA;[StationCredit] money&#xA;,[IntroducerPersonId] int&#xA;      ,[EducationName] nvarchar(50)&#xA;      ,[MonthlySalary] money&#xA;      ,[TransactionLevel] nvarchar(50)&#xA;)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
