      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\FactImeTrade(AutomationDW)\Merge Source With Target"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{D7AC382E-4CDF-4B9C-B173-B305C9BC1CAE}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Merge Source With Target"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="&#xA;  MERGE [FactImeTrade] AS TARGET&#xA;USING (SELECT&#xA;DISTINCT &#xA;ISNULL([Id] ,-1) AS Id&#xA;,ISNULL([ContractNumber],-1) AS ContractNumber&#xA;,ISNULL([ContractDate],'1921-03-21') AS ContractDate&#xA;,ISNULL([ImeContractTypeId],-1) AS ImeContractTypeId&#xA;,ISNULL([SettlementDeadline],'1921-03-21') AS SettlementDeadline&#xA;,ISNULL([SettlementDate],'1921-03-21') AS SettlementDate&#xA;,ISNULL([ImeSettlementTypeId],-1) AS ImeSettlementTypeId&#xA;,ISNULL([SellerCustomerId],-1) AS SellerCustomerId&#xA;,ISNULL([BuyerCustomerId],-1) AS BuyerCustomerId&#xA;,ISNULL([UnitCount],0) AS UnitCount&#xA;,ISNULL([UnitPrice],0) AS UnitPrice&#xA;,ISNULL([UnitCount] * [UnitPrice],0) AS TotalUnittrade&#xA;,ISNULL([BrokerCommission],0) AS BrokerCommission&#xA;,ISNULL([is_canceled],1) AS is_canceled&#xA;,ISNULL([BuyerBrokerId],-1) AS BuyerBrokerId&#xA;,ISNULL([SellerBrokerId],-1) AS SellerBrokerId&#xA;,ISNULL([Comodity_ID],-1) AS Comodity_ID&#xA;,ISNULL([ImeManfacturerId],-1) AS ImeManfacturerId&#xA;,ISNULL([ImeSupplierId],-1) AS ImeSupplierId&#xA;,ISNULL([MarketName], N'نامشخص') AS MarketName&#xA;,ISNULL([ImeCommoditySubGroupId],-1) AS ImeCommoditySubGroupId&#xA;,ISNULL([ImeCommodityGroupId],-1) AS ImeCommodityGroupId&#xA;,ISNULL([PrepaymentPercent],0) AS PrepaymentPercent&#xA;,ISNULL([Prepayment],0) AS Prepayment&#xA;, CASE WHEN [BuyerBrokerId] = 44 AND [SellerBrokerId] = 44 THEN 3&#xA; WHEN [BuyerBrokerId] = 44 THEN 1&#xA; WHEN [SellerBrokerId] = 44 THEN 2&#xA; ELSE -1 &#xA; END AS OrderSide&#xA;&#xA;FROM [RawDB].[bi].[ImeTrade]) AS SOURCE &#xA;ON (TARGET.Id = SOURCE.ID) &#xA;WHEN MATCHED AND TARGET.[HashValue] &lt;&gt; (HASHBYTES('MD5', CONCAT_WS('|',&#xA;Source.[Id]&#xA;,Source.[ContractNumber]&#xA;,Source.[ContractDate]&#xA;,Source.[ImeContractTypeId]&#xA;,Source.[SettlementDeadline]&#xA;,Source.[SettlementDate]&#xA;,Source.[ImeSettlementTypeId]&#xA;,Source.[SellerCustomerId]&#xA;,Source.[BuyerCustomerId]&#xA;,Source.[UnitCount]&#xA;,Source.[UnitPrice]&#xA;,Source.[BrokerCommission]&#xA;,Source.[is_canceled]&#xA;,Source.[BuyerBrokerId]&#xA;,Source.[SellerBrokerId]&#xA;,Source.[Comodity_ID]&#xA;,Source.[ImeManfacturerId]&#xA;,Source.[ImeSupplierId]&#xA;,Source.[MarketName]&#xA;,Source.[ImeCommoditySubGroupId]&#xA;,Source.[ImeCommodityGroupId]&#xA;,Source.[PrepaymentPercent]&#xA;,Source.[Prepayment]&#xA;)))&#xA;&#xA;THEN UPDATE SET &#xA;&#xA;TARGET.[Id]=Source.[Id] &#xA;,TARGET.[ContractNumber]=Source.[ContractNumber]&#xA;,TARGET.[ContractDate]=Source.[ContractDate]&#xA;,TARGET.[ImeContractTypeId]=Source.[ImeContractTypeId]&#xA;,TARGET.[SettlementDeadline]=Source.[SettlementDeadline]&#xA;,TARGET.[SettlementDate]=Source.[SettlementDate]&#xA;,TARGET.[ImeSettlementTypeId]=Source.[ImeSettlementTypeId]&#xA;,TARGET.[SellerCustomerId]=Source.[SellerCustomerId]&#xA;,TARGET.[BuyerCustomerId]=Source.[BuyerCustomerId]&#xA;,TARGET.[UnitCount]=Source.[UnitCount]&#xA;,TARGET.[UnitPrice]=Source.[UnitPrice]&#xA;,TARGET.TotalUnittrade = SOURCE.TotalUnittrade&#xA;,TARGET.[BrokerCommission]=Source.[BrokerCommission]&#xA;,TARGET.[is_canceled]=Source.[is_canceled]&#xA;,TARGET.[BuyerBrokerId]=Source.[BuyerBrokerId]&#xA;,TARGET.[SellerBrokerId]=Source.[SellerBrokerId]&#xA;,TARGET.[Comodity_ID]=Source.[Comodity_ID]&#xA;,TARGET.[ImeManfacturerId]=Source.[ImeManfacturerId]&#xA;,TARGET.[ImeSupplierId]=Source.[ImeSupplierId]&#xA;,TARGET.[MarketName]=Source.[MarketName]&#xA;,TARGET.[ImeCommoditySubGroupId]=Source.[ImeCommoditySubGroupId]&#xA;,TARGET.[ImeCommodityGroupId]=Source.[ImeCommodityGroupId]&#xA;,TARGET.[PrepaymentPercent]=Source.[PrepaymentPercent]&#xA;,TARGET.[Prepayment]=Source.[Prepayment]&#xA;,TARGET.OrderSide = SOURCE.OrderSide&#xA;&#xA;&#xA;WHEN NOT MATCHED BY TARGET &#xA;THEN INSERT (&#xA;&#xA;[Id]&#xA;      ,[ContractNumber]&#xA;      ,[ContractDate]&#xA;      ,[ImeContractTypeId]&#xA;      ,[SettlementDeadline]&#xA;      ,[SettlementDate]&#xA;      ,[ImeSettlementTypeId]&#xA;      ,[SellerCustomerId]&#xA;      ,[BuyerCustomerId]&#xA;      ,[UnitCount]&#xA;      ,[UnitPrice]&#xA;&#x9;  ,TotalUnittrade&#xA;      ,[BrokerCommission]&#xA;      ,[is_canceled]&#xA;      ,[BuyerBrokerId]&#xA;      ,[SellerBrokerId]&#xA;      ,[Comodity_ID]&#xA;      ,[ImeManfacturerId]&#xA;      ,[ImeSupplierId]&#xA;      ,[MarketName]&#xA;      ,[ImeCommoditySubGroupId]&#xA;      ,[ImeCommodityGroupId]&#xA;      ,[PrepaymentPercent]&#xA;      ,[Prepayment]&#x9;&#x9;&#xA;&#x9;  ,OrderSide&#xA;      )&#xA;VALUES&#xA;(     &#xA;Source.[Id] &#xA;,Source.[ContractNumber]&#xA;,Source.[ContractDate]&#xA;,Source.[ImeContractTypeId]&#xA;,Source.[SettlementDeadline]&#xA;,Source.[SettlementDate]&#xA;,Source.[ImeSettlementTypeId]&#xA;,Source.[SellerCustomerId]&#xA;,Source.[BuyerCustomerId]&#xA;,Source.[UnitCount]&#xA;,Source.[UnitPrice]&#xA;,SOURCE.TotalUnittrade&#xA;,Source.[BrokerCommission]&#xA;,Source.[is_canceled]&#xA;,Source.[BuyerBrokerId]&#xA;,Source.[SellerBrokerId]&#xA;,Source.[Comodity_ID]&#xA;,Source.[ImeManfacturerId]&#xA;,Source.[ImeSupplierId]&#xA;,Source.[MarketName]&#xA;,Source.[ImeCommoditySubGroupId]&#xA;,Source.[ImeCommodityGroupId]&#xA;,Source.[PrepaymentPercent]&#xA;,Source.[Prepayment]&#xA;,SOURCE.OrderSide&#xA;)&#xA;WHEN NOT MATCHED BY SOURCE &#xA;THEN  DELETE ;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:Executable>
