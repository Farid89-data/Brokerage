          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="drop table if exists&#xA;[tempdb].[dbo].[DimMonthBranch],&#xA;[tempdb].[dbo].[OveralChangeBroker],&#xA;[tempdb].[dbo].[OveralCommission],&#xA;[tempdb].[dbo].[OveralRegistered],&#xA;[tempdb].[dbo].[TempBranchRank],&#xA;[tempdb].[dbo].[BranchRegistered],&#xA;[tempdb].[dbo].[BranchChangeBroker],&#xA;[tempdb].[dbo].[BranchCommission]" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create  Branch Broker Commission"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{BD61D9B9-B011-45DB-90CC-40F836FE4A3B}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create  Branch Broker Commission"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="2">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="------BrokerCommission&#xA;drop table if exists tempdb.dbo.BranchCommission&#xA;-----------------------------&#xA;SELECT PersianYearMonthInt,db.BranchIsBranch,db.BranchId,sum(bcom) as BrokerCommission,&#xA;PERCENTILE_CONT(0.25) WITHIN GROUP (ORDER BY sum(BrokerCommission))   &#xA;                            OVER (PARTITION BY PersianYearMonthInt,db.BranchIsBranch) AS Q1,&#xA;PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY sum(BrokerCommission))   &#xA;                            OVER (PARTITION BY PersianYearMonthInt,db.BranchIsBranch) AS Q2,&#xA;PERCENTILE_CONT(0.75) WITHIN GROUP (ORDER BY sum(BrokerCommission))   &#xA;                            OVER (PARTITION BY PersianYearMonthInt,db.BranchIsBranch) AS Q3&#xA;&#xA;&#x9;into tempdb.dbo.BranchCommission&#xA;&#x9;FROM [AutomationDW].[dbo].[DimCustomer] dc&#xA;&#x9;join DimBranchLocation db on db.BranchId = dc.BranchId&#xA;&#x9;join FactTrade ft on ft.CustomerId=dc.CustomerId &#xA;&#x9;join dimdate dd on dd.GregorianDate = ft.Date&#xA;&#x9;where IsCanceled = 0&#xA;&#x9;group by PersianYearMonthInt,db.BranchIsBranch,db.BranchId" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create  Branch Change Broker"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{98E480C9-6DBE-4C79-9912-C1F9E9E76FE2}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create  Branch Change Broker"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="3">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="drop table if exists tempdb.dbo.BranchChangeBroker&#xA;&#xA;SELECT PersianYearMonthInt,db.BranchIsBranch,db.BranchId,count(*) as OveralChangeBroker,&#xA;PERCENTILE_CONT(0.25) WITHIN GROUP (ORDER BY count(*))   &#xA;                            OVER (PARTITION BY PersianYearMonthInt,db.BranchIsBranch) AS Q1,&#xA;PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY count(*))   &#xA;                            OVER (PARTITION BY PersianYearMonthInt,db.BranchIsBranch) AS Q2,&#xA;PERCENTILE_CONT(0.75) WITHIN GROUP (ORDER BY count(*))   &#xA;                            OVER (PARTITION BY PersianYearMonthInt,db.BranchIsBranch) AS Q3&#xA;&#x9;into tempdb.dbo.BranchChangeBroker&#xA;&#x9;FROM [AutomationDW].[dbo].[DimCustomer] dc&#xA;&#x9;join FactChangeBroker fcb on fcb.CustomerId = dc.CustomerId&#xA;&#x9;join DimDate dd on dd.GregorianStr = fcb.Date&#xA;&#x9;join DimBranchLocation db on db.BranchId = dc.BranchId&#xA;&#x9;where fcb.ChangeBrokerStateId = 4&#xA;&#x9;group by PersianYearMonthInt,db.BranchIsBranch,db.BranchId&#xA;&#x9;order by PersianYearMonthInt desc" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create  Branch Client Registered"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{4A39E3CD-8046-4243-B8BA-2F6D7D21617A}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create  Branch Client Registered"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="1">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="------OveralRegistered&#xA;drop table if exists tempdb.dbo.BranchRegistered&#xA;&#xA;SELECT PersianYearMonthInt,db.BranchIsBranch,db.BranchId,count(*) as OveralRegistered,&#xA;PERCENTILE_CONT(0.25) WITHIN GROUP (ORDER BY count(*))   &#xA;                            OVER (PARTITION BY PersianYearMonthInt,db.BranchIsBranch) AS Q1,&#xA;PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY count(*))   &#xA;                            OVER (PARTITION BY PersianYearMonthInt,db.BranchIsBranch) AS Q2,&#xA;PERCENTILE_CONT(0.75) WITHIN GROUP (ORDER BY count(*))   &#xA;                            OVER (PARTITION BY PersianYearMonthInt,db.BranchIsBranch) AS Q3&#xA;&#xA;&#x9;into tempdb.dbo.BranchRegistered&#xA;&#x9;FROM [AutomationDW].[dbo].[DimCustomer] dc&#xA;&#x9;join DimDate dd on dd.GregorianStr = dc.StartDate&#xA;&#x9;join DimBranchLocation db on db.BranchId = dc.BranchId&#xA;&#x9;group by PersianYearMonthInt,db.BranchIsBranch,db.BranchId&#xA;&#x9;order by PersianYearMonthInt desc" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create  Overall Broker Commission"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{0F184563-49E6-4733-AE1D-FB019DC06944}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create  Overall Broker Commission"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="2">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="drop table if exists tempdb.dbo.OveralCommission&#xA;SELECT PersianYearMonthInt,bc.BranchIsBranch,sum(isnull(BrokerCommission,0)) as BrokerCommission,&#xA;AVG(BrokerCommission) as AVGBrokerCommission&#xA;&#x9;into tempdb.dbo.OveralCommission&#xA;&#x9;FROM tempdb.dbo.BranchCommission bc&#xA;&#x9;group by PersianYearMonthInt,bc.BranchIsBranch" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create  Overall Client Registered"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{FA36474A-0AD0-4AB7-982A-0EABF1F8E757}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create  Overall Client Registered"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="1">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="drop table if exists tempdb.dbo.OveralRegistered&#xA;SELECT PersianYearMonthInt,br.BranchIsBranch,sum(isnull(br.OveralRegistered,0)) as OveralRegistered&#xA;,AVG(isnull(br.OveralRegistered,0)) as AVGRegistered&#xA;&#x9;into tempdb.dbo.OveralRegistered&#xA;&#x9;FROM tempdb.dbo.BranchRegistered br&#xA;&#x9;group by PersianYearMonthInt,br.BranchIsBranch&#xA;&#x9;order by PersianYearMonthInt desc" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create Month Branch Table"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{E997A4DF-1879-4213-AD18-B9914766A39C}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create Month Branch Table"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="drop table if exists tempdb.dbo.DimMonthBranch&#xA;---------------------------------------&#xA;select distinct PersianYearMonthInt,BranchIsBranch,BranchId&#xA;into tempdb.dbo.DimMonthBranch&#xA;from automationdw.dbo.DimDate dd,DimBranchLocation db&#xA;where PersianYearMonthInt between &#xA;(select min(PersianYearMonthInt) from automationdw.dbo.FactTrade join automationdw.dbo.DimDate on Date=GregorianDate)&#xA;&#xA;and (select max(PersianYearMonthInt) from automationdw.dbo.FactTrade join automationdw.dbo.DimDate on Date=GregorianDate)&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create Overall Change Broker"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{F7FD1698-5CB4-4B0E-BC13-4D4EBBADBD25}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create Overall Change Broker"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="3">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="drop table if exists tempdb.dbo.OveralChangeBroker&#xA;SELECT PersianYearMonthInt,bcb.BranchIsBranch,sum(isnull(bcb.OveralChangeBroker,0)) as OveralChangeBroker&#xA;,AVG(isnull(bcb.OveralChangeBroker,0)) as AVGChangeBroker&#xA;&#x9;into tempdb.dbo.OveralChangeBroker&#xA;&#x9;FROM tempdb.dbo.BranchChangeBroker bcb&#xA;&#x9;group by PersianYearMonthInt,bcb.BranchIsBranch&#xA;&#x9;order by PersianYearMonthInt desc" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\FactBranchMonthlyRank"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{3CCE3C7B-9F36-4DFE-8C74-C3CC5B5E57B9}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="FactBranchMonthlyRank"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="drop table if exists  AutomationDW.dbo.FactBranchMonthlyRank&#xA;&#xA;select db.*,isnull(bc.BrokerCommission,0) as BrokerCommission,&#xA;case when isnull(bc.BrokerCommission,0) &gt;= 0 and isnull(bc.BrokerCommission,0)&lt;=bc.Q1 then 4&#xA;when isnull(bc.BrokerCommission,0) &gt; bc.Q1 and isnull(bc.BrokerCommission,0)&lt;=bc.Q2 then 3&#xA;when isnull(bc.BrokerCommission,0) &gt; bc.Q2 and isnull(bc.BrokerCommission,0)&lt;=bc.Q3 then 2 &#xA;when isnull(bc.BrokerCommission,0) &gt; bc.Q3 then 1 else 4 end as QRankBrokerCommission,&#xA;isnull(bc.BrokerCommission,0)/oc.BrokerCommission as RankZaribBrokerCommission,&#xA;oc.AVGBrokerCommission as TotalAvgBrokerCommison,&#xA;isnull(bc.BrokerCommission,0) - oc.AVGBrokerCommission as DiffAvgBrokerCommisson,&#xA;&#xA;isnull(br.OveralRegistered,0) as Registered ,&#xA;isnull(br.OveralRegistered,0) - isnull(ocr.AVGRegistered,0) as DiffAvgRegistered,&#xA;isnull(ocr.AVGRegistered,0) as AvgRegistered,&#xA;case when isnull(br.OveralRegistered,0) &gt;= 0 and isnull(br.OveralRegistered,0)&lt;=br.Q1 then 4&#xA;when isnull(br.OveralRegistered,0) &gt; br.Q1 and isnull(br.OveralRegistered,0)&lt;=br.Q2 then 3&#xA;when isnull(br.OveralRegistered,0) &gt; br.Q2 and isnull(br.OveralRegistered,0)&lt;=br.Q3 then 2 &#xA;when isnull(br.OveralRegistered,0) &gt; br.Q3 then 1 else 4 end as QRankBrokerRegistered,&#xA;&#xA;isnull(isnull(br.OveralRegistered,0)/ocr.OveralRegistered,0) as RankZaribRegistered,&#xA;&#xA;&#xA;isnull(bcb.OveralChangeBroker,0) as ChangeBroker ,&#xA;isnull(bcb.OveralChangeBroker,0) - isnull(ocb.AVGChangeBroker,0) as DiffAVGChangeBroker,&#xA;isnull(ocb.AVGChangeBroker,0) as AVGChangeBroker,&#xA;case when isnull(bcb.OveralChangeBroker,0) &gt;= 0 and isnull(bcb.OveralChangeBroker,0)&lt;=bcb.Q1 then 4&#xA;when isnull(bcb.OveralChangeBroker,0) &gt; bcb.Q1 and isnull(bcb.OveralChangeBroker,0)&lt;=bcb.Q2 then 3&#xA;when isnull(bcb.OveralChangeBroker,0) &gt; bcb.Q2 and isnull(bcb.OveralChangeBroker,0)&lt;=bcb.Q3 then 2 &#xA;when isnull(bcb.OveralChangeBroker,0) &gt; bcb.Q3 then 1 else 4 end as QRankChangeBroker,&#xA;isnull(isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker,0) as RankZaribChangeBroker,&#xA;&#xA;&#xA;isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0) as RankZaribOverall,&#xA;&#xA;case when isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0) &#xA;&gt;= 0 &#xA;and &#xA;isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0)&#xA;&lt;=PERCENTILE_CONT(0.25) WITHIN GROUP (ORDER BY isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0))   &#xA;                            OVER (PARTITION BY db.PersianYearMonthInt,db.BranchIsBranch) then 4&#xA;when isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0)&#xA;&gt; PERCENTILE_CONT(0.25) WITHIN GROUP (ORDER BY isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0))   &#xA;                            OVER (PARTITION BY db.PersianYearMonthInt,db.BranchIsBranch)&#xA;and &#xA;isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0)&#xA;&lt;=PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0))   &#xA;                            OVER (PARTITION BY db.PersianYearMonthInt,db.BranchIsBranch) then 3&#xA;when isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0)&#xA;&gt; PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0))   &#xA;                            OVER (PARTITION BY db.PersianYearMonthInt,db.BranchIsBranch)&#xA;and isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0)&#xA;&lt;=PERCENTILE_CONT(0.75) WITHIN GROUP (ORDER BY isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0))   &#xA;                            OVER (PARTITION BY db.PersianYearMonthInt,db.BranchIsBranch) then 2 &#xA;when isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0)&#xA;&gt; PERCENTILE_CONT(0.75) WITHIN GROUP (ORDER BY isnull(( 0.15*isnull(bcb.OveralChangeBroker,0) / ocb.OveralChangeBroker ),0)+&#xA;isnull((0.1*isnull(br.OveralRegistered,0)/ocr.OveralRegistered),0)+&#xA;isnull((0.75*isnull(bc.BrokerCommission,0)/oc.BrokerCommission),0))   &#xA;                            OVER (PARTITION BY db.PersianYearMonthInt,db.BranchIsBranch) then 1 else 4 end as FinalRank&#xA;&#xA;into AutomationDW.dbo.FactBranchMonthlyRank&#xA;from tempdb.dbo.DimMonthBranch db&#xA;join [tempdb].[dbo].[BranchCommission] bc on &#xA;db.PersianYearMonthInt = bc.PersianYearMonthInt and &#xA;db.BranchIsBranch = bc.BranchIsBranch and &#xA;db.BranchId = bc.BranchId&#xA;&#xA;left join [tempdb].[dbo].[OveralCommission] oc on&#xA;db.PersianYearMonthInt = oc.PersianYearMonthInt and &#xA;db.BranchIsBranch = oc.BranchIsBranch&#xA;&#xA;left join [tempdb].[dbo].[BranchRegistered] br on&#xA;db.PersianYearMonthInt = br.PersianYearMonthInt and &#xA;db.BranchIsBranch = br.BranchIsBranch and &#xA;db.BranchId = br.BranchId&#xA;&#xA;left join [tempdb].[dbo].[OveralRegistered] ocr on&#xA;db.PersianYearMonthInt = ocr.PersianYearMonthInt and &#xA;db.BranchIsBranch = ocr.BranchIsBranch&#xA;&#xA;&#xA;left join [tempdb].[dbo].[BranchChangeBroker] bcb on&#xA;db.PersianYearMonthInt = bcb.PersianYearMonthInt and &#xA;db.BranchIsBranch = bcb.BranchIsBranch and &#xA;db.BranchId = bcb.BranchId&#xA;&#xA;left join [tempdb].[dbo].[OveralChangeBroker] ocb on&#xA;db.PersianYearMonthInt = ocb.PersianYearMonthInt and &#xA;db.BranchIsBranch = ocb.BranchIsBranch" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
