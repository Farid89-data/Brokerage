          SQLTask:SqlStatementSource=" ALTER TABLE  [AutomationDW].[dbo].[FactFeutureTrade] REBUILD WITH (DATA_COMPRESSION=PAGE)&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
