      <DTS:Executables>
        <DTS:Executable
          DTS:refId="Package\FactFeutureTrade(AutomationDW)\Merge Source With Target"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{7578420e-e754-4d07-b81c-698a2e3c9a84}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Merge Source With Target"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="&#xA;  MERGE [FactFeutureTrade] AS TARGET&#xA;USING RawDB.[bi].[FeutureTrade] AS SOURCE &#xA;ON (TARGET.Id = SOURCE.ID) &#xA;WHEN MATCHED AND TARGET.[HashValue] &lt;&gt; (HASHBYTES('MD5', CONCAT_WS('|',&#xA;       source.[Id]&#xA;      ,source.[FeutureInstrumentId]&#xA;      ,source.[FeutureCommodityId]&#xA;      ,source.[OrderSide]&#xA;      ,source.[Quantity]&#xA;      ,source.[Price]&#xA;      ,SOURCE.[Price]*SOURCE.[Quantity]&#xA;&#x9;  ,source.[DateTime]&#xA;      ,CONVERT(DATE,source.[DateTime],120)&#xA;      ,source.[IsOnline]&#xA;      ,source.[CustomerId]&#xA;&#x9;  ,SOURCE.BrokerCommission&#xA;)))&#xA;THEN UPDATE SET &#xA;       target.[Id]                      = ISNULL(SOURCE.Id,-1)&#xA;      ,target.[FeutureInstrumentId]&#x9;&#x9;=ISNULL(SOURCE.FeutureInstrumentId,-1)&#xA;      ,target.[FeutureCommodityId]&#x9;&#x9;=ISNULL(SOURCE.FeutureCommodityId,-1)&#xA;      ,target.[OrderSide]&#x9;&#x9;&#x9;&#x9;=ISNULL(SOURCE.OrderSide,0)&#xA;      ,target.[Quantity]&#x9;&#x9;&#x9;&#x9;=ISNULL(SOURCE.Quantity,0)&#xA;      ,target.[Price]&#x9;&#x9;&#x9;&#x9;&#x9;=ISNULL(SOURCE.Price,0)&#xA;      ,target.[TradeValue]&#x9;&#x9;&#x9;&#x9;=ISNULL(SOURCE.Quantity,0)*ISNULL(SOURCE.Price,0)&#xA;      ,target.[DateTime]&#x9;&#x9;&#x9;&#x9;=ISNULL(SOURCE.DateTime,'1921-03-21')&#xA;      ,target.[Date]&#x9;&#x9;&#x9;&#x9;&#x9;=ISNULL(CONVERT(DATE,SOURCE.DateTime,120),'1921-03-21')&#xA;      ,target.[IsOnline]&#x9;&#x9;&#x9;&#x9;=ISNULL(SOURCE.IsOnline,0)&#xA;      ,target.[CustomerId]&#x9;&#x9;&#x9;&#x9;=ISNULL(SOURCE.CustomerId,-1)&#xA;      ,target.BrokerCommission&#x9;&#x9;&#x9;=ISNULL(SOURCE.BrokerCommission,0)&#xA;&#xA;&#xA;WHEN NOT MATCHED BY TARGET &#xA;THEN INSERT (&#xA;      [Id]&#xA;      ,[FeutureInstrumentId]&#xA;      ,[FeutureCommodityId]&#xA;      ,[OrderSide]&#xA;      ,[Quantity]&#xA;      ,[Price]&#xA;      ,[TradeValue]&#xA;      ,[DateTime]&#xA;      ,[Date]&#xA;      ,[IsOnline]&#xA;      ,[CustomerId]&#xA;&#x9;  ,BrokerCommission&#xA;&#xA;      )&#xA;VALUES&#xA;(      SOURCE.[Id]&#xA;      ,SOURCE.[FeutureInstrumentId]&#xA;      ,SOURCE.[FeutureCommodityId]&#xA;      ,SOURCE.[OrderSide]&#xA;      ,SOURCE.[Quantity]&#xA;      ,SOURCE.[Price]&#xA;      ,SOURCE.[Price]*SOURCE.[Quantity]&#xA;      ,SOURCE.[DateTime]&#xA;      ,CONVERT(DATE,SOURCE.[DateTime],120)&#xA;      ,SOURCE.[IsOnline]&#xA;      ,SOURCE.[CustomerId]&#xA;      ,SOURCE.BrokerCommission&#xA;&#xA;);&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:Executable>
