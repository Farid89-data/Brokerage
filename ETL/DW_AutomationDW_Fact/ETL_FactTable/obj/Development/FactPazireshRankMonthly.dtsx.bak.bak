          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="drop table if exists&#xA;tempdb.dbo.TempUserChangeBroker&#xA;,tempdb.dbo.TempUserChangeBrokerMonthly&#xA;,tempdb.dbo.TempUserRegitered&#xA;,tempdb.dbo.TempUserRegiteredMonthly&#xA;,tempdb.dbo.TempUserIntroduced&#xA;,tempdb.dbo.TempUserIntroducedMonthly&#xA;,tempdb.dbo.TempUserYearMonth&#xA;,tempdb.dbo.[PazireshAbsoluteAbsence]" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create  Change Broker"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{96C59CF7-B623-4BA1-9B61-2E6B907BA7A3}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create  Change Broker"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="1">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="----change broker&#xA;drop table if exists tempdb.dbo.TempUserChangeBroker&#xA;&#xA;select UserId,PersianYearMonthInt,count(*) as CbCount&#xA;&#x9;,DENSE_RANK() OVER (PARTITION BY PersianYearMonthInt ORDER BY count(*) asc) AS Rank&#xA;into tempdb.dbo.TempUserChangeBroker&#xA;from FactChangeBroker fcb&#xA;join dimdate dd on dd.GregorianDate = fcb.Date&#xA;where fcb.ChangeBrokerStateId = 4 and UserId &gt;-1 and PersianYearMonthInt&gt;=139801&#xA;group by UserId,PersianYearMonthInt&#xA;order by PersianYearMonthInt,CbCount" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create  ChangeBrokerMonthly"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{32CE310A-339F-4F6B-8BAE-D1F7087FA135}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create  ChangeBrokerMonthly"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="1">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="-----------------------ChangeBrokerMonthly&#xA;&#xA;drop table if exists tempdb.dbo.TempUserChangeBrokerMonthly&#xA;select PersianYearMonthInt, sum(CbCount) as MonthCbCount,&#xA;max(CbCount) as MaxCbCount ,min(CbCount)as MinCbCount,avg(CbCount) as AvgCbCount, max(Rank) as MaxRankCbCount&#xA;into tempdb.dbo.TempUserChangeBrokerMonthly&#xA;from tempdb.dbo.TempUserChangeBroker&#xA;group by PersianYearMonthInt" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create  Introduce User"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{A24ABC71-463A-4E5E-8C00-A0287973AA2F}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create  Introduce User"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="2">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="-----Introduce User&#xA;drop table if exists tempdb.dbo.TempUserIntroduced&#xA;&#xA;select du.UserID,PersianYearMonthInt,count(*) as IntruducedCount &#xA;,DENSE_RANK() OVER (PARTITION BY PersianYearMonthInt ORDER BY count(*) asc) AS Rank&#xA;into tempdb.dbo.TempUserIntroduced&#xA;from DimCustomer dc&#xA;join dimdate dd on dd.GregorianDate = dc.StartDate&#xA;join DimUser du on dc.IntroducerPersonId = du.PersonId&#xA;where du.userid&gt;-1 and PersianYearMonthInt&gt;=139801&#xA;group by du.UserID,PersianYearMonthInt&#xA;order by PersianYearMonthInt desc&#xA;------------------------------------------" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create  PazireshAbsoluteAbsence"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{530fb130-4308-4e80-9969-e56f5f655178}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create  PazireshAbsoluteAbsence"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="------PazireshAbsoluteAbsence&#xA;drop table if exists tempdb.dbo.[PazireshAbsoluteAbsence]&#xA;Select PersianYearMonth,UserId,[PazireshAbsoluteAbsenceHour],&#xA;case when [PazireshAbsoluteAbsenceHour] &gt;=0 then 5 &#xA;when [PazireshAbsoluteAbsenceHour] &lt;0 and [PazireshAbsoluteAbsenceHour] &gt;= -16 then 4&#xA;when [PazireshAbsoluteAbsenceHour] &lt;-16 and [PazireshAbsoluteAbsenceHour] &gt;= -32 then 3&#xA;when [PazireshAbsoluteAbsenceHour] &lt;-32 and [PazireshAbsoluteAbsenceHour] &gt;= -48 then 2&#xA;when [PazireshAbsoluteAbsenceHour] &lt;-48 and [PazireshAbsoluteAbsenceHour] &gt;= -64 then 1&#xA;when [PazireshAbsoluteAbsenceHour] &lt;-64 then 0 end as UserAbsenceMark&#xA;into tempdb.dbo.[PazireshAbsoluteAbsence]&#xA;from AutomationDW.dbo.FactAttendanceData&#xA;&#xA;order by PersianYearMonth desc,UserAbsenceMark desc" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create  UserIntroducedMonthly"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{529E06A3-C06A-4BE0-9EFE-344069C8A816}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create  UserIntroducedMonthly"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="2">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="------------------------------------------UserIntroducedMonthly&#xA;drop table if exists tempdb.dbo.TempUserIntroducedMonthly&#xA;&#xA;select PersianYearMonthInt, sum(IntruducedCount) as MonthIntruducedCount,max(IntruducedCount) as MaxIntruducedCount ,&#xA;min(IntruducedCount)as MinIntruducedCount,avg(IntruducedCount) as AvgIntruducedCount, max(Rank) as MaxRankIntruducedCount&#xA;into tempdb.dbo.TempUserIntroducedMonthly&#xA;from tempdb.dbo.TempUserIntroduced&#xA;group by PersianYearMonthInt&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create  UserRegitered"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{602B9DE7-35A2-4EC1-8826-B82AD45327B7}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create  UserRegitered"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="4">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="-----Register&#xA;drop table if exists tempdb.dbo.TempUserRegitered&#xA;&#xA;select InsertUserId,PersianYearMonthInt,count(*) as InsertedUser,&#xA;DENSE_RANK() OVER (PARTITION BY PersianYearMonthInt ORDER BY count(*) asc) AS Rank&#xA;into tempdb.dbo.TempUserRegitered&#xA;from DimCustomer dc&#xA;join dimdate dd on dd.GregorianDate = dc.StartDate&#xA;where InsertUserId&gt;-1 and PersianYearMonthInt&gt;=139801&#xA;group by InsertUserId,PersianYearMonthInt&#xA;order by PersianYearMonthInt desc" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create Overall UserRegiteredMonthly"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{4551CE23-EFDF-4BEA-970C-1B1E320BA65E}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create Overall UserRegiteredMonthly"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="4">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="--------------------------------------UserRegiteredMonthly&#xA;&#xA;drop table if exists tempdb.dbo.TempUserRegiteredMonthly&#xA;select PersianYearMonthInt, sum(InsertedUser) as MonthInsertedUser,max(InsertedUser) as MaxInsertedUser ,min(InsertedUser)as MinInsertedUser,avg(InsertedUser) as AvgInsertedUser, max(Rank) as MaxRankInsertedUser&#xA;into tempdb.dbo.TempUserRegiteredMonthly&#xA;from tempdb.dbo.TempUserRegitered&#xA;group by PersianYearMonthInt&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\Drop- Create UserYearMonth"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{9CC4AC92-F809-4F66-AAB6-DE30A061A884}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Drop- Create UserYearMonth"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="3">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="----TempUserYearMonth-&#xA;drop table if exists tempdb.dbo.TempUserYearMonth&#xA;&#xA;Select distinct InsertUserId,PersianYearMonthInt &#xA;into tempdb.dbo.TempUserYearMonth&#xA;from DimCustomer dc,DimDatePersianMonth&#xA;where PersianYearMonthInt between 139801 and (select PersianYearMonthInt  from Dimdate where GregorianDate = convert(date,GETDATE()))&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
        <DTS:Executable
          DTS:refId="Package\MainPackage\FactPazireshRankMonthly"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{A6E04B98-D777-4DAB-A0B9-62C6DD1BE0E6}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="FactPazireshRankMonthly"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="-------FactPazireshRankMonthly&#xA;Drop Table if exists automationdw.dbo.FactPazireshRankMonthly&#xA;&#xA;Select uym.PersianYearMonthInt,UYM.InsertUserId as UserId,&#xA;isnull(ucb.CbCount,0) as CbCount ,isnull(0.4*(ucb.CbCount*5/UCBM.MaxCbCount)+0.6*(ucb.Rank*5/UCBM.MaxRankCbCount),0) as CBUserMark,&#xA;isnull(ur.InsertedUser,0) as RegisteredUser,isnull(0.4*(ur.InsertedUser*5/urm.MaxInsertedUser)+0.6*(ur.Rank*5/urm.MaxRankInsertedUser),0) as RegUserMark,&#xA;isnull(ui.IntruducedCount,0) as IntruducedUser,isnull(0.4*(ui.IntruducedCount*5/uim.MaxIntruducedCount)+0.6*(5*ui.Rank/uim.MaxRankIntruducedCount),0) as IntruducedUserMark,&#xA;isnull(paa.[PazireshAbsoluteAbsenceHour],0) as [PazireshAbsoluteAbsenceHour],paa.UserAbsenceMark,&#xA;isnull(0.4*(ucb.CbCount*5/UCBM.MaxCbCount)+0.6*(ucb.Rank*5/UCBM.MaxRankCbCount),0) * 1.5 + &#xA;isnull(0.4*(ur.InsertedUser*5/urm.MaxInsertedUser)+0.6*(ur.Rank*5/urm.MaxRankInsertedUser),0) * 1.25 +&#xA;isnull(0.4*(ui.IntruducedCount*5/uim.MaxIntruducedCount)+0.6*(5*ui.Rank/uim.MaxRankIntruducedCount),0) * 2 +&#xA;paa.UserAbsenceMark*1.25&#xA;as UserFinalMarK&#xA;Into automationdw.dbo.FactPazireshRankMonthly&#xA;from tempdb.dbo.TempUserYearMonth UYM&#xA;left join tempdb.dbo.TempUserChangeBroker UCB on UYM.PersianYearMonthInt=ucb.PersianYearMonthInt and uym.InsertUserId=ucb.UserId&#xA;left join tempdb.dbo.TempUserChangeBrokerMonthly UCBM on UYM.PersianYearMonthInt=ucbm.PersianYearMonthInt &#xA;left join tempdb.dbo.TempUserRegitered UR on UYM.PersianYearMonthInt=ur.PersianYearMonthInt and uym.InsertUserId=ur.InsertUserId&#xA;left join tempdb.dbo.TempUserRegiteredMonthly URM on UYM.PersianYearMonthInt=urm.PersianYearMonthInt&#xA;left join tempdb.dbo.TempUserIntroduced Ui on UYM.PersianYearMonthInt=ui.PersianYearMonthInt and uym.InsertUserId=ui.UserID&#xA;left join tempdb.dbo.TempUserIntroducedMonthly Uim on UYM.PersianYearMonthInt=uim.PersianYearMonthInt &#xA;left join tempdb.dbo.[PazireshAbsoluteAbsence] PAA on UYM.PersianYearMonthInt=Paa.PersianYearMonth and uym.InsertUserId=PAA.UserID&#xA;&#xA;order by uym.PersianYearMonthInt desc,CbCount desc" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
