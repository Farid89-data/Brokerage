        <DTS:Executable
          DTS:refId="Package\FactClubMemberScore(AutomationDW)\Merge Source With Target"
          DTS:CreationName="Microsoft.ExecuteSQLTask"
          DTS:Description="Execute SQL Task"
          DTS:DTSID="{2d3d4475-1541-44b9-9c55-110dde142550}"
          DTS:ExecutableType="Microsoft.ExecuteSQLTask"
          DTS:LocaleID="-1"
          DTS:ObjectName="Merge Source With Target"
          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{DEF3454D-A45D-4DE8-9AED-58A2227637E4}"
              SQLTask:SqlStatementSource="&#xA;  MERGE [FactClubMemberScore] AS TARGET&#xA;USING RawDB.[bi].[ClubMemberScore] AS SOURCE &#xA;ON (TARGET.Id = SOURCE.ID) &#xA;WHEN MATCHED AND TARGET.[HashValue] &lt;&gt; (HASHBYTES('MD5', CONCAT_WS('|',&#xA;       SOURCE.[Id]&#xA;      ,SOURCE.[ClubMemberId]&#xA;      ,SOURCE.[CustomerId]&#xA;      ,SOURCE.[DateTime]&#xA;      ,CONVERT(DATE, SOURCE.[DateTime],120)&#xA;      ,SOURCE.[ScoreTypeId]&#xA;      ,SOURCE.[Score]&#xA;)))&#xA;THEN UPDATE SET &#xA;Target.[Id]&#x9;&#x9;&#x9;&#x9;&#x9;= ISNULL(Source.[Id],-1)&#xA;, Target.[ClubMemberId]&#x9;&#x9;=ISNULL( Source.[ClubMemberId],-1)&#xA;, Target.[CustomerId]&#x9;&#x9;&#x9;=ISNULL(Source.[CustomerId],-1)&#xA;, Target.[DateTime]&#x9;&#x9;&#x9;&#x9;= ISNULL(Source.[DateTime] ,'1921-03-21')&#xA;, Target.[Date]&#x9;&#x9;&#x9;&#x9;= ISNULL(CONVERT(Date,SOURCE.DateTime,120) ,'1921-03-21')&#xA;, Target.[ScoreTypeId]&#x9;&#x9;&#x9;&#x9;=ISNULL(  Source.[ScoreTypeId],-1)&#xA;, Target.[Score]&#x9;&#x9;&#x9;&#x9;&#x9;=ISNULL(  Source.[Score],0)&#xA;&#xA;&#xA;&#xA;WHEN NOT MATCHED BY TARGET &#xA;THEN INSERT (&#xA;       [Id]&#xA;      ,[ClubMemberId]&#xA;&#x9;  ,[CustomerId]&#xA;      ,[DateTime]&#xA;      ,[Date]&#xA;      ,[ScoreTypeId]&#xA;      ,[Score]&#xA;      )&#xA;VALUES&#xA;(      source.[Id]&#xA;&#x9;  ,SOURCE.[ClubMemberId]&#xA;      ,source.[CustomerId]&#xA;      ,source.[DateTime]&#xA;      ,CONVERT(Date,SOURCE.DateTime,120) &#xA;      ,source.[ScoreTypeId]&#xA;      ,source.[Score]&#xA;&#xA;);&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
    </DTS:Executable>
