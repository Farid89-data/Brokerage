              SQLTask:SqlStatementSource="&#xA;  IF  object_id(N'AutomationDW.dbo.DimFeutureInstrument', 'U') is null&#xA;&#xA;&#x9;BEGIN&#xA;&#x9;&#x9;SELECT DISTINCT  &#xA;&#x9;&#x9;&#x9;  [FeutureInstrumentId]&#xA;&#x9;&#x9;&#x9;  ,[ContractDescription]&#xA;&#x9;&#x9;&#x9;  ,[FeutureCommodityId]&#xA;&#x9;&#x9;&#x9;  ,[FeutureCommodityName]&#xA;&#xA;&#x9;&#x9;&#x9;  INTO AutomationDW.dbo.DimFeutureInstrument&#xA;&#xA;&#x9;&#x9;  FROM [RawDB].[bi].[FeutureTrade]&#xA;&#x9;&#x9;  INSERT AutomationDW.dbo.DimFeutureInstrument ([FeutureInstrumentId]&#xA;&#x9;&#x9;&#x9;  ,[ContractDescription]&#xA;&#x9;&#x9;&#x9;  ,[FeutureCommodityId]&#xA;&#x9;&#x9;&#x9;  ,[FeutureCommodityName])&#xA;&#x9;&#x9;&#x9;  VALUES (-1,N'نامشخص',-1,N'نامشخص')&#xA;&#x9;END&#xA;ELSE&#xA;&#x9;BEGIN&#xA;&#x9;  TRUNCATE TABLE AutomationDW.dbo.DimFeutureInstrument&#xA;&#xA;  &#x9;&#x9;  INSERT AutomationDW.dbo.DimFeutureInstrument ([FeutureInstrumentId]&#xA;&#x9;&#x9;&#x9;  ,[ContractDescription]&#xA;&#x9;&#x9;&#x9;  ,[FeutureCommodityId]&#xA;&#x9;&#x9;&#x9;  ,[FeutureCommodityName])&#xA;&#x9;&#x9;&#x9;  VALUES (-1,N'نامشخص',-1,N'نامشخص')&#xA;&#xA;&#xA;&#x9;  INSERT AutomationDW.dbo.DimFeutureInstrument ([FeutureInstrumentId]&#xA;&#x9;&#x9;&#x9;  ,[ContractDescription]&#xA;&#x9;&#x9;&#x9;  ,[FeutureCommodityId]&#xA;&#x9;&#x9;&#x9;  ,[FeutureCommodityName])&#xA;&#x9;&#x9;  &#x9;&#x9;SELECT DISTINCT  &#xA;&#x9;&#x9;&#x9;  [FeutureInstrumentId]&#xA;&#x9;&#x9;&#x9;  ,[ContractDescription]&#xA;&#x9;&#x9;&#x9;  ,[FeutureCommodityId]&#xA;&#x9;&#x9;&#x9;  ,[FeutureCommodityName]&#xA;&#x9;&#x9;  &#xA;&#x9;&#x9;  FROM [RawDB].[bi].[FeutureTrade]&#xA;&#x9;END" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
