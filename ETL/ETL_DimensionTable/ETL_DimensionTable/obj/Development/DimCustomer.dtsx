          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{67048846-090F-4BFA-824D-4D8BB471F18C}"
              SQLTask:SqlStatementSource="  DROP TABLE IF EXISTS  [Automation].[dbo].[DimCustomerTemp]&#xA;&#xA;&#xA;CREATE TABLE Automation.dbo.DimCustomerTemp (&#xA;  Id INT NULL&#xA; ,PersonId INT NULL&#xA; ,ClubMemberId INT NULL&#xA; ,IsClubMember INT NULL&#xA; ,IsFromSejam INT NULL&#xA; ,PersonTypeId INT NULL&#xA; ,PersonName NVARCHAR(100) NULL&#xA; ,GenderId INT NULL&#xA; ,MarriedStateId INT NULL&#xA; ,MilitaryStateId INT NULL&#xA; ,FatherName NVARCHAR(30) NULL&#xA; ,NationalCode NVARCHAR(20) NULL&#xA; ,BirthDate DATE NULL&#xA; ,RegistrationDate DATE NULL&#xA; ,BirthCityId INT NULL&#xA; ,RegistrationCityId INT NULL&#xA; ,EconomicCode NVARCHAR(30) NULL&#xA; ,StockIntroductionId INT NULL&#xA; ,IntroducerGenderId INT NULL&#xA; ,IntroducerHomeLocationId INT NULL&#xA; ,JobId INT NULL&#xA; ,Credit MONEY NULL&#xA; ,StationCredit MONEY NULL&#xA; ,IsClubMemberName NVARCHAR(20) NULL&#xA; ,IsFromSejamName NVARCHAR(20) NULL&#xA; ,PersonTypeName NVARCHAR(50) NULL&#xA; ,GenderName NVARCHAR(50) NULL&#xA; ,MarriedStateName NVARCHAR(50) NULL&#xA; ,MilitaryStateName NVARCHAR(50) NULL&#xA; ,BirthCityName NVARCHAR(30) NULL&#xA; ,BirthStateName NVARCHAR(20) NULL&#xA; ,RegistrationCityName NVARCHAR(30) NULL&#xA; ,RegistrationStateName NVARCHAR(20) NULL&#xA; ,StockIntroductionName NVARCHAR(50) NULL&#xA; ,IntroducerGenderName NVARCHAR(50) NULL&#xA; ,IntroducerCityName NVARCHAR(30) NULL&#xA; ,IntroducerStateName NVARCHAR(20) NULL&#xA; ,JobName NVARCHAR(50) NULL&#xA; ,StockTypeId INT NULL&#xA; ,BranchId INT NULL&#xA; ,StartDate DATE NULL&#xA; ,MarketerId INT NULL&#xA; ,InsertUserId INT NULL&#xA; ,BourseCode NVARCHAR(20) NULL&#xA; ,ClientAccountNumber NVARCHAR(20) NULL&#xA; ,StockTypeName NVARCHAR(50) NULL&#xA; ,BranchName NVARCHAR(40) NULL&#xA; ,CityNameBranch NVARCHAR(30) NULL&#xA; ,StateNameBranch NVARCHAR(20) NULL&#xA; ,BranchStatusID INT NULL&#xA; ,BranchStatusName NVARCHAR(50) NULL&#xA; ,MarketerName NVARCHAR(100) NULL&#xA; ,MarketerIsActiveName NVARCHAR(10) NULL&#xA; ,MarketerPersonTypeName NVARCHAR(8) NULL&#xA; ,MarketerGenderName NVARCHAR(10) NULL&#xA; ,InsertPersonName NVARCHAR(100) NULL&#xA; ,InsertGenderName NVARCHAR(10) NULL&#xA; ,BranchCityID INT NULL&#xA; ,InsertUserGenderID INT NULL&#xA; ,[IntroducerPersonId] INT&#xA; ,[IntroducerPersonName] NVARCHAR(100) NULL&#xA; ,ClubMembershipDate DATE&#xA;  ,Available_bonus FLOAT NULL&#xA; ,Reserved_bonus INT NULL&#xA; ,IsStockMarketCustomer INT NULL&#xA; ,IsKalaCustomer INT NULL&#xA; ,IsEnergyCustomer INT NULL&#xA; ,IsAtiCustomer INT NULL&#xA; ,First_name NVARCHAR(100) NULL&#xA; ,Last_name NVARCHAR(100) NULL&#xA;  ,CodeAccount NVARCHAR(20) NULL&#xA;   ,IsForeigner BIT NULL&#xA;      ,[EducationName] nvarchar(50)&#xA;      ,[MonthlySalary] money&#xA;      ,[TransactionLevel] nvarchar(50)&#xA; ,HashValue AS (HASHBYTES('MD5', CONCAT_WS('|', ISNULL([PersonId], (-1)), ISNULL([ClubMemberId], (-1)), ISNULL([IsClubMember], (-1)),&#xA; ISNULL([IsClubMemberName], N'نامشخص'), ISNULL([IsFromSejam], (-1)), ISNULL([IsFromSejamName], N'نامشخص'), ISNULL([PersonTypeId], &#xA; (-1)), ISNULL([PersonTypeName], N'نامشخص'), ISNULL([PersonName], N'نامشخص'), ISNULL([GenderId], (-1)), ISNULL([GenderName], N'نامشخص'),&#xA; ISNULL([MarriedStateId], (-1)), ISNULL([MarriedStateName], N'نامشخص'), ISNULL([MilitaryStateId], (-1)), ISNULL([MilitaryStateName], N'نامشخص'),&#xA; ISNULL([FatherName], N'نامشخص'), ISNULL([NationalCode], (-1)), ISNULL([BirthDate], '1921-03-21'), ISNULL([RegistrationDate], '1921-03-21'), &#xA; ISNULL([BirthCityId], (-1)), ISNULL([BirthCityName], N'نامشخص'), ISNULL([BirthStateName], N'نامشخص'), ISNULL([RegistrationCityId], (-1)),&#xA; ISNULL([RegistrationCityName], N'نامشخص'), ISNULL([RegistrationStateName], N'نامشخص'), ISNULL([EconomicCode], (-1)), ISNULL([StockIntroductionId], (-1)),&#xA; ISNULL([StockIntroductionName], N'نامشخص'), ISNULL([IntroducerGenderId], (-1)), ISNULL([IntroducerGenderName], N'نامشخص'), ISNULL([IntroducerHomeLocationId],&#xA; (-1)), ISNULL([IntroducerCityName], N'نامشخص'), ISNULL([IntroducerStateName], N'نامشخص'), ISNULL([JobId], (-1)), ISNULL([JobName], N'نامشخص'), ISNULL([StockTypeId],&#xA; (-1)), ISNULL([StockTypeName], N'نامشخص'), ISNULL([BranchId], (-1)), ISNULL([BranchName], N'نامشخص'), [BranchCityID], ISNULL([CityNameBranch], N'نامشخص'), &#xA; ISNULL([StateNameBranch], N'نامشخص'), ISNULL([StartDate], '1921-03-21'), ISNULL([MarketerId], (-1)), ISNULL([MarketerName], N'نامشخص'), &#xA; ISNULL([MarketerGenderName], N'نامشخص'), ISNULL([MarketerIsActiveName], N'نامشخص'), ISNULL([MarketerPersonTypeName], N'نامشخص'), ISNULL([InsertUserId], (-1)),&#xA; ISNULL([InsertPersonName], N'نامشخص'), [InsertUserGenderID], ISNULL([InsertGenderName], N'نامشخص'), ISNULL([BourseCode], N'نامشخص'), ISNULL([ClientAccountNumber],&#xA; (-1)), ISNULL([Credit], (-1)), ISNULL([StationCredit], (-1)),ISNULL([IntroducerPersonId],-1),IntroducerPersonName,ClubMembershipDate ,Available_bonus&#xA; ,Reserved_bonus&#xA; ,IsStockMarketCustomer&#xA; ,IsKalaCustomer&#xA; ,IsEnergyCustomer&#xA; ,IsAtiCustomer&#xA; ,First_name&#xA; ,Last_name,CodeAccount&#xA; ,IsForeigner,&#xA;[EducationName]&#xA; ,[MonthlySalary] &#xA;,[TransactionLevel] ,BranchStatusID ,BranchStatusName&#xA; )))&#xA;&#xA;) &#xA;&#xA;&#xA;  INSERT INTO Automation.dbo.CustomerDW (Id) &#xA;  (&#xA;  SELECT CustomerId FROM [AutomationDW].dbo.FactTrade&#xA;  EXCEPT&#xA;  SELECT Id FROM Automation.dbo.CustomerDW);&#xA;&#xA;  INSERT INTO Automation.dbo.CustomerDW (Id) &#xA;  (&#xA;  SELECT CustomerId FROM PaymentStage.dbo.HistoricalRemain hr&#xA;  EXCEPT&#xA;  SELECT Id FROM Automation.dbo.CustomerDW);" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
