            <SQLTask:SqlTaskData
              SQLTask:Connection="{00BB60CC-9FA4-49A1-82A0-4E564A3BB3DE}"
              SQLTask:SqlStatementSource="  MERGE [AutomationDW].dbo.[DimCustomer] AS TARGET&#xA;USING Automation.[dbo].[DimCustomerTemp] AS SOURCE &#xA;ON (TARGET.[CustomerId] = SOURCE.[Id]) &#xA;--When records are matched, update the records if there is any change&#xA;WHEN MATCHED AND TARGET.Hashvalue &lt;&gt; SOURCE.Hashvalue&#xA;                       &#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#xA;THEN UPDATE SET &#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#xA;&#x9;   Target.[PersonId]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[PersonId]&#xA;  ,    Target.[ClubMemberId]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[ClubMemberId]&#xA;  ,    Target.[IsClubMember]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[IsClubMember]&#xA;  ,    Target.[IsClubMemberName]&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[IsClubMemberName]&#xA;  ,    Target.[IsFromSejam]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[IsFromSejam]&#xA;  ,    Target.[IsFromSejamName]&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[IsFromSejamName]&#xA;  ,    Target.[PersonTypeId]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[PersonTypeId]&#xA;  ,    Target.[PersonTypeName]&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[PersonTypeName]&#xA;  ,    Target.[PersonName]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[PersonName]&#xA;  ,    Target.[GenderId]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[GenderId]&#xA;  ,    Target.[CustomerGenderName]&#x9;&#x9;&#x9;&#x9;=Source.[GenderName]&#xA;  ,    Target.[MarriedStateId]&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[MarriedStateId]&#xA;  ,    Target.[MarriedStateName]&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[MarriedStateName]&#xA;  ,    Target.[MilitaryStateId]&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[MilitaryStateId]&#xA;  ,    Target.[MilitaryStateName]&#x9;&#x9;&#x9;&#x9;=Source.[MilitaryStateName]&#xA;  ,    Target.[FatherName]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[FatherName]&#xA;  ,    Target.[NationalCode]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[NationalCode]&#xA;  ,    Target.[BirthDate]&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;=Source.[BirthDate]&#xA;  ,    Target.[Registr