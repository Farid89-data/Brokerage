          DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
          DTS:ThreadHint="0">
          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{00BB60CC-9FA4-49A1-82A0-4E564A3BB3DE}"
              SQLTask:SqlStatementSource="MERGE [DimMarketer] AS TARGET&#xA;USING Automation.[dbo].[DimMarketerTemp] AS SOURCE &#xA;ON (TARGET.[MarketerId] = SOURCE.[Id]) &#xA;--When records are matched, update the records if there is any change&#xA;WHEN MATCHED AND TARGET.Hashvalue &lt;&gt; SOURCE.Hashvalue&#xA;THEN UPDATE SET &#xA;Target. [StartDate]=Source. [StartDate]&#xA;,Target. [EndDate]=Source. [EndDate]&#xA;,Target. [IsActive]=Source. [IsActive]&#xA;,Target. [PersonId]=Source. [PersonId]&#xA;,Target. [MarketerName]=Source. [MarketerName]&#xA;,Target. [PersonTypeId]=Source. [PersonTypeId]&#xA;,Target. [GenderId]=Source. [GenderId]&#xA;,Target. [HomeLocationId]=Source. [HomeLocationId]&#xA;,Target. [IsActiveName]=Source. [IsActiveName]&#xA;,Target. [PersonTypeName]=Source. [PersonTypeName]&#xA;,Target. [GenderName]=Source. [GenderName]&#xA;,Target. [HomeLocationCityName]=Source. [HomeLocationCityName]&#xA;,Target. [Email]=Source. [Email]&#xA;,Target. [MarketerTypeId]=Source. [MarketerTypeId]&#xA;,Target. [MarketerTypeName]=Source. [MarketerTypeName]&#xA;,Target. [BranchId]=Source. [BranchId]&#xA;,Target. [BranchName]=Source. [BranchName]&#xA;,Target. [BranchCityID]=Source. [BranchCityID]&#xA;,Target. [BranchIsCityName]=Source. [BranchCityName]&#xA;,Target. [BranchIsCityState]=Source. [BranchStateName]&#xA;&#xA;--When no records are matched, insert the incoming records from source table to target table&#xA;WHEN NOT MATCHED BY TARGET &#xA;THEN INSERT (&#xA;       [MarketerId]&#xA;      ,[StartDate]&#xA;      ,[EndDate]&#xA;      ,[IsActive]&#xA;      ,[PersonId]&#xA;      ,[MarketerName]&#xA;      ,[PersonTypeId]&#xA;      ,[GenderId]&#xA;      ,[HomeLocationId]&#xA;      ,[IsActiveName]&#xA;      ,[PersonTypeName]&#xA;      ,[GenderName]&#xA;      ,[HomeLocationCityName]&#xA;      ,[Email]&#xA;      ,[MarketerTypeId]&#xA;      ,[MarketerTypeName]&#xA;      ,[BranchId]&#xA;      ,[BranchName]&#xA;      ,[BranchCityID]&#xA;      ,[BranchIsCityName]&#xA;      ,[BranchIsCityState]&#xA;)&#xA;VALUES&#xA;(&#xA;&#x9;   source.[Id]&#xA;      ,source.[StartDate]&#xA;      ,source.[EndDate]&#xA;      ,source.[IsActive]&#xA;      ,source.[PersonId]&#xA;      ,source.[MarketerName]&#xA;      ,source.[PersonTypeId]&#xA;      ,source.[GenderId]&#xA;      ,source.[HomeLocationId]&#xA;      ,source.[IsActiveName]&#xA;      ,source.[PersonTypeName]&#xA;      ,source.[GenderName]&#xA;      ,source.[HomeLocationCityName]&#xA;      ,source.[Email]&#xA;      ,source.[MarketerTypeId]&#xA;      ,source.[MarketerTypeName]&#xA;      ,source.[BranchId]&#xA;      ,source.[BranchName]&#xA;      ,source.[BranchCityID]&#xA;      ,source.[BranchCityName]&#xA;      ,source.[BranchStateName]&#xA;)&#xA;--When there is a row that exists in target and same record does not exist in source then delete this record target&#xA;WHEN NOT MATCHED BY SOURCE &#xA;THEN  DELETE ;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
      </DTS:Executables>
