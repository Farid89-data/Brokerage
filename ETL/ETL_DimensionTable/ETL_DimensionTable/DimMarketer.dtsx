            <SQLTask:SqlTaskData
              SQLTask:Connection="{67048846-090F-4BFA-824D-4D8BB471F18C}"
              SQLTask:SqlStatementSource="DROP TABLE IF EXISTS Automation.dbo.DimMarketerTemp&#xA;&#xA;CREATE TABLE Automation.dbo.DimMarketerTemp (&#xA;  Id INT NULL&#xA; ,StartDate DATE NULL&#xA; ,EndDate DATE NULL&#xA; ,IsActive INT NULL&#xA; ,PersonId INT NULL&#xA; ,MarketerName NVARCHAR(100) NULL&#xA; ,PersonTypeId INT NULL&#xA; ,GenderId INT NULL&#xA; ,HomeLocationId INT NULL&#xA; ,BranchId INT NULL&#xA; ,IsActiveName NVARCHAR(10) NULL&#xA; ,PersonTypeName NVARCHAR(8) NULL&#xA; ,GenderName NVARCHAR(10) NULL&#xA; ,HomeLocationCityName NVARCHAR(30) NULL&#xA; ,BranchName NVARCHAR(40) NULL&#xA; ,BranchCityName NVARCHAR(30) NULL&#xA; ,BranchStateName NVARCHAR(30) NULL&#xA; ,BranchCityID INT NULL&#xA; ,Email NVARCHAR(100) NULL&#xA; ,MarketerTypeId INT NULL&#xA; ,MarketerTypeName NVARCHAR(100) NULL&#xA; ,HashValue AS (HASHBYTES('MD5', CONCAT_WS('|', [StartDate], [EndDate], [IsActive], [PersonId], [MarketerName], [PersonTypeId], [GenderId], [HomeLocationId], [IsActiveName], [PersonTypeName], [GenderName], [HomeLocationCityName], [BranchId], [BranchName], [BranchCityID], [BranchCityName], [BranchStateName]&#xA; ,Email&#xA; ,MarketerTypeId&#xA; ,MarketerTypeName&#xA;&#xA;)))&#xA;) " xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
