              SQLTask:Connection="{00BB60CC-9FA4-49A1-82A0-4E564A3BB3DE}"
              SQLTask:SqlStatementSource="DROP TABLE IF EXISTS AutomationDW.dbo.TempDimChangeBrokerState&#xA;&#xA;DROP TABLE IF EXISTS AutomationDW.dbo.TempDimChangeBrokerCancelType&#xA;&#xA;CREATE TABLE AutomationDW.dbo.TempDimChangeBrokerState (&#xA;  DimChangeBrokerState_Id INT NOT NULL&#xA; ,DimChangeBrokerState_Name NVARCHAR(100) NOT NULL&#xA;) ON [PRIMARY]&#xA;GO&#xA;&#xA;CREATE TABLE AutomationDW.dbo.TempDimChangeBrokerCancelType (&#xA;  DimChangeBrokerCancelType_Id INT NOT NULL&#xA; ,DimChangeBrokerCancelType_Name NVARCHAR(200) NOT NULL&#xA;  ,DimChangeBrokerCancelType_ShortName AS (CASE DimChangeBrokerCancelType_Id &#xA;&#x9;WHEN -1 THEN N'نامشخص'&#xA;&#x9;WHEN 1 THEN N'دارایی ندارد'&#xA;&#x9;WHEN 2 THEN N'بدهی در کارگزاری دیگر'&#xA;&#x9;WHEN 3 THEN  N'فریز'&#xA;&#x9;WHEN 4 THEN&#x9; N'عدم خرید'&#xA;&#x9;WHEN 5 THEN&#x9; N'سپرده نشده'&#xA;&#x9;WHEN 6 THEN&#x9; N'دو کده'&#xA;&#x9;WHEN 7 THEN&#x9; N'ضمیمه گواهینامه'&#xA;&#x9;WHEN 8 THEN&#x9; N'سایر'&#xA;&#x9;WHEN 9 THEN&#x9; N'خرید اعتباری'&#xA;&#x9;WHEN 10 THEN N'احراز هویت نشده'&#xA;&#x9;end)&#xA;) ON [PRIMARY]&#xA;GO" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
