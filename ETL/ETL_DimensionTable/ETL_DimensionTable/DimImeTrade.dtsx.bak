        <SQLTask:SqlTaskData
          SQLTask:Connection="{00BB60CC-9FA4-49A1-82A0-4E564A3BB3DE}"
          SQLTask:BypassPrepare="False"
          SQLTask:SqlStatementSource="DROP TABLE IF EXISTS DimImeContractType&#xA;&#xA;SELECT DISTINCT ISNULL(ImeContractTypeId,-1) AS ImeContractTypeId,ISNULL(ImeContractTypeName,N'نامشخص') AS ImeContractTypeName&#xA;INTO DimImeContractType&#xA;FROM RawDB.bi.ImeTrade&#xA;&#xA;&#xA;DROP TABLE IF EXISTS DimImeSettlementType&#xA;&#xA;SELECT DISTINCT ISNULL(ImeSettlementTypeId,-1)AS ImeSettlementTypeId,ISNULL( ImeSettlementTypeName,N'نامشخص')AS ImeSettlementTypeName&#xA;INTO DimImeSettlementType&#xA;FROM RawDB.bi.ImeTrade&#xA;&#xA;&#xA;&#xA;DROP TABLE IF EXISTS DimImeCommodity&#xA;SELECT DISTINCT ISNULL(Comodity_ID,-1) AS Comodity_ID, ISNULL(ImeCommodityName,N'نامشخص') AS ImeCommodityName,&#xA;ISNULL(ImeCommodityGroupId,-1) AS ImeCommodityGroupId,ISNULL(ImeCommodityGroupName,N'نامشخص') AS ImeCommodityGroupName,&#xA;ISNULL(ImeCommoditySubGroupId,-1)AS ImeCommoditySubGroupId, ISNULL(ImeCommoditySubGroupName,N'نامشخص')AS ImeCommoditySubGroupName&#xA;INTO DimImeCommodity&#xA;FROM RawDB.bi.ImeTrade&#xA;&#xA;&#xA;DROP TABLE IF EXISTS DimImeManfacturer&#xA;&#xA;SELECT DISTINCT ISNULL(ImeManfacturerId,-1) AS ImeManfacturerId, ISNULL(ImeManfacturerName,N'نامشخص') AS ImeManfacturerName&#xA;INTO DimImeManfacturer&#xA;FROM RawDB.bi.ImeTrade&#xA;&#xA;&#xA;DROP TABLE IF EXISTS DimImeSupplier&#xA;&#xA;SELECT DISTINCT  ISNULL(ImeSupplierId,-1) AS ImeSupplierId, ISNULL(ImeSupplierName,N'نامشخص') AS ImeSupplierName&#xA;INTO DimImeSupplier&#xA;FROM RawDB.bi.ImeTrade&#xA;&#xA;&#xA;&#xA;&#xA;DROP TABLE IF EXISTS AutomationDw.dbo.DimIMeTradeBrokerName&#xA;&#xA;SELECT DISTINCT BrokerID,BrokerName &#xA;INTO AutomationDw.dbo.DimIMeTradeBrokerName&#xA;FROM (&#xA;SELECT it.BuyerBrokerId AS BrokerID,it.BuyerBrokerName AS BrokerName FROM RawDB.bi.ImeTrade it&#xA;UNION ALL&#xA;SELECT it.SellerBrokerId AS BrokerID, it.SellerBrokerName AS BrokerName FROM RawDB.bi.ImeTrade it) UnionBrokers&#xA;ORDER BY BrokerID&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
