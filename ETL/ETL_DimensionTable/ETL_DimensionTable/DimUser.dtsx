              SQLTask:SqlStatementSource="DROP TABLE IF EXISTS [Automation].[dbo].[DimUserTemp]&#xA;&#xA;CREATE TABLE[Automation].[dbo].[DimUserTemp] (&#xA;UserID Int Not Null&#xA;,PersonId INT NULL&#xA; ,PersonName NVARCHAR(100) NULL&#xA; ,IsActive INT NULL&#xA; ,IsActiveName NVARCHAR(20) NULL&#xA; ,BranchId INT NULL&#xA; ,BranchName NVARCHAR(40) NULL&#xA; ,BranchCityId INT NULL&#xA; ,BranchCityName NVARCHAR(30) NULL&#xA; ,BranchStateName NVARCHAR(30) NULL&#xA; ,GenderId INT NULL&#xA; ,GenderName NVARCHAR(10) NULL&#xA; ,BirthDate Date NULL&#xA; ,HomeLocationId INT NULL&#xA; ,HomeCityName NVARCHAR(30) NULL&#xA; ,HomeStateName NVARCHAR(20) NULL&#xA; ,ContractStartDate DATE NULL&#xA; ,ContractEndDate DATE NULL&#xA;,CompanyName NVARCHAR(100) NULL&#xA;,Code NVARCHAR(30) NULL&#xA;,AttendanceCardNumber NVARCHAR(50) NULL&#xA;,JobTitle NVARCHAR(50) NULL&#xA;,Tel NVARCHAR(100) NULL&#xA;,HashValue AS (HASHBYTES('MD5', CONCAT_WS('|', PersonId,[PersonName], [IsActive], [IsActiveName], [BranchId], [BranchName], [BranchCityName], [BranchCityId], [BranchStateName], [GenderId], [GenderName], [BirthDate], [HomeLocationId], [HomeCityName], [HomeStateName], [ContractStartDate], [ContractEndDate],CompanyName,Code,AttendanceCardNumber,JobTitle,Tel)))&#xA;)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
