          <DTS:Variables />
          <DTS:ObjectData>
            <SQLTask:SqlTaskData
              SQLTask:Connection="{00BB60CC-9FA4-49A1-82A0-4E564A3BB3DE}"
              SQLTask:SqlStatementSource="  MERGE [AutomationDW].[dbo].[DimUser] AS TARGET&#xA;USING [Automation].[dbo].[DimUserTemp] AS SOURCE &#xA;ON (TARGET.[UserID] = SOURCE.UserID) &#xA;--When records are matched, update the records if there is any change&#xA;WHEN MATCHED AND TARGET.Hashvalue &lt;&gt; SOURCE.HashValue&#xA;                       &#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#xA;THEN UPDATE SET &#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#x9;&#xA;Target.[UserID]=Source.[UserID]&#xA;,Target.[PersonId]=Source.[PersonId]&#xA;,Target.[PersonName]=Source.[PersonName]&#xA;,Target.[IsActive]=Source.[IsActive]&#xA;,Target.[IsActiveName]=Source.[IsActiveName]&#xA;,Target.[BranchId]=Source.[BranchId]&#xA;,Target.[BranchName]=Source.[BranchName]&#xA;,Target.[BranchCityId]=Source.[BranchCityId]&#xA;,Target.[BranchCityName]=Source.[BranchCityName]&#xA;,Target.[BranchStateName]=Source.[BranchStateName]&#xA;,Target.[GenderId]=Source.[GenderId]&#xA;,Target.[GenderName]=Source.[GenderName]&#xA;,Target.[BirthDate]=Source.[BirthDate]&#xA;,Target.[HomeLocationId]=Source.[HomeLocationId]&#xA;,Target.[HomeCityName]=Source.[HomeCityName]&#xA;,Target.[HomeStateName]=Source.[HomeStateName]&#xA;,Target.[ContractStartDate]=Source.[ContractStartDate]&#xA;,Target.[ContractEndDate]=Source.[ContractEndDate]&#xA;,Target.[CompanyName]=Source.[CompanyName]&#xA;,Target.[Code]=Source.[Code]&#xA;,Target.[AttendanceCardNumber]=Source.[AttendanceCardNumber]&#xA;,Target.[JobTitle]=Source.[JobTitle]&#xA;,Target.[Tel]=Source.[Tel]&#xA;&#xA;--When no records are matched, insert the incoming records from source table to target table&#xA;WHEN NOT MATCHED BY TARGET &#xA;THEN INSERT (&#xA;[UserID]&#xA;,[PersonId]&#xA;,[PersonName]&#xA;,[IsActive]&#xA;,[IsActiveName]&#xA;,[BranchId]&#xA;,[BranchName]&#xA;,[BranchCityId]&#xA;,[BranchCityName]&#xA;,[BranchStateName]&#xA;,[GenderId]&#xA;,[GenderName]&#xA;,[BirthDate]&#xA;,[HomeLocationId]&#xA;,[HomeCityName]&#xA;,[HomeStateName]&#xA;,[ContractStartDate]&#xA;,[ContractEndDate]&#xA;,[CompanyName]&#xA;,[Code]&#xA;,[AttendanceCardNumber]&#xA;,[JobTitle]&#xA;,[Tel]&#xA;)&#xA;VALUES&#xA;(&#xA;Source.[UserID]&#xA;,Source.[PersonId]&#xA;,Source.[PersonName]&#xA;,Source.[IsActive]&#xA;,Source.[IsActiveName]&#xA;,Source.[BranchId]&#xA;,Source.[BranchName]&#xA;,Source.[BranchCityId]&#xA;,Source.[BranchCityName]&#xA;,Source.[BranchStateName]&#xA;,Source.[GenderId]&#xA;,Source.[GenderName]&#xA;,Source.[BirthDate]&#xA;,Source.[HomeLocationId]&#xA;,Source.[HomeCityName]&#xA;,Source.[HomeStateName]&#xA;,Source.[ContractStartDate]&#xA;,Source.[ContractEndDate]&#xA;,Source.[CompanyName]&#xA;,Source.[Code]&#xA;,Source.[AttendanceCardNumber]&#xA;,Source.[JobTitle]&#xA;,Source.[Tel]&#xA;)&#xA;--When there is a row that exists in target and same record does not exist in source then delete this record target&#xA;WHEN NOT MATCHED BY SOURCE &#xA;THEN  DELETE ;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
          </DTS:ObjectData>
        </DTS:Executable>
