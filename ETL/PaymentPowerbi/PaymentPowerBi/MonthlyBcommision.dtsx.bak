      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{9363122B-FF1B-482D-8CF6-32264B28F06F}"
          SQLTask:SqlStatementSource="TRUNCATE TABLE MonthlyBrokerCommission;&#xA;SET QUOTED_IDENTIFIER ON;&#xA;INSERT INTO [PaymentPowerBI].dbo.[MonthlyBrokerCommission] ([FactTradeCustomerId],[FactTradeBrokerCommission],[PersianYear],[PersianMonth])&#xA;SELECT &#xA;[FactTrade].[CustomerId],&#xA;SUM([FactTrade].[bcom]),&#xA;[DimDate].[PersianYearInt],&#xA;[DimDate].[PersianMonthNo]&#xA;&#xA;  FROM [BI-DB].[AutomationDW].[dbo].[FactTrade] &#xA;JOIN [BI-DB].[AutomationDW].[dbo].[DimDate] ON &#xA;[FactTrade].Date=[DimDate].[GregorianDate]&#xA;where [IsCanceled] = 0&#xA;GROUP BY [DimDate].[PersianYearInt],[DimDate].[PersianMonthNo],[FactTrade].[CustomerId]&#xA;ORDER BY [DimDate].[PersianYearInt],[DimDate].[PersianMonthNo],[FactTrade].[CustomerId] DESC&#xA;&#xA;SET QUOTED_IDENTIFIER ON;  &#xA;&#xA;UPDATE [MonthlyBrokerCommission]&#xA;  SET [PersianMonth] = '0'+[PersianMonth]&#xA;  WHERE [PersianMonth] &lt; 10;&#xA;&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
