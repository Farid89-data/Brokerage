        <SQLTask:SqlTaskData
          SQLTask:Connection="{9363122B-FF1B-482D-8CF6-32264B28F06F}"
          SQLTask:SqlStatementSource=" ALTER TABLE &#xA;CustomerStartDateByMarket&#xA; REBUILD WITH (DATA_COMPRESSION=PAGE)&#xA; &#xA;&#xA;ALTER TABLE &#xA;CustomerStartDateByMarket_Date&#xA; REBUILD WITH (DATA_COMPRESSION=PAGE)" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\CstomerStartDateBy Market &amp; Date"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{09b4fb53-30e8-4d82-b890-3fec1c3e21d8}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="CstomerStartDateBy Market &amp; Date"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{9363122B-FF1B-482D-8CF6-32264B28F06F}"
          SQLTask:SqlStatementSource="  DROP TABLE IF EXISTS CustomerStartDateByMarket;&#xA;  DROP TABLE IF EXISTS CustomerStartDateByMarket_Date;&#xA;&#xA;&#xA;SELECT cst.StartDate  &#xA;,sum(CASE WHEN  cst.StockTypeId = 1 THEN 1 ELSE 0 end )AS Oragh&#xA;,sum(CASE WHEN  cst.StockTypeId = 2 THEN 1 ELSE 0 end )AS Kala&#xA;,sum(CASE WHEN  cst.StockTypeId = 3 THEN 1 ELSE 0 end )AS Energy&#xA;,sum(CASE WHEN  cst.StockTypeId = 4 THEN 1 ELSE 0 end )AS Ati&#xA;,count(*) AS Total&#xA;INTO CustomerStartDateByMarket&#xA;FROM [AutomationDW].dbo.DimCustomer dc&#xA;JOIN RawDB.bi.CustomerStockType cst&#xA;ON dc.CustomerId = cst.CustomerId &#xA;GROUP BY cst.StartDate&#xA;ORDER BY cst.StartDate ASC&#xA;&#xA;--------------------------------------&#xA;--------------------------------------&#xA;SELECT dc.CustomerId  &#xA;,min(CASE WHEN  cst.StockTypeId = 1 THEN cst.StartDate ELSE null end )AS Oragh&#xA;,min(CASE WHEN  cst.StockTypeId = 2 THEN cst.StartDate ELSE null end )AS Kala&#xA;,min(CASE WHEN  cst.StockTypeId = 3 THEN cst.StartDate ELSE null end )AS Energy&#xA;,min(CASE WHEN  cst.StockTypeId = 4 THEN cst.StartDate ELSE null end )AS Ati&#xA;INTO CustomerStartDateByMarket_Date&#xA;FROM [AutomationDW].dbo.DimCustomer dc&#xA;JOIN RawDB.bi.CustomerStockType cst&#xA;ON dc.CustomerId = cst.CustomerId &#xA;GROUP BY dc.CustomerId&#xA;ORDER BY dc.CustomerId ASC" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\Rollback"
