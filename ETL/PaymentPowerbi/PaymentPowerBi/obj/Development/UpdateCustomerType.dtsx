    <DTS:Executable
      DTS:refId="Package\Drop|CorssJoin CustomerTemp"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{7f21d917-642a-47af-b7fc-792ffd060e13}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="Drop|CorssJoin CustomerTemp"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{9363122B-FF1B-482D-8CF6-32264B28F06F}"
          SQLTask:SqlStatementSource="DROP TABLE IF EXISTS CustomerTEMP&#xA;  SELECT dd1.CustomerId,dc1.[persian_year]&#xA;      ,dc1.[persian_month]&#xA;      ,dc1.[PersianYearMonth]&#xA;      ,dc1.[PersianDateKey] &#xA;&#x9;  ,dc1.PersianMonthName&#xA;&#x9;  ,dd1.BranchId&#xA;&#x9;  ,dd1.BranchName&#xA;&#x9;  ,dd1.BranchCityId&#xA;&#x9;  ,dd1.CityNameBranch&#xA;&#x9;  &#x9;  ,dd1.GenderId&#xA;&#x9;  ,dd1.CustomerGenderName&#xA;&#x9;  &#x9;  INTO CustomerTEMP&#xA;&#x9;  FROM  DateCombo dc1 ,&#xA;&#x9;  &#xA;&#x9;  (SELECT &#xA;&#x9;  dc.CustomerId,&#xA;&#x9;  dbl.BranchId&#xA;&#x9;  ,dbl.BranchName&#xA;&#x9;  ,dbl.BranchCityId&#xA;&#x9;  ,dbl.CityNameBranch &#xA;&#x9;  ,dc.GenderId&#xA;&#x9;  ,dc.CustomerGenderName&#xA;&#x9;  FROM [BI-DB].AutomationDW.dbo.DimCustomer dc&#xA;&#x9;  JOIN [BI-DB].AutomationDW.dbo.DimBranchLocation dbl&#xA;&#x9;  ON dc.BranchId = dbl.BranchId&#xA;&#x9;  ) AS dd1&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
    <DTS:Executable
      DTS:refId="Package\OveralSummery"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{32F76472-5E80-4689-9B20-4D18738A3F70}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="OveralSummery"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{9363122B-FF1B-482D-8CF6-32264B28F06F}"
          SQLTask:SqlStatementSource="Drop  TABLE IF EXISTS CustomerTEMP;&#xA;Drop  TABLE IF EXISTS tt;&#xA;&#xA;DROP TABLE IF EXISTS OveralSummery;&#xA;&#xA;SELECT persian_year, persian_month, SUM(CostSum)/SUM(BrokerCommissionSum) AS Div ,SUM(CostSum) AS Costsum,SUM(BrokerCommissionSum) AS BrokerCommissionSum&#xA;INTO OveralSummery&#xA;FROM PaymentPowerBI.dbo.CustomerFinalTableFullInfo &#xA;GROUP BY PersianDateKey,persian_year, persian_month&#xA;ORDER BY PersianDateKey,persian_year, persian_month" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
