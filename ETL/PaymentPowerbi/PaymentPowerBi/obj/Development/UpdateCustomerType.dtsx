      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="TT Calculation"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{9363122B-FF1B-482D-8CF6-32264B28F06F}"
          SQLTask:SqlStatementSource="&#xA;&#xA;DROP TABLE IF EXISTS tt &#xA;SELECT ct.CustomerId, ct.persian_year, ct.persian_month, ct.PersianYearMonth,&#xA;ct.PersianDateKey, ct.PersianMonthName, ct.BranchId, ct.BranchName, ct.BranchCityId,&#xA;ct.CityNameBranch, ct.GenderId, ct.CustomerGenderName, ISNULL(mbc.FactTradeBrokerCommission,0) AS BrokerCommission ,ISNULL( ccim.CostSum,0) AS Cost &#xA;INTO tt&#xA;FROM CustomerTEMP ct &#xA;LEFT JOIN MonthlyBrokerCommission mbc ON ct.PersianYearMonth = mbc.PersianYearMonth AND ct.CustomerId = mbc.FactTradeCustomerId&#xA;LEFT JOIN CustomerCostsInMonth ccim ON ct.PersianYearMonth = ccim.PersianYearMonth AND ct.CustomerId = ccim.CustomerId&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
  </DTS:Executables>
