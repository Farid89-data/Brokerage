    <DTS:Executable
      DTS:refId="Package\CustomerRegisteredByBranch"
      DTS:CreationName="Microsoft.ExecuteSQLTask"
      DTS:Description="Execute SQL Task"
      DTS:DTSID="{F829EE91-20CF-46B4-906C-CEE98E564109}"
      DTS:ExecutableType="Microsoft.ExecuteSQLTask"
      DTS:LocaleID="-1"
      DTS:ObjectName="CustomerRegisteredByBranch"
      DTS:TaskContact="Execute SQL Task; Microsoft Corporation; SQL Server 2019; © 2019 Microsoft Corporation; All Rights Reserved;http://www.microsoft.com/sql/support/default.asp;1"
      DTS:ThreadHint="0">
      <DTS:Variables />
      <DTS:ObjectData>
        <SQLTask:SqlTaskData
          SQLTask:Connection="{9363122B-FF1B-482D-8CF6-32264B28F06F}"
          SQLTask:SqlStatementSource="&#x9;&#x9;DROP TABLE IF EXISTS CustomerRegisteredByBranchTemp;&#xA;&#x9;&#x9;DROP TABLE IF EXISTS CustomerRegisteredByBranch;&#xA;&#x9;SET NOCOUNT ON;&#xA;&#xA;&#xA;&#x9;&#x9;CREATE TABLE PaymentPowerBI.dbo.CustomerRegisteredByBranchTemp (&#xA;  PersianYearInt SMALLINT NULL&#xA; ,PersianHalfYearCode INT NULL&#xA; ,SeasonCode TINYINT NULL&#xA; ,PersianMonthNo TINYINT NULL&#xA; ,PersianYearMonthInt INT null&#xA; ,PersianDayInMonth TINYINT NULL&#xA; ,PersianInt INT NULL&#xA; ,GregorianDate DATE NULL&#xA; ,BranchId INT NOT NULL&#xA; ,GenderId INT NOT NULL&#xA; ,CustomerRegNo INT NULL&#xA; ,UptoNowRegisteredUser AS ([dbo].[UptoNowRegisteredUser]([PersianInt], [BranchId], [GenderId]))&#xA;) ON [PRIMARY]&#xA;&#xA;INSERT INTO PaymentPowerBI.dbo.CustomerRegisteredByBranchTemp &#xA;&#x9;&#x9;SELECT dd.PersianYearInt ,&#xA;&#x9;&#x9;dd.PersianHalfYearCode, &#xA;&#x9;&#x9;dd.SeasonCode,&#xA;&#x9;&#x9;dd.PersianMonthNo ,&#xA;&#x9;&#x9;dd.PersianYearMonthInt,&#xA;&#x9;&#x9;dd.PersianDayInMonth,&#xA;&#x9;&#x9;dd.PersianInt,&#xA;&#x9;&#x9;dd.GregorianDate,&#xA;&#x9;&#x9;dc.BranchId ,&#xA;&#x9;&#x9;dc.GenderId,&#xA;&#x9;&#x9;COUNT(dc.CustomerId) AS CustomerRegNo&#xA;&#x9;&#x9;FROM [AutomationDW].dbo.DimCustomer dc&#xA;&#x9;&#x9;JOIN [AutomationDW].dbo.DimDate dd&#xA;&#x9;&#x9;ON dc.StartDate = dd.GregorianDate&#xA;&#x9;&#x9;GROUP BY dd.PersianYearInt,dd.PersianHalfYearCode,dd.SeasonCode, dd.PersianMonthNo ,dc.BranchId , dd.PersianDayInMonth,dd.PersianInt,dd.GregorianDate , dc.GenderId ,dd.PersianYearMonthInt&#xA;&#x9;&#x9;ORDER BY dd.PersianYearInt DESC,dd.PersianHalfYearCode DESC, dd.SeasonCode DESC, dd.PersianMonthNo DESC ,dd.PersianDayInMonth DESC,dd.PersianInt DESC,dd.GregorianDate DESC, dc.BranchId DESC&#xA;&#xA;&#x9;&#x9;SELECT *&#xA;INTO [CustomerRegisteredByBranch]&#xA;  FROM [PaymentPowerBI].[dbo].[CustomerRegisteredByBranchTemp]&#xA;  &#x9;&#x9;DROP TABLE IF EXISTS CustomerRegisteredByBranchTemp&#xA;&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
      </DTS:ObjectData>
    </DTS:Executable>
