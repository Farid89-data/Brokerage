        <SQLTask:SqlTaskData
          SQLTask:Connection="{9363122B-FF1B-482D-8CF6-32264B28F06F}"
          SQLTask:SqlStatementSource=" ALTER TABLE CustomerRegisteredByBranch REBUILD WITH (DATA_COMPRESSION=PAGE)&#xA;" xmlns:SQLTask="www.microsoft.com/sqlserver/dts/tasks/sqltask" />
