                  name="SqlCommand"
                  UITypeEditor="Microsoft.DataTransformationServices.Controls.ModalMultilineStringEditor, Microsoft.DataTransformationServices.Controls, Version=16.0.0.0, Culture=neutral, PublicKeyToken=89845dcd8080cc91">SELECT 
[CustomerFinalTableFullInfo].persian_year, [CustomerFinalTableFullInfo].persian_month,
   [CustomerFinalTableFullInfo].PersianYearMonth,[CustomerFinalTableFullInfo].PersianDateKey,[CustomerFinalTableFullInfo].[BranchId]
   ,COUNT(*) AS CountInActiveCustomer 
  FROM [PaymentPowerBI].[dbo].[CustomerFinalTableFullInfo]

JOIN (SELECT persian_year, persian_month, PersianYearMonth, PersianDateKey,[BranchId]
  FROM [PaymentPowerBI].[dbo].[CustomerFinalTableFullInfo]
      WHERE [CustomerTypeByCommissionName] = N'مشتری غیر فعال'
  EXCEPT
  SELECT persian_year, persian_month, PersianYearMonth, PersianDateKey,[BranchId]
  FROM [PaymentPowerBI].[dbo].[CustomerFinalTableFullInfo]
  WHERE [CustomerTypeByCommissionName] = N'مشتری فعال') TempTb

  ON [CustomerFinalTableFullInfo].persian_year=TempTb.persian_year AND 
  [CustomerFinalTableFullInfo].persian_month = TempTb.persian_month AND
  [CustomerFinalTableFullInfo].PersianYearMonth=TempTb.PersianYearMonth and
  [CustomerFinalTableFullInfo].PersianDateKey = TempTb.PersianDateKey AND
  [CustomerFinalTableFullInfo].[BranchId]=TempTb.BranchId
      WHERE [CustomerTypeByCommissionName] = N'مشتری غیر فعال'
	  GROUP BY [CustomerFinalTableFullInfo].persian_year, [CustomerFinalTableFullInfo].persian_month,
   [CustomerFinalTableFullInfo].PersianYearMonth,[CustomerFinalTableFullInfo].PersianDateKey,[CustomerFinalTableFullInfo].[BranchId]</property>
